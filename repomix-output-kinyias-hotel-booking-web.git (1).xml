  1: import {
  2:   Injectable,
  3:   ConflictException,
  4:   BadRequestException,
  5:   NotFoundException,
  6: } from '@nestjs/common';
  7: import { PrismaService } from '../prisma/prisma.service';
  8: import * as argon2 from 'argon2';
  9: import { ChangePasswordDto } from '../auth/dto/change-password.dto';
 10: import { ListUsersQuery } from '../users/dto/list-users.query';
 11: import { UpdateMeDto } from '../users/dto/update-me.dto';
 12: const userPublicSelect = {
 13:   id: true,
 14:   email: true,
 15:   firstName: true,
 16:   lastName: true,
 17:   createdAt: true,
 18:   updatedAt: true,
 19:   roles: {
 20:     select: {
 21:       role: {
 22:         select: { id: true, name: true },
 23:       },
 24:     },
 25:   },
 26:   avatar: {
 27:     select: {
 28:       id: true,
 29:       url: true,
 30:       secureUrl: true,
 31:       publicId: true,
 32:     },
 33:   },
 34: };
 35: @Injectable()
 36: export class UsersService {
 37:   constructor(private prisma: PrismaService) {}
 38:   async createLocalUser(
 39:     email: string,
 40:     password: string,
 41:     firstName?: string,
 42:     lastName?: string,
 43:   ) {
 44:     const exists = await this.prisma.user.findUnique({ where: { email } });
 45:     if (exists) throw new ConflictException('Email already in use');
 46:     const passwordHash = await argon2.hash(password, { type: argon2.argon2id });
 47:     return this.prisma.user.create({
 48:       data: { email, passwordHash, firstName, lastName },
 49:     });
 50:   }
 51:   async markEmailVerified(userId: string) {
 52:     return this.prisma.user.update({
 53:       where: { id: userId },
 54:       data: { emailVerified: true },
 55:     });
 56:   }
 57:   async findByEmail(email: string) {
 58:     return this.prisma.user.findUnique({ where: { email } });
 59:   }
 60:   async changePassword(userId: string, dto: ChangePasswordDto) {
 61:     if (dto.newPassword !== dto.confirmPassword) {
 62:       throw new BadRequestException('Passwords do not match');
 63:     }
 64:     const user = await this.prisma.user.findUnique({ where: { id: userId } });
 65:     if (!user?.passwordHash)
 66:       throw new BadRequestException('Password auth not available');
 67:     const ok = await argon2.verify(user.passwordHash, dto.currentPassword);
 68:     if (!ok) throw new BadRequestException('Current password is incorrect');
 69:     const passwordHash = await argon2.hash(dto.newPassword, {
 70:       type: argon2.argon2id,
 71:     });
 72:     await this.prisma.user.update({
 73:       where: { id: userId },
 74:       data: { passwordHash },
 75:     });
 76:     await this.prisma.authSession.deleteMany({ where: { userId } });
 77:     return { ok: true };
 78:   }
 79:   async me(userId: string) {
 80:     const result = await this.prisma.user.findUnique({
 81:       where: { id: userId },
 82:       select: userPublicSelect,
 83:     });
 84:     const allowedActions = await this.getAllowedActions(userId);
 85:     return {
 86:       ...result,
 87:       allowedActions,
 88:     };
 89:   }
 90:   private async getAllowedActions(userId: string): Promise<string[]> {
 91:     const userRoles = await this.prisma.userRole.findMany({
 92:       where: { userId },
 93:       include: {
 94:         role: {
 95:           include: {
 96:             permissions: {
 97:               include: {
 98:                 permission: true,
 99:               },
100:             },
101:           },
102:         },
103:       },
104:     });
105:     const userPermissions = new Set<string>();
106:     userRoles.forEach((ur) =>
107:       ur.role.permissions.forEach((rp) =>
108:         userPermissions.add(rp.permission.name),
109:       ),
110:     );
111:     const apiActions = await this.prisma.apiAction.findMany({
112:       where: { enabled: true },
113:       include: {
114:         policies: {
115:           include: {
116:             permission: true,
117:           },
118:         },
119:       },
120:     });
121:     const allowedActionKeys: string[] = [];
122:     for (const action of apiActions) {
123:       const requiredPermissions = action.policies.map((p) => p.permission.name);
124:       if (requiredPermissions.length === 0) continue;
125:       let hasAccess = false;
126:       if (action.mode === 'ALL') {
127:         hasAccess = requiredPermissions.every((p) => userPermissions.has(p));
128:       } else {
129:         hasAccess = requiredPermissions.some((p) => userPermissions.has(p));
130:       }
131:       if (hasAccess) {
132:         allowedActionKeys.push(action.key);
133:       }
134:     }
135:     return allowedActionKeys.sort();
136:   }
137:   async updateMe(userId: string, dto: UpdateMeDto) {
138:     const user = await this.prisma.user.update({
139:       where: { id: userId },
140:       data: {
141:         ...(dto.firstName !== undefined ? { firstName: dto.firstName } : {}),
142:         ...(dto.lastName !== undefined ? { lastName: dto.lastName } : {}),
143:       },
144:       select: userPublicSelect,
145:     });
146:     return user;
147:   }
148:   async getPublicProfile(requesterId: string, targetUserId: string) {
149:     const user = await this.prisma.user.findUnique({
150:       where: { id: targetUserId },
151:       select: userPublicSelect,
152:     });
153:     if (!user) throw new NotFoundException('User not found');
154:     const isSelf = requesterId === targetUserId;
155:     const isPrivileged = await this.isPrivileged(requesterId);
156:     if (!isSelf && !isPrivileged) {
157:       delete (user as any).email;
158:     }
159:     return user;
160:   }
161:   private async isPrivileged(userId: string): Promise<boolean> {
162:     if (!userId) return false;
163:     const exists = await this.prisma.user.findFirst({
164:       where: {
165:         id: userId,
166:         roles: {
167:           some: {
168:             role: {
169:               name: { in: ['admin', 'manager'], mode: 'insensitive' },
170:             },
171:           },
172:         },
173:       },
174:       select: { id: true },
175:     });
176:     return !!exists;
177:   }
178:   async listUsers(query: ListUsersQuery) {
179:     const { q, role, emailVerified, limit, offset, sortBy, order } = query;
180:     const where: any = {
181:       AND: [
182:         q
183:           ? {
184:               OR: [
185:                 { email: { contains: q, mode: 'insensitive' } },
186:                 { firstName: { contains: q, mode: 'insensitive' } },
187:                 { lastName: { contains: q, mode: 'insensitive' } },
188:               ],
189:             }
190:           : {},
191:         emailVerified !== undefined
192:           ? { emailVerified: String(emailVerified).toLowerCase() === 'true' }
193:           : {},
194:         role
195:           ? {
196:               roles: {
197:                 some: {
198:                   role: { name: { equals: role, mode: 'insensitive' } },
199:                 },
200:               },
201:             }
202:           : {},
203:       ],
204:     };
205:     const [items, total] = await this.prisma.$transaction([
206:       this.prisma.user.findMany({
207:         where,
208:         select: {
209:           id: true,
210:           email: true,
211:           firstName: true,
212:           lastName: true,
213:           emailVerified: true,
214:           createdAt: true,
215:           updatedAt: true,
216:           avatar: { select: { id: true, url: true, publicId: true } },
217:           roles: { select: { role: { select: { id: true, name: true } } } },
218:         },
219:         orderBy: { [sortBy]: order },
220:         skip: offset,
221:         take: limit,
222:       }),
223:       this.prisma.user.count({ where }),
224:     ]);
225:     return { items, meta: { limit, offset, total } };
226:   }
227: }
</file>

