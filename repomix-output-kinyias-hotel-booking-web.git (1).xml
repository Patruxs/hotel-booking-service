 5: const api = axios.create({
 6:   baseURL: API_BASE_URL,
 7:   headers: {
 8:     'Content-Type': 'application/json',
 9:   },
10:   withCredentials: true,
11: });
12: api.interceptors.request.use(
13:   (config) => {
14:     const accessToken = Cookies.get('accessToken');
15:     if (accessToken) {
16:       config.headers.Authorization = `Bearer ${accessToken}`;
17:     }
18:     return config;
19:   },
20:   (error) => Promise.reject(error)
21: );
22: const AUTH_WHITELIST = [
23:   API_ENDPOINTS.AUTH.LOGIN,
24:   API_ENDPOINTS.AUTH.REFRESH_TOKEN,
25:   API_ENDPOINTS.AUTH.REGISTER,
26: ];
27: api.interceptors.response.use(
28:   (response) => response,
29:   async (error) => {
30:     const originalRequest = error.config;
31:     const requestUrl = originalRequest.url;
32:     const isAuthEndpoint = AUTH_WHITELIST.some((url) =>
33:       requestUrl?.includes(url)
34:     );
35:     if (error.code === 'ERR_NETWORK') {
36:       console.error('Network error — cannot reach API server.');
37:       alert('Network error — cannot reach server.');
38:       return Promise.reject(error);
39:     }
40:     if (
41:       error.response?.status === 401 &&
42:       !isAuthEndpoint &&
43:       !originalRequest._retry
44:     ) {
45:       originalRequest._retry = true;
46:       try {
47:         const { data } = await api.post(
48:           `${API_BASE_URL}${API_ENDPOINTS.AUTH.REFRESH_TOKEN}`
49:         );
50:         setAuthTokens(data.accessToken);
51:         originalRequest.headers.Authorization = `Bearer ${data.accessToken}`;
52:         return axios(originalRequest);
53:       } catch (refreshError) {
54:         Cookies.remove('accessToken');
55:         window.location.href = `${ROUTES.LOGIN}?session=expired`;
56:         return Promise.reject(refreshError);
57:       }
58:     }
59:     if (error.response?.status === 403) {
60:       toast.error('You do not have permission to access this feature');
61:       if (window.location.pathname !== ROUTES.FORBIDDEN) {
62:         setTimeout(() => {
63:           window.location.href = ROUTES.FORBIDDEN;
64:         }, 200);
65:       }
66:       return Promise.reject(error);
67:     }
68:     return Promise.reject(error);
69:   }
70: );
71: export const setAuthTokens = (accessToken: string) => {
72:   Cookies.set('accessToken', accessToken, {
73:     expires: 7,
74:     secure: true,
75:     sameSite: 'strict',
76:   });
77:   api.defaults.headers.common.Authorization = `Bearer ${accessToken}`;
78: };
