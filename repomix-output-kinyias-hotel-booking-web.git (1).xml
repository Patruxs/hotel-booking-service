218:     setIsDragOver(true)
219:   }
220:   const handleDrop = (e: React.DragEvent) => {
221:     e.preventDefault()
222:     e.stopPropagation()
223:     setIsDragActive(false)
224:     setIsDragOver(false)
225:     const files = Array.from(e.dataTransfer.files)
