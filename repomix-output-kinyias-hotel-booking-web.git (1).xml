 95:             <FormField
 96:               control={form.control}
 97:               name="roleIds"
 98:               render={({ field }) => {
 99:                 const selectedIds = [
100:                   ...(field.value ?? []),
101:                   ...(user?.roles
102:                     .map((r) => r.id)
103:                     .filter((id) => !removedBaseRoles.includes(id)) ??
104:                     []),
105:                 ];
106:                 const selectedRoles =
107:                   roles?.filter((r) => selectedIds.includes(r.id)) || [];
108:                 const filteredSuggestions =
109:                   roles?.filter(
110:                     (r) =>
111:                       r.name.toLowerCase().includes(inputValue.toLowerCase()) &&
112:                       !selectedIds.includes(r.id)
113:                   ) || [];
114:                 const addRole = (id: string) => {
115:                   field.onChange([...field.value, id]);
116:                   setInputValue('');
117:                   inputRef.current?.focus();
118:                 };
119:                 const removeRole = (id: string) => {
120:                   if (user?.roles.some((r) => r.id === id)) {
121:                     setRemovedBaseRoles((prev) => [...prev, id]);
122:                   }
123:                   field.onChange(
124:                     field.value?.filter((rid) => rid !== id) ?? []
125:                   );
126:                 };
127:                 return (
