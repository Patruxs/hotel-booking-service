<file path="apps/api/src/modules/auth/guards/action.guard.ts">
  1: import {
  2:   CanActivate,
  3:   ExecutionContext,
  4:   ForbiddenException,
  5:   Injectable,
  6:   UnauthorizedException,
  7: } from '@nestjs/common';
  8: import { Reflector } from '@nestjs/core';
  9: import * as crypto from 'crypto';
 10: import { createClient } from 'redis';
 11: import { ACTION_KEY } from '../../auth/decorator/action.decorator';
 12: import { PrismaService } from '../../prisma/prisma.service';
 13: import { IS_PUBLIC_KEY } from '../../../common/decorators/public.decorator';
 14: @Injectable()
 15: export class ActionGuard implements CanActivate {
 16:   private redis?: ReturnType<typeof createClient>;
 17:   private cacheTTL = 60;
 18:   constructor(
 19:     private readonly reflector: Reflector,
 20:     private readonly prisma: PrismaService,
 21:   ) {
 22:     try {
 23:       const url = process.env.REDIS_URL || undefined;
 24:       const host = process.env.REDIS_HOST || undefined;
 25:       const port = process.env.REDIS_PORT
 26:         ? Number(process.env.REDIS_PORT)
 27:         : undefined;
 28:       if (url || host) {
 29:         this.redis = createClient(url ? { url } : { socket: { host, port } });
 30:         this.redis.connect().catch(() => (this.redis = undefined));
 31:       }
 32:     } catch (_) {}
 33:   }
 34:   async canActivate(ctx: ExecutionContext): Promise<boolean> {
 35:     const isPublic = this.reflector.getAllAndOverride<boolean>(IS_PUBLIC_KEY, [
 36:       ctx.getHandler(),
 37:       ctx.getClass(),
 38:     ]);
 39:     if (isPublic) return true;
 40:     const req = ctx.switchToHttp().getRequest();
 41:     const user = req.user;
 42:     if (!user?.id) throw new UnauthorizedException('Unauthorized');
 43:     const actionKey = this.reflector.getAllAndOverride<string>(ACTION_KEY, [
 44:       ctx.getHandler(),
 45:       ctx.getClass(),
 46:     ]);
 47:     if (!actionKey) throw new ForbiddenException('Action is not configured');
 48:     const policy = await this.getActionPolicy(actionKey);
 49:     if (!policy) {
 50:       throw new ForbiddenException(`No policy bound to action "${actionKey}"`);
 51:     }
 52:     const userPerms = await this.getUserPermissions(user.id);
 53:     const required = policy.permissionNames;
 54:     const hasAll = required.every((p) => userPerms.has(p));
 55:     const hasAny = required.some((p) => userPerms.has(p));
 56:     const ok = policy.mode === 'ALL' ? hasAll : hasAny;
 57:     if (!ok)
 58:       throw new ForbiddenException('Missing permission(s) for this action');
 59:     return true;
 60:   }
 61:   private cacheKeyAction(actionKey: string) {
 62:     const h = crypto.createHash('sha1').update(actionKey).digest('hex');
 63:     return `policy:action:${h}`;
 64:   }
 65:   private cacheKeyUserPerm(userId: string) {
 66:     return `permissions:user:${userId}`;
 67:   }
 68:   private async getActionPolicy(
 69:     actionKey: string,
 70:   ): Promise<{ mode: 'ANY' | 'ALL'; permissionNames: string[] } | null> {
 71:     const key = this.cacheKeyAction(actionKey);
 72:     if (this.redis) {
 73:       const raw = await this.redis.get(key);
 74:       if (raw) return JSON.parse(raw);
 75:     }
 76:     const action = await this.prisma.apiAction.findUnique({
 77:       where: { key: actionKey },
 78:       include: { policies: { include: { permission: true } } },
 79:     });
 80:     if (!action || !action.enabled) return null;
 81:     const value = {
 82:       mode: action.mode as 'ANY' | 'ALL',
 83:       permissionNames: action.policies.map((p) => p.permission.name),
 84:     };
 85:     if (this.redis)
 86:       await this.redis.setEx(key, this.cacheTTL, JSON.stringify(value));
 87:     return value;
 88:   }
 89:   private async getUserPermissions(userId: string): Promise<Set<string>> {
 90:     const key = this.cacheKeyUserPerm(userId);
 91:     if (this.redis) {
 92:       const raw = await this.redis.get(key);
 93:       if (raw) return new Set<string>(JSON.parse(raw));
 94:     }
 95:     const roles = await this.prisma.userRole.findMany({
 96:       where: { userId },
 97:       include: {
 98:         role: { include: { permissions: { include: { permission: true } } } },
 99:       },
100:     });
101:     const set = new Set<string>();
102:     roles.forEach((ur) =>
103:       ur.role.permissions.forEach((rp) => set.add(rp.permission.name)),
104:     );
105:     if (this.redis)
106:       await this.redis.setEx(key, this.cacheTTL, JSON.stringify([...set]));
107:     return set;
108:   }
109: }
</file>

