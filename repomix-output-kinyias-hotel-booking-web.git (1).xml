 11: import { PrismaService } from '../prisma/prisma.service';
 12: @Injectable()
 13: export class RoomService {
 14:   constructor(private readonly prisma: PrismaService) {}
 15:   private async assertHotelAccess(hotelId: string, userId: string) {
 16:     const hotel = await this.prisma.hotel.findFirst({
 17:       where: {
 18:         id: hotelId,
 19:         deletedAt: null,
 20:         OR: [{ ownerId: userId }, { members: { some: { userId } } }],
 21:       },
 22:       select: { id: true },
 23:     });
 24:     if (!hotel)
 25:       throw new ForbiddenException('You have no access to this hotel');
 26:   }
 27:   async create(hotelId: string, userId: string, dto: CreateRoomDto) {
 28:     await this.assertHotelAccess(hotelId, userId);
 29:     const rt = await this.prisma.roomType.findFirst({
 30:       where: { id: dto.roomTypeId, hotelId },
 31:       select: { id: true },
 32:     });
 33:     if (!rt) throw new BadRequestException('RoomType not found in this hotel');
 34:     try {
 35:       const dup = await this.prisma.room.findFirst({
 36:         where: { hotelId, code: dto.code, deletedAt: null },
 37:         select: { id: true },
 38:       });
 39:       if (dup)
 40:         throw new BadRequestException('Room code already exists in this hotel');
 41:       return await this.prisma.room.create({
 42:         data: {
 43:           hotelId,
 44:           roomTypeId: dto.roomTypeId,
 45:           code: dto.code,
 46:           floor: dto.floor,
 47:           note: dto.note,
 48:         },
 49:       });
 50:     } catch (e: any) {
 51:       throw new BadRequestException('Room code already exists in this hotel');
 52:     }
 53:   }
 54:   async list(hotelId: string, userId: string, q: ListRoomDto) {
 55:     await this.assertHotelAccess(hotelId, userId);
 56:     const limit = q.limit ?? 20;
 57:     const page = q.page ?? 1;
 58:     const offset = (page - 1) * limit;
 59:     const where: Prisma.RoomWhereInput = {
 60:       hotelId,
 61:       deletedAt: null,
 62:       ...(q.roomTypeId ? { roomTypeId: q.roomTypeId } : {}),
 63:       ...(q.q
 64:         ? {
 65:             OR: [
 66:               { code: { contains: q.q, mode: 'insensitive' } },
 67:               { note: { contains: q.q, mode: 'insensitive' } },
 68:               { floor: { contains: q.q, mode: 'insensitive' } },
 69:             ],
 70:           }
 71:         : {}),
 72:     };
 73:     const [items, total] = await this.prisma.$transaction([
 74:       this.prisma.room.findMany({
 75:         where,
 76:         take: limit,
 77:         skip: offset,
 78:         orderBy: { createdAt: 'desc' },
 79:         include: {
 80:           roomType: true,
 81:         },
 82:       }),
 83:       this.prisma.room.count({ where }),
 84:     ]);
 85:     return {
 86:       data: items,
 87:       meta: {
 88:         limit,
 89:         offset,
 90:         total,
 91:       },
 92:     };
 93:   }
 94:   async get(hotelId: string, userId: string, id: string) {
 95:     await this.assertHotelAccess(hotelId, userId);
 96:     const room = await this.prisma.room.findFirst({
 97:       where: { id, hotelId, deletedAt: null },
 98:       include: { roomType: true },
 99:     });
100:     if (!room) throw new NotFoundException('Room not found');
101:     return room;
102:   }
103:   async update(
104:     hotelId: string,
105:     userId: string,
106:     id: string,
107:     dto: UpdateRoomDto,
108:   ) {
109:     await this.assertHotelAccess(hotelId, userId);
110:     const exists = await this.prisma.room.findFirst({
111:       where: { id, hotelId, deletedAt: null },
112:       select: { id: true, code: true },
113:     });
114:     if (!exists) throw new NotFoundException('Room not found');
115:     try {
116:       if (dto.code && dto.code !== exists.code) {
117:         const dup = await this.prisma.room.findFirst({
118:           where: { hotelId, code: dto.code, deletedAt: null, NOT: { id } },
119:           select: { id: true },
120:         });
121:         if (dup)
122:           throw new BadRequestException(
123:             'Room code already exists in this hotel',
124:           );
125:       }
126:       return await this.prisma.room.update({
127:         where: { id },
128:         data: dto,
129:         include: { roomType: true },
130:       });
131:     } catch (e: any) {
132:       throw new BadRequestException('Room code already exists in this hotel');
133:     }
134:   }
135:   async remove(hotelId: string, userId: string, id: string) {
136:     await this.assertHotelAccess(hotelId, userId);
137:     const room = await this.prisma.room.findFirst({
138:       where: { id, hotelId, deletedAt: null },
139:       select: { id: true },
140:     });
141:     if (!room) throw new NotFoundException('Room not found');
142:     await this.prisma.room.update({
143:       where: { id },
144:       data: {
145:         deletedAt: new Date(),
146:         status: 'INACTIVE',
147:       },
148:     });
149:     return { ok: true };
150:   }
151: }
