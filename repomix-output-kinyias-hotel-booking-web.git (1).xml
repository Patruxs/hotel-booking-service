 1: import { useMutation, useQueryClient } from "@tanstack/react-query";
 2: import { HotelFormValues } from "./validator";
 3: import { addMembersToHotel, createHotel, deleteHotel, removeMemberFromHotel, updateHotel } from "./api";
 4: export const useCreateHotelMutation = () => {
 5:     const queryClient = useQueryClient();
 6:     return useMutation({
 7:         mutationFn: (data: HotelFormValues) => createHotel(data),
 8:         onSuccess: () => {
 9:             queryClient.invalidateQueries({ queryKey: ['hotels'] });
10:         },
11:     });
12: };
13: export const useUpdateHotelMutation = (id: string) => {
14:     const queryClient = useQueryClient();
15:     return useMutation({
16:         mutationFn: (data: HotelFormValues) => updateHotel(id, data),
17:         onSuccess: () => {
18:             queryClient.invalidateQueries({ queryKey: ['hotels'] });
19:             queryClient.invalidateQueries({ queryKey: ['hotel', id] });
20:         },
21:     });
22: };
23: export const useDeleteHotelMutation = () => {
24:     const queryClient = useQueryClient();
25:     return useMutation({
26:         mutationFn: (id:string) => deleteHotel(id),
27:         onSuccess: () => {
28:             queryClient.invalidateQueries({ queryKey: ['hotels'] });
29:         },
30:     });
31: };
32: export const useAddMembersToHotelMutation = () => {
33:     const queryClient = useQueryClient();
34:     return useMutation({
35:         mutationFn: (data: { hotelId: string; userIds: string[] }) => addMembersToHotel(data.hotelId, data.userIds),
36:         onSuccess: (_, variables) => {
37:             queryClient.invalidateQueries({ queryKey: ['hotels'] });
38:             queryClient.invalidateQueries({ queryKey: ['hotel-members', variables.hotelId] });
39:             queryClient.invalidateQueries({ queryKey: ['hotel', variables.hotelId] });
40:         },
41:     });
42: };
43: export const useRemoveMemberFromHotelMutation = () => {
44:     const queryClient = useQueryClient();
45:     return useMutation({
46:         mutationFn: (data: { hotelId: string; userId: string }) => removeMemberFromHotel(data.hotelId, data.userId),
47:         onSuccess: (_, variables) => {
48:             queryClient.invalidateQueries({ queryKey: ['hotel-members', variables.hotelId] });
49:             queryClient.invalidateQueries({ queryKey: ['hotel', variables.hotelId] });
50:         },
51:     });
52: };
