<file path="apps/web/src/features/inventory/components/CalendarInventory.tsx">
  1: "use client"
  2: import * as React from "react"
  3: import { format, eachDayOfInterval, startOfDay, isSameDay } from "date-fns"
  4: import { Ban } from "lucide-react"
  5: import { DateRange } from "react-day-picker"
  6: import { cn } from "@/lib/utils"
  7: import { ScrollArea } from "@/components/ui/scroll-area"
  8: import { Inventory } from "@/features/inventory/types"
  9: import { UpdateInventoryDialog } from "./UpdateInventoryDialog"
 10: interface CalendarInventoryProps {
 11:     date: DateRange | undefined;
 12:     inventoryData: Inventory[] | undefined;
 13:     isLoading?: boolean;
 14: }
 15: export const CalendarInventory = ({ date, inventoryData, isLoading }: CalendarInventoryProps) => {
 16:     const [selectedInventory, setSelectedInventory] = React.useState<Inventory | null>(null)
 17:     const days = React.useMemo(() => {
 18:         if (!date?.from || !date?.to) return []
 19:         return eachDayOfInterval({ start: date.from, end: date.to })
 20:     }, [date])
 21:     const getInventoryForDate = (day: Date) => {
 22:         if (!inventoryData) return undefined
 23:         const data = Array.isArray(inventoryData) ? inventoryData : (inventoryData as any)?.data || [];
 24:         return (data as Inventory[]).find((inv) => isSameDay(new Date(inv.date), day))
 25:     }
 26:     if (!date?.from || !date?.to) {
 27:          return <div className="p-4 text-center text-muted-foreground">Please select a date range</div>
 28:     }
 29:     if (isLoading) {
 30:         return <div className="p-4 text-center text-muted-foreground">Loading inventory...</div>
 31:     }
 32:     return (
 33:         <ScrollArea className="h-[calc(100vh-400px)] rounded-md border p-4">
 34:              <div className="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-7 gap-4">
 35:                 {days.map((day, index) => {
 36:                     const inventory = getInventoryForDate(day);
 37:                     const isPast = day < startOfDay(new Date());
 38:                     const hasInventory = !!inventory;
 39:                     return (
 40:                         <div
 41:                             key={index}
 42:                             onClick={() => hasInventory && setSelectedInventory(inventory)}
 43:                             className={cn(
 44:                                 "relative group flex flex-col border rounded-lg p-4 min-h-[120px]",
 45:                                 "transition-all duration-200 ease-out",
 46:                                 hasInventory && "hover:shadow-md hover:-translate-y-0.5 hover:border-primary/60",
 47:                                 isPast ? "bg-muted/50" : "bg-card",
 48:                                 inventory?.stopSell
 49:                                 ? "border-red-200 bg-red-50 dark:bg-red-900/10 dark:border-red-900/50"
 50:                                 : "hover:bg-primary/5",
 51:                                 hasInventory ? "cursor-pointer" : ""
 52:                             )}
 53:                         >
 54:                             {hasInventory && (
 55:                                 <div className="
 56:                                     absolute inset-0
 57:                                     flex items-center justify-center
 58:                                     bg-black/5
 59:                                     opacity-0
 60:                                     group-hover:opacity-100
 61:                                     transition-opacity
 62:                                     rounded-lg
 63:                                 ">
 64:                                     <span className="text-xs font-medium text-primary">
 65:                                     Click to edit
 66:                                     </span>
 67:                                 </div>
 68:                                 )}
 69:                             <div className="flex justify-between items-start mb-4">
 70:                                 <span className={cn(
 71:                                     "text-lg font-semibold",
 72:                                     isPast && "text-muted-foreground"
 73:                                 )}>
 74:                                     {format(day, "MMM d")}
 75:                                 </span>
 76:                                 <span className="text-xs text-muted-foreground uppercase">
 77:                                     {format(day, "EEE")}
 78:                                 </span>
 79:                             </div>
 80:                             <div className="mt-auto flex flex-col gap-1 items-center justify-center text-center">
 81:                                {hasInventory ? (
 82:                                    <>
 83:                                      {inventory.stopSell && (
 84:                                          <div className="flex items-center text-red-600 dark:text-red-400 text-xs font-medium mb-1">
 85:                                              <Ban className="w-3 h-3 mr-1" />
 86:                                              Stopped
 87:                                          </div>
 88:                                      )}
 89:                                      <div className={cn(
 90:                                          "text-2xl font-bold font-mono",
 91:                                          inventory.availableRooms === 0 ? "text-red-500" : "text-primary"
 92:                                      )}>
 93:                                          {inventory.availableRooms}
 94:                                          <span className="text-sm text-muted-foreground font-normal ml-1">
 95:                                              / {inventory.totalRooms}
 96:                                          </span>
 97:                                      </div>
 98:                                      <span className="text-xs text-muted-foreground">Available</span>
 99:                                    </>
100:                                ) : (
101:                                    <div className="text-muted-foreground text-sm italic">
102:                                        No Data
103:                                    </div>
104:                                )}
105:                             </div>
106:                         </div>
107:                     )
108:                 })}
109:              </div>
110:              {selectedInventory && (
111:                 <UpdateInventoryDialog
112:                     inventory={selectedInventory}
113:                     open={!!selectedInventory}
114:                     onOpenChange={(open) => !open && setSelectedInventory(null)}
115:                 />
116:              )}
117:         </ScrollArea>
118:     )
119: }
</file>

