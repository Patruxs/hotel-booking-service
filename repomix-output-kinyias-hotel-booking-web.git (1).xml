 16:   async createHotel(userId: string, dto: CreateHotelDto) {
 17:     const { images, ...hotelData } = dto;
 18:     return this.prisma.hotel.create({
 19:       data: {
 20:         ...hotelData,
 21:         ownerId: userId,
 22:         members: {
 23:           create: {
 24:             userId,
 25:           },
 26:         },
 27:         images:
 28:           images && images.length > 0
 29:             ? {
 30:                 create: images.map((i) => ({ url: i.url }) as any),
 31:               }
 32:             : undefined,
 33:       },
 34:       include: {
 35:         owner: {
 36:           select: { id: true, email: true, firstName: true, lastName: true },
 37:         },
 38:         members: true,
 39:         images: true,
 40:       },
 41:     });
 42:   }
 43:   async getMyHotels(userId: string) {
 44:     return this.prisma.hotel.findMany({
 45:       where: {
 46:         deletedAt: null,
 47:         OR: [{ ownerId: userId }, { members: { some: { userId } } }],
 48:       },
 49:       orderBy: { createdAt: 'desc' },
 50:     });
 51:   }
 52:   async updateHotel(hotelId: string, dto: UpdateHotelDto) {
 53:     const { images, ...otherData } = dto;
 54:     const hotel = await this.prisma.hotel.findFirst({
 55:       where: {
 56:         id: hotelId,
 57:         deletedAt: null,
 58:       },
 59:       include: { images: true },
 60:     });
 61:     if (!hotel) {
 62:       throw new NotFoundException('Hotel not found or has been deleted');
 63:     }
 64:     let imageOps: any = undefined;
 65:     if (images) {
 66:       const currentImageIds = hotel.images.map((img) => img.id);
 67:       const imagesToUpdate = images.filter(
 68:         (img) => img.id && currentImageIds.includes(img.id),
 69:       );
 70:       const imagesToCreate = images.filter(
 71:         (img) => !img.id || (img.id && !currentImageIds.includes(img.id)),
 72:       );
 73:       const validUpdateIds = new Set(imagesToUpdate.map((img) => img.id));
 74:       const imagesToDeleteIds = currentImageIds.filter(
 75:         (id) => !validUpdateIds.has(id),
 76:       );
 77:       imageOps = {
 78:         deleteMany: { id: { in: imagesToDeleteIds } },
 79:         update: imagesToUpdate.map((img) => ({
 80:           where: { id: img.id },
 81:           data: { url: img.url },
 82:         })),
 83:         create: imagesToCreate.map((img) => ({ url: img.url })),
 84:       };
 85:     }
 86:     return this.prisma.hotel.update({
 87:       where: { id: hotelId },
 88:       data: {
 89:         ...otherData,
 90:         ...(imageOps ? { images: imageOps } : {}),
 91:       },
 92:       include: {
 93:         images: true,
 94:       },
 95:     });
 96:   }
