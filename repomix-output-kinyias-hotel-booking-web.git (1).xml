  1: import {
  2:   BadRequestException,
  3:   ForbiddenException,
  4:   Injectable,
  5:   NotFoundException,
  6: } from '@nestjs/common';
  7: import { Prisma } from '@prisma/client';
  8: import { PrismaService } from '../prisma/prisma.service';
  9: import { CreatePromotionDto } from './dto/create-promotion.dto';
 10: import { ListPromotionsQueryDto } from './dto/list-promotions.query';
 11: import { UpdatePromotionDto } from './dto/update-promotion.dto';
 12: @Injectable()
 13: export class PromotionService {
 14:   constructor(private prisma: PrismaService) {}
 15:   async create(dto: CreatePromotionDto) {
 16:     const exist = await this.prisma.promotion.findUnique({
 17:       where: { code: dto.code },
 18:     });
 19:     if (exist) {
 20:       throw new BadRequestException('Promotion code already exists');
 21:     }
 22:     return this.prisma.promotion.create({
 23:       data: {
 24:         code: dto.code,
 25:         name: dto.name,
 26:         description: dto.description,
 27:         discountType: dto.discountType,
 28:         discountValue: dto.discountValue,
 29:         maxDiscountAmount: dto.maxDiscountAmount,
 30:         minBookingAmount: dto.minBookingAmount,
 31:         totalUsageLimit: dto.totalUsageLimit,
 32:         perUserLimit: dto.perUserLimit,
 33:         startAt: new Date(dto.startAt),
 34:         endAt: new Date(dto.endAt),
 35:         isActive: dto.isActive ?? true,
 36:       },
 37:     });
 38:   }
 39:   async listAdmin(query: ListPromotionsQueryDto) {
 40:     const page = query.page ?? 1;
 41:     const limit = query.limit ?? 20;
 42:     const offset = (page - 1) * limit;
 43:     const where: Prisma.PromotionWhereInput = {};
 44:     if (query.search) {
 45:       where.OR = [
 46:         { code: { contains: query.search, mode: 'insensitive' } },
 47:         { name: { contains: query.search, mode: 'insensitive' } },
 48:       ];
 49:     }
 50:     if (typeof query.isActive === 'boolean') {
 51:       where.isActive = query.isActive;
 52:     }
 53:     const [total, items] = await this.prisma.$transaction([
 54:       this.prisma.promotion.count({ where }),
 55:       this.prisma.promotion.findMany({
 56:         where,
 57:         skip: offset,
 58:         take: limit,
 59:         orderBy: { createdAt: 'desc' },
 60:         include: {
 61:           hotel: {
 62:             select: { id: true, name: true },
 63:           },
 64:         },
 65:       }),
 66:     ]);
 67:     return {
 68:       data: items,
 69:       meta: {
 70:         total,
 71:         page,
 72:         limit,
 73:       },
 74:     };
 75:   }
 76:   async listPublic(query: ListPromotionsQueryDto) {
 77:     const page = query.page ?? 1;
 78:     const limit = query.limit ?? 20;
 79:     const offset = (page - 1) * limit;
 80:     const now = new Date();
 81:     const where: Prisma.PromotionWhereInput = {
 82:       isActive: true,
 83:       startAt: { lte: now },
 84:       endAt: { gte: now },
 85:     };
 86:     if (query.search) {
 87:       where.AND = [
 88:         {
 89:           OR: [
 90:             { code: { contains: query.search, mode: 'insensitive' } },
 91:             { name: { contains: query.search, mode: 'insensitive' } },
 92:           ],
 93:         },
 94:       ];
 95:     }
 96:     const [total, items] = await this.prisma.$transaction([
 97:       this.prisma.promotion.count({ where }),
 98:       this.prisma.promotion.findMany({
 99:         where,
100:         skip: offset,
101:         take: limit,
102:         orderBy: { createdAt: 'desc' },
103:         include: {
104:            hotel: {
105:             select: { id: true, name: true}
106:            }
107:         }
108:       }),
109:     ]);
110:     return {
111:       data: items,
112:       meta: {
113:         total,
114:         page,
115:         limit,
116:       },
117:     };
118:   }
119:   async findOne(id: string) {
120:     const promotion = await this.prisma.promotion.findUnique({
121:       where: { id },
122:       include: {
123:         hotel: true,
124:       },
125:     });
126:     if (!promotion) throw new NotFoundException('Promotion not found');
127:     return promotion;
128:   }
129:   async update(id: string, userId: string, dto: UpdatePromotionDto) {
130:     const promotion = await this.findOne(id);
131:     if (promotion.hotelId) {
132:       const hasPermission = await this.checkHotelPermission(userId, promotion.hotelId);
133:       if (!hasPermission) {
134:         throw new ForbiddenException('No permission to update this promotion');
135:       }
136:     } else {
137:        const isAdmin = await this.checkIsAdmin(userId);
138:        if (!isAdmin) throw new ForbiddenException('Only admin can update global promotion');
139:     }
140:     return this.prisma.promotion.update({
141:       where: { id },
142:       data: {
143:         ...dto,
144:         startAt: dto.startAt ? new Date(dto.startAt) : undefined,
145:         endAt: dto.endAt ? new Date(dto.endAt) : undefined,
146:       },
147:     });
148:   }
149:   async remove(id: string, userId: string) {
150:     const promotion = await this.findOne(id);
151:     if (promotion.hotelId) {
152:       const hasPermission = await this.checkHotelPermission(userId, promotion.hotelId);
153:       if (!hasPermission) {
154:         throw new ForbiddenException('No permission to delete this promotion');
155:       }
156:     } else {
157:        const isAdmin = await this.checkIsAdmin(userId);
158:        if (!isAdmin) throw new ForbiddenException('Only admin can delete global promotion');
159:     }
160:     return this.prisma.promotion.delete({
161:       where: { id },
162:     });
163:   }
164:   private async checkIsAdmin(userId: string): Promise<boolean> {
165:      const userRoles = await this.prisma.userRole.findMany({
166:       where: { userId },
167:       include: { role: true },
168:     });
169:     return userRoles.some((ur) => ur.role.name.toUpperCase() === 'ADMIN');
170:   }
171:   private async checkHotelPermission(userId: string, hotelId: string): Promise<boolean> {
172:     if (await this.checkIsAdmin(userId)) return true;
173:     const hotel = await this.prisma.hotel.findUnique({
174:       where: { id: hotelId },
175:       select: { ownerId: true },
176:     });
177:     if (hotel?.ownerId === userId) return true;
178:     const member = await this.prisma.hotelMember.findUnique({
179:        where: { hotelId_userId: { hotelId, userId } },
180:     });
181:     return !!member;
182:   }
183: }
