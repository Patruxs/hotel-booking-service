366:   selection: Selection,
367:   allowedNodeTypes: string[]
368: ): NodeWithPos[] {
369:   const results: NodeWithPos[] = []
370:   const allowed = new Set(allowedNodeTypes)
371:   if (selection instanceof CellSelection) {
372:     selection.forEachCell((node: PMNode, pos: number) => {
373:       if (allowed.has(node.type.name)) {
374:         results.push({ node, pos })
375:       }
376:     })
377:     return results
378:   }
379:   if (selection instanceof NodeSelection) {
380:     const { node, from: pos } = selection
381:     if (node && allowed.has(node.type.name)) {
382:       results.push({ node, pos })
383:     }
384:     return results
385:   }
386:   const { $anchor } = selection
387:   const cell = cellAround($anchor)
388:   if (cell) {
389:     const cellNode = selection.$anchor.doc.nodeAt(cell.pos)
390:     if (cellNode && allowed.has(cellNode.type.name)) {
391:       results.push({ node: cellNode, pos: cell.pos })
392:       return results
393:     }
394:   }
395:   const parentNode = findParentNodeClosestToPos($anchor, (node) =>
396:     allowed.has(node.type.name)
397:   )
398:   if (parentNode) {
399:     results.push({ node: parentNode.node, pos: parentNode.pos })
400:   }
401:   return results
