  1: "use client"
  2: import { forwardRef, useCallback, useEffect, useRef, useState } from "react"
  3: import { Separator } from "@/components/tiptap-ui-primitive/separator"
  4: import "@/components/tiptap-ui-primitive/toolbar/toolbar.scss"
  5: import { cn } from "@/lib/tiptap-utils"
  6: import { useMenuNavigation } from "@/hooks/use-menu-navigation"
  7: import { useComposedRef } from "@/hooks/use-composed-ref"
  8: type BaseProps = React.HTMLAttributes<HTMLDivElement>
  9: interface ToolbarProps extends BaseProps {
 10:   variant?: "floating" | "fixed"
 11: }
 12: const useToolbarNavigation = (
 13:   toolbarRef: React.RefObject<HTMLDivElement | null>
 14: ) => {
 15:   const [items, setItems] = useState<HTMLElement[]>([])
 16:   const collectItems = useCallback(() => {
 17:     if (!toolbarRef.current) return []
 18:     return Array.from(
 19:       toolbarRef.current.querySelectorAll<HTMLElement>(
 20:         'button:not([disabled]), [role="button"]:not([disabled]), [tabindex="0"]:not([disabled])'
 21:       )
 22:     )
 23:   }, [toolbarRef])
 24:   useEffect(() => {
 25:     const toolbar = toolbarRef.current
 26:     if (!toolbar) return
 27:     const updateItems = () => setItems(collectItems())
 28:     updateItems()
 29:     const observer = new MutationObserver(updateItems)
 30:     observer.observe(toolbar, { childList: true, subtree: true })
 31:     return () => observer.disconnect()
 32:   }, [collectItems, toolbarRef])
 33:   const { selectedIndex } = useMenuNavigation<HTMLElement>({
 34:     containerRef: toolbarRef,
 35:     items,
 36:     orientation: "horizontal",
 37:     onSelect: (el) => el.click(),
 38:     autoSelectFirstItem: false,
 39:   })
 40:   useEffect(() => {
 41:     const toolbar = toolbarRef.current
 42:     if (!toolbar) return
 43:     const handleFocus = (e: FocusEvent) => {
 44:       const target = e.target as HTMLElement
 45:       if (toolbar.contains(target))
 46:         target.setAttribute("data-focus-visible", "true")
 47:     }
 48:     const handleBlur = (e: FocusEvent) => {
 49:       const target = e.target as HTMLElement
 50:       if (toolbar.contains(target)) target.removeAttribute("data-focus-visible")
 51:     }
 52:     toolbar.addEventListener("focus", handleFocus, true)
 53:     toolbar.addEventListener("blur", handleBlur, true)
 54:     return () => {
 55:       toolbar.removeEventListener("focus", handleFocus, true)
 56:       toolbar.removeEventListener("blur", handleBlur, true)
 57:     }
 58:   }, [toolbarRef])
 59:   useEffect(() => {
 60:     if (selectedIndex !== undefined && items[selectedIndex]) {
 61:       items[selectedIndex].focus()
 62:     }
 63:   }, [selectedIndex, items])
 64: }
 65: export const Toolbar = forwardRef<HTMLDivElement, ToolbarProps>(
 66:   ({ children, className, variant = "fixed", ...props }, ref) => {
 67:     const toolbarRef = useRef<HTMLDivElement>(null)
 68:     const composedRef = useComposedRef(toolbarRef, ref)
 69:     useToolbarNavigation(toolbarRef)
 70:     return (
 71:       <div
 72:         ref={composedRef}
 73:         role="toolbar"
 74:         aria-label="toolbar"
 75:         data-variant={variant}
 76:         className={cn("tiptap-toolbar", className)}
 77:         {...props}
 78:       >
 79:         {children}
 80:       </div>
 81:     )
 82:   }
 83: )
 84: Toolbar.displayName = "Toolbar"
 85: export const ToolbarGroup = forwardRef<HTMLDivElement, BaseProps>(
 86:   ({ children, className, ...props }, ref) => (
 87:     <div
 88:       ref={ref}
 89:       role="group"
 90:       className={cn("tiptap-toolbar-group", className)}
 91:       {...props}
 92:     >
 93:       {children}
 94:     </div>
 95:   )
 96: )
 97: ToolbarGroup.displayName = "ToolbarGroup"
 98: export const ToolbarSeparator = forwardRef<HTMLDivElement, BaseProps>(
 99:   ({ ...props }, ref) => (
100:     <Separator ref={ref} orientation="vertical" decorative {...props} />
101:   )
102: )
103: ToolbarSeparator.displayName = "ToolbarSeparator"
