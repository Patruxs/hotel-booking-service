<file path="apps/web/src/components/tiptap-ui/heading-button/use-heading.ts">
  1: "use client"
  2: import { useCallback, useEffect, useState } from "react"
  3: import { type Editor } from "@tiptap/react"
  4: import { NodeSelection, TextSelection } from "@tiptap/pm/state"
  5: import { useTiptapEditor } from "@/hooks/use-tiptap-editor"
  6: import {
  7:   findNodePosition,
  8:   isNodeInSchema,
  9:   isNodeTypeSelected,
 10:   isValidPosition,
 11:   selectionWithinConvertibleTypes,
 12: } from "@/lib/tiptap-utils"
 13: import { HeadingOneIcon } from "@/components/tiptap-icons/heading-one-icon"
 14: import { HeadingTwoIcon } from "@/components/tiptap-icons/heading-two-icon"
 15: import { HeadingThreeIcon } from "@/components/tiptap-icons/heading-three-icon"
 16: import { HeadingFourIcon } from "@/components/tiptap-icons/heading-four-icon"
 17: import { HeadingFiveIcon } from "@/components/tiptap-icons/heading-five-icon"
 18: import { HeadingSixIcon } from "@/components/tiptap-icons/heading-six-icon"
 19: export type Level = 1 | 2 | 3 | 4 | 5 | 6
 20: export interface UseHeadingConfig {
 21:   editor?: Editor | null
 22:   level: Level
 23:   hideWhenUnavailable?: boolean
 24:   onToggled?: () => void
 25: }
 26: export const headingIcons = {
 27:   1: HeadingOneIcon,
 28:   2: HeadingTwoIcon,
 29:   3: HeadingThreeIcon,
 30:   4: HeadingFourIcon,
 31:   5: HeadingFiveIcon,
 32:   6: HeadingSixIcon,
 33: }
 34: export const HEADING_SHORTCUT_KEYS: Record<Level, string> = {
 35:   1: "ctrl+alt+1",
 36:   2: "ctrl+alt+2",
 37:   3: "ctrl+alt+3",
 38:   4: "ctrl+alt+4",
 39:   5: "ctrl+alt+5",
 40:   6: "ctrl+alt+6",
 41: }
 42: export function canToggle(
 43:   editor: Editor | null,
 44:   level?: Level,
 45:   turnInto: boolean = true
 46: ): boolean {
 47:   if (!editor || !editor.isEditable) return false
 48:   if (
 49:     !isNodeInSchema("heading", editor) ||
 50:     isNodeTypeSelected(editor, ["image"])
 51:   )
 52:     return false
 53:   if (!turnInto) {
 54:     return level
 55:       ? editor.can().setNode("heading", { level })
 56:       : editor.can().setNode("heading")
 57:   }
 58:   if (
 59:     !selectionWithinConvertibleTypes(editor, [
 60:       "paragraph",
 61:       "heading",
 62:       "bulletList",
 63:       "orderedList",
 64:       "taskList",
 65:       "blockquote",
 66:       "codeBlock",
 67:     ])
 68:   )
 69:     return false
 70:   return level
 71:     ? editor.can().setNode("heading", { level }) || editor.can().clearNodes()
 72:     : editor.can().setNode("heading") || editor.can().clearNodes()
 73: }
 74: export function isHeadingActive(
 75:   editor: Editor | null,
 76:   level?: Level | Level[]
 77: ): boolean {
 78:   if (!editor || !editor.isEditable) return false
 79:   if (Array.isArray(level)) {
 80:     return level.some((l) => editor.isActive("heading", { level: l }))
 81:   }
 82:   return level
 83:     ? editor.isActive("heading", { level })
 84:     : editor.isActive("heading")
 85: }
 86: export function toggleHeading(
 87:   editor: Editor | null,
 88:   level: Level | Level[]
 89: ): boolean {
 90:   if (!editor || !editor.isEditable) return false
 91:   const levels = Array.isArray(level) ? level : [level]
 92:   const toggleLevel = levels.find((l) => canToggle(editor, l))
 93:   if (!toggleLevel) return false
 94:   try {
 95:     const view = editor.view
 96:     let state = view.state
 97:     let tr = state.tr
 98:     if (state.selection.empty || state.selection instanceof TextSelection) {
 99:       const pos = findNodePosition({
100:         editor,
101:         node: state.selection.$anchor.node(1),
102:       })?.pos
103:       if (!isValidPosition(pos)) return false
104:       tr = tr.setSelection(NodeSelection.create(state.doc, pos))
105:       view.dispatch(tr)
106:       state = view.state
107:     }
108:     const selection = state.selection
109:     let chain = editor.chain().focus()
110:     if (selection instanceof NodeSelection) {
111:       const firstChild = selection.node.firstChild?.firstChild
112:       const lastChild = selection.node.lastChild?.lastChild
113:       const from = firstChild
114:         ? selection.from + firstChild.nodeSize
115:         : selection.from + 1
116:       const to = lastChild
117:         ? selection.to - lastChild.nodeSize
118:         : selection.to - 1
119:       const resolvedFrom = state.doc.resolve(from)
120:       const resolvedTo = state.doc.resolve(to)
121:       chain = chain
122:         .setTextSelection(TextSelection.between(resolvedFrom, resolvedTo))
123:         .clearNodes()
124:     }
125:     const isActive = levels.some((l) =>
126:       editor.isActive("heading", { level: l })
127:     )
128:     const toggle = isActive
129:       ? chain.setNode("paragraph")
130:       : chain.setNode("heading", { level: toggleLevel })
131:     toggle.run()
132:     editor.chain().focus().selectTextblockEnd().run()
133:     return true
134:   } catch {
135:     return false
136:   }
137: }
138: export function shouldShowButton(props: {
139:   editor: Editor | null
140:   level?: Level | Level[]
141:   hideWhenUnavailable: boolean
142: }): boolean {
143:   const { editor, level, hideWhenUnavailable } = props
144:   if (!editor || !editor.isEditable) return false
145:   if (!isNodeInSchema("heading", editor)) return false
146:   if (hideWhenUnavailable && !editor.isActive("code")) {
147:     if (Array.isArray(level)) {
148:       return level.some((l) => canToggle(editor, l))
149:     }
150:     return canToggle(editor, level)
151:   }
152:   return true
153: }
154: export function useHeading(config: UseHeadingConfig) {
155:   const {
156:     editor: providedEditor,
157:     level,
158:     hideWhenUnavailable = false,
159:     onToggled,
160:   } = config
161:   const { editor } = useTiptapEditor(providedEditor)
162:   const [isVisible, setIsVisible] = useState<boolean>(true)
163:   const canToggleState = canToggle(editor, level)
164:   const isActive = isHeadingActive(editor, level)
165:   useEffect(() => {
166:     if (!editor) return
167:     const handleSelectionUpdate = () => {
168:       setIsVisible(shouldShowButton({ editor, level, hideWhenUnavailable }))
169:     }
170:     handleSelectionUpdate()
171:     editor.on("selectionUpdate", handleSelectionUpdate)
172:     return () => {
173:       editor.off("selectionUpdate", handleSelectionUpdate)
174:     }
175:   }, [editor, level, hideWhenUnavailable])
176:   const handleToggle = useCallback(() => {
177:     if (!editor) return false
178:     const success = toggleHeading(editor, level)
179:     if (success) {
180:       onToggled?.()
181:     }
182:     return success
183:   }, [editor, level, onToggled])
184:   return {
185:     isVisible,
186:     isActive,
187:     handleToggle,
188:     canToggle: canToggleState,
189:     label: `Heading ${level}`,
190:     shortcutKeys: HEADING_SHORTCUT_KEYS[level],
191:     Icon: headingIcons[level],
192:   }
193: }
</file>

<file path="apps/web/src/components/tiptap-ui/heading-dropdown-menu/heading-dropdown-menu.tsx">
  1: "use client"
  2: import { forwardRef, useCallback, useState } from "react"
  3: import { ChevronDownIcon } from "@/components/tiptap-icons/chevron-down-icon"
  4: import { useTiptapEditor } from "@/hooks/use-tiptap-editor"
  5: import { HeadingButton } from "@/components/tiptap-ui/heading-button"
