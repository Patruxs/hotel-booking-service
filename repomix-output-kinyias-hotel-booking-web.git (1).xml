 23: import { CheckInGuestsDialog } from "./CheckInGuestsDialog";
 24: interface UpdateStatusBookingDialogProps {
 25:   hotelId: string;
 26:   bookingId: string;
 27:   currentStatus: BookingStatus;
 28:   open: boolean;
 29:   onOpenChange: (open: boolean) => void;
 30: }
 31: const TRANSITIONS: Record<string, BookingStatus[]> = {
 32:   PENDING: ["CONFIRMED", "CANCELLED"],
 33:   CONFIRMED: ["CHECKED_IN", "CANCELLED"],
 34:   CHECKED_IN: ["COMPLETED"],
 35:   COMPLETED: [],
 36:   CANCELLED: [],
 37:   NO_SHOW: [],
 38: };
 39: const STATUS_CONFIG: Record<
 40:   BookingStatus,
 41:   {
 42:     label: string;
 43:     description: string;
 44:     icon: React.ElementType;
 45:     variant: "default" | "destructive" | "outline" | "secondary" | "ghost" | "link";
 46:     requiresConfirmation?: boolean;
 47:     confirmationMessage?: string;
 48:   }
 49: > = {
 50:   PENDING: {
 51:     label: "Pending",
 52:     description: "Booking requires confirmation",
 53:     icon: Loader2,
 54:     variant: "secondary",
 55:   },
 56:   CONFIRMED: {
 57:     label: "Confirm Booking",
 58:     description: "Mark this booking as confirmed",
 59:     icon: CheckCircle2,
 60:     variant: "default",
 61:   },
 62:   CANCELLED: {
 63:     label: "Cancel Booking",
 64:     description: "Cancel this booking (Destructive)",
 65:     icon: XCircle,
 66:     variant: "destructive",
 67:     requiresConfirmation: true,
 68:     confirmationMessage: "Are you sure you want to cancel this booking? This action cannot be undone.",
 69:   },
 70:   CHECKED_IN: {
 71:     label: "Check In Guest",
 72:     description: "Guest has arrived",
 73:     icon: LogIn,
 74:     variant: "default",
 75:   },
 76:   COMPLETED: {
 77:     label: "Check Out Guest",
 78:     description: "Guest is leaving and payment settled",
 79:     icon: LogOut,
 80:     variant: "default",
 81:     requiresConfirmation: true,
 82:     confirmationMessage: "Are you sure you want to check out this guest? Ensure all payments are settled.",
 83:   },
 84:   NO_SHOW: {
 85:       label: "Mark as No Show",
 86:       description: "Guest did not arrive",
 87:       icon: XCircle,
 88:       variant: "destructive",
 89:       requiresConfirmation: true,
 90:       confirmationMessage: "Are you sure to mark this as No Show?"
 91:   }
 92: };
 93: export function UpdateStatusBookingDialog({
 94:   hotelId,
 95:   bookingId,
 96:   currentStatus,
 97:   open,
 98:   onOpenChange,
 99: }: UpdateStatusBookingDialogProps) {
100:   const [targetStatus, setTargetStatus] = useState<BookingStatus | null>(null);
101:   const [showCheckInDialog, setShowCheckInDialog] = useState(false);
102:   useEffect(() => {
103:     if (open) {
104:       setTargetStatus(null);
105:       setShowCheckInDialog(false);
106:     }
107:   }, [open]);
108:   const { mutate: updateStatus, isPending } = useUpdateBookingStatusMutation(
109:     hotelId,
110:     bookingId
111:   );
112:   const availableTransitions = TRANSITIONS[currentStatus] || [];
113:   const handleActionClick = (status: BookingStatus) => {
114:     if (status === "CHECKED_IN") {
115:          setShowCheckInDialog(true);
116:          return;
117:     }
118:     const config = STATUS_CONFIG[status];
119:     if (config.requiresConfirmation) {
120:       setTargetStatus(status);
121:     } else {
122:       executeStatusUpdate(status);
123:     }
124:   };
125:   const executeStatusUpdate = (status: BookingStatus) => {
126:     updateStatus(status, {
127:       onSuccess: () => {
128:         toast.success(`Booking status updated to ${STATUS_CONFIG[status].label}`);
129:         onOpenChange(false);
130:       },
131:       onError: (error) => {
132:         toast.error("Failed to update booking status");
133:         console.error(error);
134:       },
135:     });
136:   };
137:   const currentConfig = STATUS_CONFIG[currentStatus];
138:   if(showCheckInDialog) {
139:        return (
140:            <CheckInGuestsDialog
141:                 hotelId={hotelId}
142:                 bookingId={bookingId}
143:                 open={showCheckInDialog}
144:                 onOpenChange={setShowCheckInDialog}
145:                 onSuccess={() => onOpenChange(false)}
146:            />
147:        )
148:   }
149:   if (targetStatus) {
150:       const targetConfig = STATUS_CONFIG[targetStatus];
151:       return (
152:         <Dialog open={open} onOpenChange={onOpenChange}>
153:             <DialogContent className="sm:max-w-[425px]">
154:                 <DialogHeader>
155:                     <DialogTitle className="flex items-center gap-2 text-destructive">
156:                         <AlertTriangle className="w-5 h-5"/>
157:                         Confirm Action
158:                     </DialogTitle>
159:                     <DialogDescription>
160:                         {targetConfig.confirmationMessage}
161:                     </DialogDescription>
162:                 </DialogHeader>
163:                 <DialogFooter className="gap-2 sm:gap-0">
164:                      <Button
165:                         variant="ghost"
166:                         onClick={() => setTargetStatus(null)}
167:                         disabled={isPending}
168:                      >
169:                         Back
170:                      </Button>
171:                      <Button
172:                         variant={targetConfig.variant}
173:                         onClick={() => executeStatusUpdate(targetStatus)}
174:                         disabled={isPending}
175:                      >
176:                         {isPending && <Loader2 className="mr-2 h-4 w-4 animate-spin" />}
177:                         Confirm {targetConfig.label}
178:                      </Button>
179:                 </DialogFooter>
180:             </DialogContent>
181:         </Dialog>
182:       )
183:   }
184:   return (
185:     <Dialog open={open} onOpenChange={onOpenChange}>
186:       <DialogContent className="sm:max-w-[500px]">
187:         <DialogHeader>
188:           <DialogTitle>Update Booking Status</DialogTitle>
189:           <DialogDescription>
190:             Current Status: <Badge variant="outline" className="ml-1">{currentConfig?.label || currentStatus}</Badge>
191:           </DialogDescription>
192:         </DialogHeader>
193:         <div className="py-4 space-y-4">
194:             {availableTransitions.length === 0 ? (
195:                 <div className="text-center py-8 text-muted-foreground">
196:                     <p>No further actions available for this booking.</p>
197:                 </div>
198:             ) : (
199:                 <div className="grid gap-3">
200:                     {availableTransitions.map((status) => {
201:                         const config = STATUS_CONFIG[status];
202:                         const Icon = config.icon;
203:                         return (
204:                             <Button
205:                                 key={status}
206:                                 variant="outline"
207:                                 className={`h-auto py-4 px-4 justify-start text-left items-start hover:bg-slate-50 border-2 ${
208:                                     config.variant === 'destructive'
209:                                         ? 'hover:border-destructive/30 hover:text-destructive'
210:                                         : 'hover:border-primary/30'
211:                                 }`}
212:                                 onClick={() => handleActionClick(status)}
213:                                 disabled={isPending}
214:                             >
215:                                 <div className={`p-2 rounded-full mr-4 ${
216:                                     config.variant === 'destructive'
217:                                         ? 'bg-red-100 text-red-600'
218:                                         : 'bg-primary/10 text-primary'
219:                                 }`}>
220:                                     <Icon className="w-5 h-5" />
221:                                 </div>
222:                                 <div>
223:                                     <div className="font-semibold">{config.label}</div>
224:                                     <div className="text-sm text-muted-foreground font-normal">
225:                                         {config.description}
226:                                     </div>
227:                                 </div>
228:                             </Button>
229:                         )
230:                     })}
231:                 </div>
232:             )}
233:         </div>
234:         <DialogFooter className="sm:justify-start">
235:           <Button
236:             type="button"
237:             variant="ghost"
238:             onClick={() => onOpenChange(false)}
239:             disabled={isPending}
240:           >
241:             Close
242:           </Button>
243:         </DialogFooter>
244:       </DialogContent>
245:     </Dialog>
246:   );
247: }
</file>

