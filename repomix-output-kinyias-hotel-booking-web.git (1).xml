  6: } from '@nestjs/common';
  7: import { CreateRoomTypeDto } from './dto/create-room-type.dto';
  8: import { UpdateRoomTypeDto } from './dto/update-room-type.dto';
  9: import { AvailableRoomTypeDto, ListRoomTypeDto } from './dto/list-room-type.dto';
 10: import { Prisma } from '@prisma/client';
 11: import { PrismaService } from '../prisma/prisma.service';
 12: @Injectable()
 13: export class RoomTypeService {
 14:   constructor(private prisma: PrismaService) {}
 15:   private async assertHotelAccess(hotelId: string, userId: string) {
 16:     const hotel = await this.prisma.hotel.findUnique({
 17:       where: { id: hotelId },
 18:       select: { id: true, ownerId: true },
 19:     });
 20:     if (!hotel) throw new NotFoundException('Hotel not found');
 21:     if (hotel.ownerId === userId) return;
 22:     const member = await this.prisma.hotelMember.findUnique({
 23:       where: { hotelId_userId: { hotelId, userId } },
 24:       select: { userId: true },
 25:     });
 26:     if (!member)
 27:       throw new ForbiddenException('You are not a member of this hotel');
 28:   }
 29:   private async assertAmenityIdsValid(amenityIds: string[]) {
 30:     if (!amenityIds.length) return;
 31:     const found = await this.prisma.amenity.findMany({
 32:       where: { id: { in: amenityIds }, isActive: true },
 33:       select: { id: true },
 34:     });
 35:     if (found.length !== amenityIds.length) {
 36:       throw new BadRequestException('Some amenities are invalid or inactive');
 37:     }
 38:   }
 39:   private async assertRoomTypeNameUnique(
 40:     hotelId: string,
 41:     name: string,
 42:     excludeId?: string,
 43:   ) {
 44:     const dup = await this.prisma.roomType.findFirst({
 45:       where: {
 46:         hotelId,
 47:         deletedAt: null,
 48:         name: { equals: name, mode: Prisma.QueryMode.insensitive },
 49:         ...(excludeId ? { NOT: { id: excludeId } } : {}),
 50:       },
 51:       select: { id: true },
 52:     });
 53:     if (dup) {
 54:       throw new BadRequestException(
 55:         'Room type name already exists in this hotel',
 56:       );
 57:     }
 58:   }
 59:   async create(hotelId: string, userId: string, dto: CreateRoomTypeDto) {
 60:     await this.assertHotelAccess(hotelId, userId);
 61:     const amenityIds = dto.amenityIds ?? [];
 62:     await this.assertAmenityIdsValid(amenityIds);
 63:     const name = dto.name.trim();
 64:     await this.assertRoomTypeNameUnique(hotelId, name);
 65:     const roomType = await this.prisma.$transaction(async (tx) => {
 66:       const created = await tx.roomType.create({
 67:         data: {
 68:           hotelId,
 69:           name,
 70:           price_per_night: new Prisma.Decimal(dto.price_per_night),
 71:           max_guests: dto.max_guests,
 72:           description: dto.description?.trim() || null,
 73:           images: {
 74:             create: dto.images?.map((img) => ({ url: img.url })) || [],
 75:           },
 76:         },
 77:         select: { id: true },
 78:       });
 79:       if (amenityIds.length) {
 80:         await tx.roomTypeAmenity.createMany({
 81:           data: amenityIds.map((amenityId) => ({
 82:             typeId: created.id,
 83:             amenityId,
 84:           })),
 85:           skipDuplicates: true,
 86:         });
 87:       }
 88:       return tx.roomType.findUnique({
 89:         where: { id: created.id },
 90:         include: {
 91:           amenities: { include: { amenity: true } },
 92:           images: true,
 93:         },
 94:       });
 95:     });
 96:     return roomType;
 97:   }
 98:   async list(hotelId: string, userId: string, q: ListRoomTypeDto) {
 99:     await this.assertHotelAccess(hotelId, userId);
100:     const limit = q.limit ?? 20;
101:     const offset = q.page ? (q.page - 1) * limit : 0;
102:     const where: Prisma.RoomTypeWhereInput = {
103:       hotelId,
104:       deletedAt: null,
105:       ...(q.q
106:         ? {
107:             OR: [
108:               { name: { contains: q.q, mode: Prisma.QueryMode.insensitive } },
109:               {
110:                 description: {
111:                   contains: q.q,
112:                   mode: Prisma.QueryMode.insensitive,
113:                 },
114:               },
115:             ],
116:           }
117:         : {}),
118:     };
119:     const [items, total] = await this.prisma.$transaction([
120:       this.prisma.roomType.findMany({
121:         where,
122:         skip: offset,
123:         take: limit,
124:         orderBy: { createdAt: 'desc' },
125:         include: {
126:           amenities: { include: { amenity: true } },
127:           images: true,
128:         },
129:       }),
130:       this.prisma.roomType.count({ where }),
131:     ]);
132:     return {
133:       data: items,
134:       meta: {
135:         limit,
136:         offset,
137:         total,
138:       },
139:     };
140:   }
141:   async getAvailableRoomTypes(
142:     hotelId: string,
143:     q: AvailableRoomTypeDto,
144:   ) {
145:     const limit = q.limit ?? 20;
146:     const offset = q.page ? (q.page - 1) * limit : 0;
147:     const startDate = new Date(q.from);
148:     const endDate = new Date(q.to);
149:     if (isNaN(startDate.getTime()) || isNaN(endDate.getTime())) {
150:       throw new BadRequestException('Invalid date format');
151:     }
152:     if (startDate > endDate) {
153:       throw new BadRequestException('Start date must be before end date');
154:     }
155:     const where: Prisma.RoomTypeWhereInput = {
156:       hotelId,
157:       deletedAt: null,
158:       ...(q.q
159:         ? {
160:             OR: [
161:               { name: { contains: q.q, mode: Prisma.QueryMode.insensitive } },
162:               {
163:                 description: {
164:                   contains: q.q,
165:                   mode: Prisma.QueryMode.insensitive,
166:                 },
167:               },
168:             ],
169:           }
170:         : {}),
171:     };
172:     const [items, total] = await this.prisma.$transaction([
173:       this.prisma.roomType.findMany({
174:         where,
175:         skip: offset,
176:         take: limit,
177:         orderBy: { price_per_night: 'asc' },
178:         include: {
179:           amenities: { include: { amenity: true } },
180:           images: true,
181:         },
182:       }),
183:       this.prisma.roomType.count({ where }),
184:     ]);
185:     const dayCount =
186:       Math.floor((endDate.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24)) + 1;
187:     const roomTypeIds = items.map((rt) => rt.id);
188:     const inventories = await this.prisma.inventory.findMany({
189:       where: {
190:         hotelId,
191:         roomTypeId: { in: roomTypeIds },
192:         date: {
193:           gte: startDate,
194:           lte: endDate,
195:         },
196:       },
197:     });
198:     const data = items.map((rt) => {
199:       const rtInvs = inventories.filter((inv) => inv.roomTypeId === rt.id);
200:       const hasStopSell = rtInvs.some((inv) => inv.stopSell);
201:       if (hasStopSell) {
202:         return { ...rt, availableRooms: 0 };
203:       }
204:       if (rtInvs.length < dayCount) {
205:         return { ...rt, availableRooms: 0 };
206:       }
207:       const minAvailable = Math.min(...rtInvs.map((inv) => inv.availableRooms));
208:       return {
209:         ...rt,
210:         availableRooms: minAvailable > 0 ? minAvailable : 0,
211:       };
212:     });
213:     return {
214:       data,
215:       meta: {
216:         limit,
217:         offset,
218:         total,
219:       },
220:     };
221:   }
222:   async getOne(hotelId: string, userId: string, id: string) {
223:     await this.assertHotelAccess(hotelId, userId);
224:     const roomType = await this.prisma.roomType.findFirst({
225:       where: { id, hotelId, deletedAt: null },
226:       include: {
227:         amenities: { include: { amenity: true } },
228:         images: true,
229:       },
230:     });
231:     if (!roomType) throw new NotFoundException('Room type not found');
232:     return roomType;
233:   }
234:   async update(
235:     hotelId: string,
236:     userId: string,
237:     id: string,
238:     dto: UpdateRoomTypeDto,
239:   ) {
240:     await this.assertHotelAccess(hotelId, userId);
241:     const existing = await this.prisma.roomType.findFirst({
242:       where: { id, hotelId, deletedAt: null },
243:       select: { id: true },
244:     });
245:     if (!existing) throw new NotFoundException('Room type not found');
246:     const { images, amenityIds, ...otherData } = dto;
247:     let imageOps: any = undefined;
248:     let amenityOps: any = undefined;
249:     if (otherData.name !== undefined) {
250:       const name = otherData.name.trim();
251:       await this.assertRoomTypeNameUnique(hotelId, name, id);
252:     }
253:     if (images) {
254:       const current = await this.prisma.roomType.findUnique({
255:         where: { id },
256:         include: { images: true },
257:       });
258:       if (current) {
259:         const currentImageIds = current.images.map((img) => img.id);
260:         const imagesToUpdate = images.filter(
261:           (img) => img.id && currentImageIds.includes(img.id),
262:         );
263:         const imagesToCreate = images.filter(
264:           (img) => !img.id || (img.id && !currentImageIds.includes(img.id)),
265:         );
266:         const validUpdateIds = new Set(imagesToUpdate.map((img) => img.id));
267:         const imagesToDeleteIds = currentImageIds.filter(
268:           (imgId) => !validUpdateIds.has(imgId),
269:         );
270:         imageOps = {
271:           deleteMany: { id: { in: imagesToDeleteIds } },
272:           update: imagesToUpdate.map((img) => ({
273:             where: { id: img.id },
274:             data: { url: img.url },
275:           })),
276:           create: imagesToCreate.map((img) => ({ url: img.url })),
277:         };
278:       }
279:     }
280:     if(amenityIds){
281:       const current = await this.prisma.roomType.findUnique({
282:       where: { id },
283:       include: { amenities: { include: { amenity: true } } },
284:     });
285:     if (current) {
286:       const currentAmenityIds = current.amenities.map(
287:         a => a.amenityId,
288:       );
289:       const toCreate = amenityIds.filter(
290:         aid => !currentAmenityIds.includes(aid),
291:       );
292:       const toDelete = currentAmenityIds.filter(
293:         aid => !amenityIds.includes(aid),
294:       );
295:       amenityOps = {
296:         deleteMany: {
297:           amenityId: { in: toDelete },
298:         },
299:         create: toCreate.map(amenityId => ({
300:           amenityId,
301:         })),
302:       };
303:     }
304:     }
305:     return await this.prisma.roomType.update({
306:       where: { id },
307:       data: {
308:         ...(otherData.name !== undefined
309:           ? { name: otherData.name.trim() }
310:           : {}),
311:         ...(otherData.price_per_night !== undefined
312:           ? { price_per_night: new Prisma.Decimal(otherData.price_per_night) }
313:           : {}),
314:         ...(otherData.max_guests !== undefined
315:           ? { max_guests: otherData.max_guests }
316:           : {}),
317:         ...(otherData.description !== undefined
318:           ? { description: otherData.description?.trim() || null }
319:           : {}),
320:         ...(imageOps ? { images: imageOps } : {}),
321:         ...(amenityOps ? { amenities: amenityOps } : {}),
322:       },
323:       include: {
324:         amenities: { include: { amenity: true } },
325:         images: true,
326:       },
327:     });
328:   }
329:   async remove(hotelId: string, userId: string, id: string) {
330:     await this.assertHotelAccess(hotelId, userId);
331:     const existing = await this.prisma.roomType.findFirst({
332:       where: { id, hotelId, deletedAt: null },
333:       select: { id: true },
334:     });
335:     if (!existing) throw new NotFoundException('Room type not found');
336:     await this.prisma.roomType.update({
337:       where: { id },
338:       data: {
339:         deletedAt: new Date(),
340:       },
341:     });
342:     return { deleted: true };
343:   }
344:   async listAll(q: ListRoomTypeDto) {
345:     const limit = q.limit ?? 20;
346:     const offset = q.page ? (q.page - 1) * limit : 0;
347:     const where: Prisma.RoomTypeWhereInput = {
348:       deletedAt: null,
349:       ...(q.q
350:         ? {
351:             OR: [
352:               { name: { contains: q.q, mode: Prisma.QueryMode.insensitive } },
353:               {
354:                 description: {
355:                   contains: q.q,
356:                   mode: Prisma.QueryMode.insensitive,
357:                 },
358:               },
359:             ],
360:           }
361:         : {}),
362:     };
363:     const [items, total] = await this.prisma.$transaction([
364:       this.prisma.roomType.findMany({
365:         where,
366:         skip: offset,
367:         take: limit,
368:         orderBy: { createdAt: 'desc' },
369:         include: {
370:           amenities: { include: { amenity: true } },
371:           images: true,
372:           hotel: true,
373:         },
374:       }),
375:       this.prisma.roomType.count({ where }),
376:     ]);
377:     return {
378:       data: items,
379:       meta: {
380:         limit,
381:         offset,
382:         total,
383:       },
384:     };
385:   }
386: }
</file>

