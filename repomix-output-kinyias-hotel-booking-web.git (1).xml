 84:         <h2 className="text-2xl font-bold text-destructive">Unable to load news</h2>
 85:         <p className="text-muted-foreground mt-2">Please try again later.</p>
 86:         <Button
 87:             variant="outline"
 88:             className="mt-4"
 89:             onClick={() => window.location.reload()}
 90:         >
 91:             Retry
 92:         </Button>
 93:       </div>
 94:     );
