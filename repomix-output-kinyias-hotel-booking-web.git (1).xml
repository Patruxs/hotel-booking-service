109:                   value={selectedYear.toString()}
110:                   onValueChange={(value) => setSelectedYear(parseInt(value))}
111:                 >
112:                   <SelectTrigger className="w-[120px]">
113:                     <SelectValue placeholder="Select year" />
114:                   </SelectTrigger>
115:                   <SelectContent>
116:                     {Array.from({ length: 5 }, (_, i) => currentYear - i).map(
117:                       (year) => (
118:                         <SelectItem key={year} value={year.toString()}>
119:                           {year}
120:                         </SelectItem>
121:                       )
122:                     )}
123:                   </SelectContent>
124:                 </Select>
125:               ) : (
126:                 <>
127:                   {}
128:                   <Popover>
129:                     <PopoverTrigger asChild>
130:                       <Button
131:                         variant="outline"
132:                         className="w-[280px] justify-start text-left font-normal"
133:                       >
134:                         <CalendarIcon className="mr-2 h-4 w-4" />
135:                         {dateRange?.from ? (
136:                           dateRange.to ? (
137:                             <>
138:                               {format(dateRange.from, 'dd/MM/yyyy')} -{' '}
139:                               {format(dateRange.to, 'dd/MM/yyyy')}
140:                             </>
141:                           ) : (
