 1: import { useMutation, useQueryClient } from "@tanstack/react-query"
 2: import { cancleBooking, createBooking, createPayment, updateBookingStatus } from "./api"
 3: import { BookingStatus, CreateBookingDto } from "./types"
 4: export const useCreateBookingMutation = (hotelId: string) => {
 5:     return useMutation({
 6:         mutationFn: (payload: CreateBookingDto)=> createBooking(hotelId, payload),
 7:     })
 8: }
 9: export const useUpdateBookingStatusMutation = (hotelId: string, bookingId: string) => {
10:     const queryClient = useQueryClient();
11:     return useMutation({
12:         mutationFn: (payload: BookingStatus)=> updateBookingStatus(hotelId, bookingId, payload),
13:         onSuccess: () => {
14:             queryClient.invalidateQueries({
15:                 queryKey: ['bookings', hotelId],
16:             });
17:             queryClient.invalidateQueries({
18:                 queryKey: ['booking', hotelId, bookingId],
19:             });
20:         },
21:     })
22: }
23: export const useCancelBookingMutation = (hotelId: string, bookingId: string) => {
24:     const queryClient = useQueryClient();
25:     return useMutation({
26:         mutationFn: ()=> cancleBooking(hotelId, bookingId),
27:         onSuccess: () => {
28:             queryClient.invalidateQueries({
29:                 queryKey: ['bookings', hotelId],
30:             });
31:         },
32:     })
33: }
34: export const useCreatePaymentMutation = (bookingId: string) => {
35:     return useMutation({
36:         mutationFn: ()=> createPayment(bookingId),
37:     })
38: }
39: export const useCheckInBookingMutation = (hotelId: string, bookingId: string) => {
40:     const queryClient = useQueryClient();
41:     return useMutation({
42:         mutationFn: (payload: any) => import("./api").then(mod => mod.checkInBooking(bookingId, payload)),
43:         onSuccess: () => {
44:              queryClient.invalidateQueries({ queryKey: ['bookings', hotelId] });
45:              queryClient.invalidateQueries({ queryKey: ['booking', hotelId, bookingId] });
46:         }
47:     });
48: }
</file>

