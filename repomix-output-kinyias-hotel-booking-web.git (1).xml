 52:   const [groupBy, setGroupBy] = useState<RevenueGroupBy>('month');
 53:   const queryParams = useMemo(() => {
 54:      if (viewType === 'year') {
 55:          return {
 56:              hotelId,
 57:              groupBy: 'month' as const,
 58:              year: selectedYear
 59:          }
 60:      }
 61:      return {
 62:         hotelId,
 63:         groupBy: groupBy === 'month' ? 'month' : 'day' as any,
 64:         from: dateRange.from?.toISOString(),
 65:         to: dateRange.to?.toISOString(),
 66:      }
 67:   }, [hotelId, viewType, selectedYear, dateRange, groupBy]);
 68:   const { data: rawData, isLoading } = useRevenueChartQuery(queryParams as any);
 69:   const chartData = useMemo(() => {
 70:       if (!rawData) return [];
 71:       if (Array.isArray(rawData) && typeof rawData[0] === 'number') {
 72:         return (rawData as number[]).map((total, index) => ({
 73:             name: monthNames[index],
 74:             revenue: total,
 75:         }));
 76:       }
 77:       const list = rawData as { date: string, revenue: number }[];
 78:       return list.map(item => ({
 79:         name: format(new Date(item.date), groupBy === 'month' ? 'MM/yyyy' : 'dd/MM/yyyy', { locale: vi }),
 80:         revenue: item.revenue
 81:       })).sort((a, b) => {
 82:           const [a1, a2, a3] = a.name.split('/').map(Number);
 83:           const [b1, b2, b3] = b.name.split('/').map(Number);
 84:           return 0;
 85:       });
 86:   }, [rawData, groupBy]);
 87:   return (
 88:     <>
 89:       <Card>
