<file path="apps/web/src/hooks/use-scrolling.ts">
 1: import type { RefObject } from "react"
 2: import { useEffect, useState } from "react"
 3: type ScrollTarget = RefObject<HTMLElement> | Window | null | undefined
 4: type EventTargetWithScroll = Window | HTMLElement | Document
 5: interface UseScrollingOptions {
 6:   debounce?: number
 7:   fallbackToDocument?: boolean
 8: }
 9: export function useScrolling(
10:   target?: ScrollTarget,
11:   options: UseScrollingOptions = {}
12: ): boolean {
13:   const { debounce = 150, fallbackToDocument = true } = options
14:   const [isScrolling, setIsScrolling] = useState(false)
15:   useEffect(() => {
16:     const element: EventTargetWithScroll =
17:       target && typeof Window !== "undefined" && target instanceof Window
18:         ? target
19:         : ((target as RefObject<HTMLElement>)?.current ?? window)
20:     const eventTarget: EventTargetWithScroll =
21:       fallbackToDocument &&
22:       element === window &&
23:       typeof document !== "undefined"
24:         ? document
25:         : element
26:     const on = (
27:       el: EventTargetWithScroll,
28:       event: string,
29:       handler: EventListener
30:     ) => el.addEventListener(event, handler, true)
31:     const off = (
32:       el: EventTargetWithScroll,
33:       event: string,
34:       handler: EventListener
35:     ) => el.removeEventListener(event, handler)
36:     let timeout: ReturnType<typeof setTimeout>
37:     const supportsScrollEnd = element === window && "onscrollend" in window
38:     const handleScroll: EventListener = () => {
39:       if (!isScrolling) setIsScrolling(true)
40:       if (!supportsScrollEnd) {
41:         clearTimeout(timeout)
42:         timeout = setTimeout(() => setIsScrolling(false), debounce)
43:       }
44:     }
45:     const handleScrollEnd: EventListener = () => setIsScrolling(false)
46:     on(eventTarget, "scroll", handleScroll)
47:     if (supportsScrollEnd) {
48:       on(eventTarget, "scrollend", handleScrollEnd)
49:     }
50:     return () => {
51:       off(eventTarget, "scroll", handleScroll)
52:       if (supportsScrollEnd) {
53:         off(eventTarget, "scrollend", handleScrollEnd)
54:       }
55:       clearTimeout(timeout)
56:     }
57:   }, [target, debounce, fallbackToDocument, isScrolling])
58:   return isScrolling
59: }
</file>

