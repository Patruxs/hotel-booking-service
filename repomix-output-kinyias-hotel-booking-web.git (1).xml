  6: import { BoldIcon } from "@/components/tiptap-icons/bold-icon"
  7: import { Code2Icon } from "@/components/tiptap-icons/code2-icon"
  8: import { ItalicIcon } from "@/components/tiptap-icons/italic-icon"
  9: import { StrikeIcon } from "@/components/tiptap-icons/strike-icon"
 10: import { SubscriptIcon } from "@/components/tiptap-icons/subscript-icon"
 11: import { SuperscriptIcon } from "@/components/tiptap-icons/superscript-icon"
 12: import { UnderlineIcon } from "@/components/tiptap-icons/underline-icon"
 13: export type Mark =
 14:   | "bold"
 15:   | "italic"
 16:   | "strike"
 17:   | "code"
 18:   | "underline"
 19:   | "superscript"
 20:   | "subscript"
 21: export interface UseMarkConfig {
 22:   editor?: Editor | null
 23:   type: Mark
 24:   hideWhenUnavailable?: boolean
 25:   onToggled?: () => void
 26: }
 27: export const markIcons = {
 28:   bold: BoldIcon,
 29:   italic: ItalicIcon,
 30:   underline: UnderlineIcon,
 31:   strike: StrikeIcon,
 32:   code: Code2Icon,
 33:   superscript: SuperscriptIcon,
 34:   subscript: SubscriptIcon,
 35: }
 36: export const MARK_SHORTCUT_KEYS: Record<Mark, string> = {
 37:   bold: "mod+b",
 38:   italic: "mod+i",
 39:   underline: "mod+u",
 40:   strike: "mod+shift+s",
 41:   code: "mod+e",
 42:   superscript: "mod+.",
 43:   subscript: "mod+,",
 44: }
 45: export function canToggleMark(editor: Editor | null, type: Mark): boolean {
 46:   if (!editor || !editor.isEditable) return false
 47:   if (!isMarkInSchema(type, editor) || isNodeTypeSelected(editor, ["image"]))
 48:     return false
 49:   return editor.can().toggleMark(type)
 50: }
 51: export function isMarkActive(editor: Editor | null, type: Mark): boolean {
 52:   if (!editor || !editor.isEditable) return false
 53:   return editor.isActive(type)
 54: }
 55: export function toggleMark(editor: Editor | null, type: Mark): boolean {
 56:   if (!editor || !editor.isEditable) return false
 57:   if (!canToggleMark(editor, type)) return false
 58:   return editor.chain().focus().toggleMark(type).run()
 59: }
 60: export function shouldShowButton(props: {
 61:   editor: Editor | null
 62:   type: Mark
 63:   hideWhenUnavailable: boolean
 64: }): boolean {
 65:   const { editor, type, hideWhenUnavailable } = props
 66:   if (!editor || !editor.isEditable) return false
 67:   if (!isMarkInSchema(type, editor)) return false
 68:   if (hideWhenUnavailable && !editor.isActive("code")) {
 69:     return canToggleMark(editor, type)
 70:   }
 71:   return true
 72: }
 73: export function getFormattedMarkName(type: Mark): string {
 74:   return type.charAt(0).toUpperCase() + type.slice(1)
 75: }
 76: export function useMark(config: UseMarkConfig) {
 77:   const {
 78:     editor: providedEditor,
 79:     type,
 80:     hideWhenUnavailable = false,
 81:     onToggled,
 82:   } = config
 83:   const { editor } = useTiptapEditor(providedEditor)
 84:   const [isVisible, setIsVisible] = useState<boolean>(true)
 85:   const canToggle = canToggleMark(editor, type)
 86:   const isActive = isMarkActive(editor, type)
 87:   useEffect(() => {
 88:     if (!editor) return
 89:     const handleSelectionUpdate = () => {
 90:       setIsVisible(shouldShowButton({ editor, type, hideWhenUnavailable }))
 91:     }
 92:     handleSelectionUpdate()
 93:     editor.on("selectionUpdate", handleSelectionUpdate)
 94:     return () => {
 95:       editor.off("selectionUpdate", handleSelectionUpdate)
 96:     }
 97:   }, [editor, type, hideWhenUnavailable])
 98:   const handleMark = useCallback(() => {
 99:     if (!editor) return false
100:     const success = toggleMark(editor, type)
101:     if (success) {
102:       onToggled?.()
103:     }
104:     return success
105:   }, [editor, type, onToggled])
106:   return {
107:     isVisible,
108:     isActive,
109:     handleMark,
110:     canToggle,
111:     label: getFormattedMarkName(type),
112:     shortcutKeys: MARK_SHORTCUT_KEYS[type],
113:     Icon: markIcons[type],
114:   }
115: }
</file>

