  2: import React, { useState } from 'react';
  3: import { useForm } from 'react-hook-form';
  4: import { zodResolver } from '@hookform/resolvers/zod';
  5: import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogFooter } from '@/components/ui/dialog';
  6: import { Button } from '@/components/ui/button';
  7: import { Input } from '@/components/ui/input';
  8: import { Label } from '@/components/ui/label';
  9: import { Switch } from '@/components/ui/switch';
 10: import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
 11: import { Textarea } from '@/components/ui/textarea';
 12: import { useCreateBannerMutation } from '../mutations';
 13: import { createBannerSchema, CreateBannerFormData } from '../validator';
 14: import { BannerLinkType } from '../types';
 15: import { toast } from 'react-hot-toast';
 16: import { X, ImagePlus, Calendar as CalendarIcon } from 'lucide-react';
 17: import GalleryImagesDialog from '@/components/common/GalleryImagesDialog';
 18: import { Calendar } from '@/components/ui/calendar';
 19: import { Popover, PopoverContent, PopoverTrigger } from '@/components/ui/popover';
 20: import { format } from 'date-fns';
 21: import { cn } from '@/lib/utils';
 22: interface CreateBannerDialogProps {
 23:   open: boolean;
 24:   onOpenChange: (open: boolean) => void;
 25: }
 26: export function CreateBannerDialog({ open, onOpenChange }: CreateBannerDialogProps) {
 27:   const [imageUrls, setImageUrls] = useState<string[]>([]);
 28:   const [galleryOpen, setGalleryOpen] = useState(false);
 29:   const [currentImageIndex, setCurrentImageIndex] = useState<number | null>(null);
 30:   const createMutation = useCreateBannerMutation();
 31:   const {
 32:     register,
 33:     handleSubmit,
 34:     formState: { errors },
 35:     setValue,
 36:     watch,
 37:     reset,
 38:   } = useForm<CreateBannerFormData>({
 39:     resolver: zodResolver(createBannerSchema),
 40:     defaultValues: {
 41:       isActive: true,
 42:       position: 0,
 43:       linkType: BannerLinkType.URL,
 44:     },
 45:   });
 46:   const isActive = watch('isActive');
 47:   const linkType = watch('linkType');
 48:   const onSubmit = async (data: CreateBannerFormData) => {
 49:     try {
 50:       const filteredImages = imageUrls.filter((url) => url.trim() !== '');
 51:       if (filteredImages.length === 0) {
 52:         toast.error('At least one image is required');
 53:         return;
 54:       }
 55:       await createMutation.mutateAsync({
 56:         ...data,
 57:         images: filteredImages,
 58:         startAt: data.startAt || undefined,
 59:         endAt: data.endAt || undefined,
 60:       });
 61:       toast.success('Banner created successfully');
 62:       onOpenChange(false);
 63:       reset();
 64:       setImageUrls([]);
 65:     } catch (error: any) {
 66:       toast.error(error?.response?.data?.message || 'Failed to create banner');
 67:     }
 68:   };
 69:   const addImageSlot = () => {
 70:     setImageUrls([...imageUrls, '']);
 71:   };
 72:   const removeImageSlot = (index: number) => {
 73:     const newUrls = imageUrls.filter((_, i) => i !== index);
 74:     setImageUrls(newUrls);
 75:     setValue('images', newUrls.filter((url) => url.trim() !== ''));
 76:   };
 77:   const openGalleryForImage = (index: number) => {
 78:     setCurrentImageIndex(index);
 79:     setGalleryOpen(true);
 80:   };
 81:   const handleGalleryConfirm = (images: { id?: string; url: string }[]) => {
 82:     if (currentImageIndex !== null && images.length > 0) {
 83:       const newUrls = [...imageUrls];
 84:       newUrls[currentImageIndex] = images[0].url;
 85:       setImageUrls(newUrls);
 86:       setValue('images', newUrls.filter((url) => url.trim() !== ''));
 87:     }
 88:     setGalleryOpen(false);
 89:     setCurrentImageIndex(null);
 90:   };
 91:   const startAt = watch('startAt');
 92:   const endAt = watch('endAt');
 93:   return (
 94:     <>
 95:       <Dialog open={open} onOpenChange={onOpenChange}>
 96:         <DialogContent className="min-w-[50vw] max-h-[90vh] overflow-y-auto">
 97:           <DialogHeader>
 98:             <DialogTitle>Create New Banner</DialogTitle>
 99:           </DialogHeader>
100:           <form onSubmit={handleSubmit(onSubmit)} className="space-y-4">
101:             {}
102:             <div className="space-y-2">
103:               <Label htmlFor="title">Title (Optional)</Label>
104:               <Input id="title" {...register('title')} placeholder="Enter banner title" />
105:               {errors.title && <p className="text-sm text-red-500">{errors.title.message}</p>}
106:             </div>
107:             <div className="space-y-2">
