 2: import { useCallback, useEffect, useState } from "react"
 3: import { type Editor } from "@tiptap/react"
 4: import { useTiptapEditor } from "@/hooks/use-tiptap-editor"
 5: import { isNodeTypeSelected } from "@/lib/tiptap-utils"
 6: import { Redo2Icon } from "@/components/tiptap-icons/redo2-icon"
 7: import { Undo2Icon } from "@/components/tiptap-icons/undo2-icon"
 8: export type UndoRedoAction = "undo" | "redo"
 9: export interface UseUndoRedoConfig {
10:   editor?: Editor | null
11:   action: UndoRedoAction
12:   hideWhenUnavailable?: boolean
13:   onExecuted?: () => void
14: }
15: export const UNDO_REDO_SHORTCUT_KEYS: Record<UndoRedoAction, string> = {
16:   undo: "mod+z",
17:   redo: "mod+shift+z",
18: }
19: export const historyActionLabels: Record<UndoRedoAction, string> = {
20:   undo: "Undo",
21:   redo: "Redo",
22: }
23: export const historyIcons = {
24:   undo: Undo2Icon,
25:   redo: Redo2Icon,
26: }
27: export function canExecuteUndoRedoAction(
28:   editor: Editor | null,
29:   action: UndoRedoAction
30: ): boolean {
31:   if (!editor || !editor.isEditable) return false
32:   if (isNodeTypeSelected(editor, ["image"])) return false
33:   return action === "undo" ? editor.can().undo() : editor.can().redo()
34: }
35: export function executeUndoRedoAction(
36:   editor: Editor | null,
37:   action: UndoRedoAction
38: ): boolean {
39:   if (!editor || !editor.isEditable) return false
40:   if (!canExecuteUndoRedoAction(editor, action)) return false
41:   const chain = editor.chain().focus()
42:   return action === "undo" ? chain.undo().run() : chain.redo().run()
43: }
44: export function shouldShowButton(props: {
45:   editor: Editor | null
46:   hideWhenUnavailable: boolean
47:   action: UndoRedoAction
48: }): boolean {
49:   const { editor, hideWhenUnavailable, action } = props
50:   if (!editor || !editor.isEditable) return false
51:   if (hideWhenUnavailable && !editor.isActive("code")) {
52:     return canExecuteUndoRedoAction(editor, action)
53:   }
54:   return true
55: }
56: export function useUndoRedo(config: UseUndoRedoConfig) {
57:   const {
58:     editor: providedEditor,
59:     action,
60:     hideWhenUnavailable = false,
61:     onExecuted,
62:   } = config
63:   const { editor } = useTiptapEditor(providedEditor)
64:   const [isVisible, setIsVisible] = useState<boolean>(true)
65:   const canExecute = canExecuteUndoRedoAction(editor, action)
66:   useEffect(() => {
67:     if (!editor) return
68:     const handleUpdate = () => {
69:       setIsVisible(shouldShowButton({ editor, hideWhenUnavailable, action }))
70:     }
71:     handleUpdate()
72:     editor.on("transaction", handleUpdate)
73:     return () => {
74:       editor.off("transaction", handleUpdate)
75:     }
76:   }, [editor, hideWhenUnavailable, action])
77:   const handleAction = useCallback(() => {
78:     if (!editor) return false
79:     const success = executeUndoRedoAction(editor, action)
80:     if (success) {
81:       onExecuted?.()
82:     }
83:     return success
84:   }, [editor, action, onExecuted])
85:   return {
86:     isVisible,
87:     handleAction,
88:     canExecute,
89:     label: historyActionLabels[action],
90:     shortcutKeys: UNDO_REDO_SHORTCUT_KEYS[action],
