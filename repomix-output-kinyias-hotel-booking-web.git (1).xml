 1: import * as crypto from 'crypto';
 2: import * as qs from 'qs';
 3: export function sortObject(obj: Record<string, any>) {
 4:   const sorted: Record<string, any> = {};
 5:   const keys = Object.keys(obj).map(encodeURIComponent).sort();
 6:   for (const k of keys) {
 7:     sorted[k] = encodeURIComponent(obj[decodeURIComponent(k)]).replace(
 8:       /%20/g,
 9:       '+',
10:     );
11:   }
12:   return sorted;
13: }
14: export function signParams(
15:   vnpParamsSorted: Record<string, any>,
16:   hashSecret: string,
17: ) {
18:   const signData = qs.stringify(vnpParamsSorted, { encode: false });
19:   return crypto
20:     .createHmac('sha512', hashSecret)
21:     .update(Buffer.from(signData, 'utf-8'))
22:     .digest('hex');
23: }
