555:   @Cron(CronExpression.EVERY_MINUTE)
556:   async cancelExpiredPendingBookings() {
557:     const cutoff = new Date(Date.now() - this.PENDING_TTL_MINUTES * 60 * 1000);
558:     const expired = await this.prisma.booking.findMany({
559:       where: {
560:         status: BookingStatus.PENDING,
561:         createdAt: { lt: cutoff },
562:         payments: {
563:           none: {
564:             status: { in: [PaymentStatus.SUCCEEDED] },
565:           },
566:         },
567:       },
568:       select: {
569:         id: true,
570:         hotelId: true,
571:         checkIn: true,
572:         checkOut: true,
573:         items: { select: { roomTypeId: true, quantity: true } },
574:       },
575:       take: 100,
576:     });
577:     if (!expired.length) return;
578:     let cancelledCount = 0;
579:     for (const b of expired) {
580:       try {
581:         await this.prisma.$transaction(async (tx) => {
582:           const updated = await tx.booking.updateMany({
583:             where: { id: b.id, status: BookingStatus.PENDING },
584:             data: { status: BookingStatus.CANCELLED },
585:           });
586:           if (updated.count !== 1) return;
587:           const nights = eachDateFixed(b.checkIn, b.checkOut);
588:           for (const item of b.items) {
589:             for (const day of nights) {
590:               await tx.inventory.updateMany({
591:                 where: {
592:                   hotelId: b.hotelId,
593:                   roomTypeId: item.roomTypeId,
594:                   date: day,
595:                 },
596:                 data: { availableRooms: { increment: item.quantity } },
597:               });
598:             }
599:           }
600:         });
601:         cancelledCount++;
602:       } catch (e: any) {
603:         this.logger.warn(
604:           `Cancel expired booking failed: ${b.id} - ${e?.message ?? e}`,
605:         );
606:       }
607:     }
608:     if (cancelledCount) {
609:       this.logger.log(
610:         `Auto-cancelled ${cancelledCount} expired pending booking(s).`,
611:       );
612:     }
613:   }
614:   async checkIn(bookingId: string, actorUserId: string, dto: CheckInDto) {
615:     const booking = await this.assertHotelAccessByBooking(
616:       bookingId,
617:       actorUserId,
618:     );
619:     if (booking.status === BookingStatus.CANCELLED) {
620:       throw new BadRequestException('Booking is cancelled');
621:     }
622:     if (booking.status === BookingStatus.COMPLETED) {
623:       throw new BadRequestException('Booking already completed');
624:     }
625:     const guests = this.normalizeGuests(dto);
626:     if (!guests.length) throw new BadRequestException('Guests are required');
627:     const result = await this.prisma.$transaction(async (tx) => {
628:       const checkIn = await tx.checkIn.upsert({
629:         where: { bookingId },
630:         create: {
631:           bookingId,
632:           checkedInBy: actorUserId,
633:           note: dto.note ?? null,
634:           checkedInAt: new Date(),
635:         },
636:         update: {
637:           checkedInBy: actorUserId,
638:           note: dto.note ?? null,
639:           checkedInAt: new Date(),
640:         },
641:       });
642:       await tx.bookingGuest.deleteMany({ where: { bookingId } });
643:       await tx.bookingGuest.createMany({
644:         data: guests.map((g) => ({
645:           bookingId,
646:           userId: g.userId ?? null,
647:           fullName: g.fullName,
648:           email: g.email ?? null,
649:           phone: g.phone ?? null,
650:           dateOfBirth: g.dateOfBirth ? new Date(g.dateOfBirth) : null,
651:           gender: (g.gender as Gender) ?? null,
652:           idNumber: g.idNumber ?? null,
653:           nationality: g.nationality ?? null,
654:         })),
655:       });
656:       await tx.booking.update({
657:         where: { id: bookingId },
658:         data: { status: BookingStatus.CHECKED_IN },
659:       });
660:       const guestsAfter = await tx.bookingGuest.findMany({
661:         where: { bookingId },
662:         orderBy: { createdAt: 'asc' },
663:       });
664:       return { checkIn, guests: guestsAfter };
665:     });
666:     return { data: result };
667:   }
668:   async getCheckIn(bookingId: string, actorUserId: string) {
669:     await this.assertHotelAccessByBooking(bookingId, actorUserId);
670:     const checkIn = await this.prisma.checkIn.findUnique({
671:       where: { bookingId },
672:     });
673:     const guests = await this.prisma.bookingGuest.findMany({
674:       where: { bookingId },
675:       orderBy: { createdAt: 'asc' },
676:     });
677:     return { data: { checkIn, guests } };
678:   }
679: }
