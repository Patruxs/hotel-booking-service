354:     const to = blockPos + blockNode.nodeSize - 2
355:     if (from < to) {
356:       const $from = doc.resolve(from)
357:       const $to = doc.resolve(to)
358:       const newSelection = TextSelection.between($from, $to, 1)
359:       if (newSelection && !selection.eq(newSelection)) {
360:         editor.view.dispatch(editor.state.tr.setSelection(newSelection))
