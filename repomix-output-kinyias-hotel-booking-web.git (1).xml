  1: import {
  2:   BadRequestException,
  3:   ForbiddenException,
  4:   Injectable,
  5:   Logger,
  6:   NotFoundException,
  7: } from '@nestjs/common';
  8: import { PrismaService } from '../prisma/prisma.service';
  9: import { CreateBookingDto } from './dto/create-booking.dto';
 10: import { Prisma, BookingStatus, PaymentStatus, Gender, NotificationType, DiscountType } from '@prisma/client';
 11: import { NotificationService } from '../notification/notification.service';
 12: import { ListMyBookingDto } from './dto/list-my-bookings.dto';
 13: import { UpdateBookingStatusDto } from './dto/update-booking-status.dto';
 14: import { Cron, CronExpression } from '@nestjs/schedule';
 15: import {
 16:   CheckInDto,
 17:   CheckInGuestDto,
 18: } from './dto/check-in.dto';
 19: function eachDateFixed(from: Date, to: Date) {
 20:   const dates: Date[] = [];
 21:   const d = new Date(from);
 22:   d.setUTCHours(0, 0, 0, 0);
 23:   const end = new Date(to);
 24:   end.setUTCHours(0, 0, 0, 0);
 25:   while (d < end) {
 26:     dates.push(new Date(d));
 27:     d.setUTCDate(d.getUTCDate() + 1);
 28:   }
 29:   return dates;
 30: }
 31: function toDateOnly(d: string) {
 32:   return new Date(`${d}T00:00:00.000Z`);
 33: }
 34: @Injectable()
 35: export class BookingService {
 36:   constructor(
 37:     private prisma: PrismaService,
 38:     private readonly notificationService: NotificationService,
 39:   ) {}
 40:   private readonly PENDING_TTL_MINUTES = 15;
 41:   private readonly logger = new Logger(BookingService.name);
 42:   private async assertHotelAccessByBooking(bookingId: string, userId: string) {
 43:     const booking = await this.prisma.booking.findUnique({
 44:       where: { id: bookingId },
 45:       select: {
 46:         id: true,
 47:         status: true,
 48:         hotelId: true,
 49:         hotel: { select: { ownerId: true } },
 50:       },
 51:     });
 52:     if (!booking) throw new NotFoundException('Booking not found');
 53:     if (booking.hotel.ownerId === userId) return booking;
 54:     const member = await this.prisma.hotelMember.findUnique({
 55:       where: { hotelId_userId: { hotelId: booking.hotelId, userId } },
 56:       select: { userId: true },
 57:     });
 58:     if (member) return booking;
 59:     throw new ForbiddenException(
 60:       'You are not allowed to check-in this booking',
 61:     );
 62:   }
 63:   private normalizeGuests(dto: CheckInDto): CheckInGuestDto[] {
 64:     const companions = dto.companions ?? [];
 65:     const all = [dto.primary, ...companions];
 66:     const seen = new Set<string>();
 67:     const res: CheckInGuestDto[] = [];
 68:     for (const g of all) {
 69:       const userKey = g.userId ? `u:${g.userId}` : null;
 70:       const naturalKey = `n:${(g.fullName || '').trim().toLowerCase()}|${g.idNumber || ''}|${g.email || ''}`;
 71:       const key = userKey ?? naturalKey;
 72:       if (seen.has(key)) continue;
 73:       seen.add(key);
 74:       res.push(g);
 75:     }
 76:     return res;
 77:   }
 78:   private async assertHotelAccess(hotelId: string, userId: string) {
 79:     const hotel = await this.prisma.hotel.findUnique({
 80:       where: { id: hotelId },
 81:       select: { id: true, ownerId: true },
 82:     });
 83:     if (!hotel) throw new NotFoundException('Hotel not found');
 84:     if (hotel.ownerId === userId) return;
 85:     const member = await this.prisma.hotelMember.findUnique({
 86:       where: { hotelId_userId: { hotelId, userId } },
 87:       select: { userId: true },
 88:     });
 89:     if (!member) throw new ForbiddenException('Forbidden');
 90:   }
 91:   async create(hotelId: string, userId: string, dto: CreateBookingDto) {
 92:     const checkIn = toDateOnly(dto.checkIn);
 93:     const checkOut = toDateOnly(dto.checkOut);
 94:     if (!(checkIn < checkOut)) {
 95:       throw new BadRequestException('checkOut must be after checkIn');
 96:     }
 97:     const nights = eachDateFixed(checkIn, checkOut);
 98:     const nightsCount = nights.length;
 99:     if (nightsCount <= 0) throw new BadRequestException('Invalid date range');
100:     const roomTypeIds = [...new Set(dto.items.map((i) => i.roomTypeId))];
101:     const roomTypes = await this.prisma.roomType.findMany({
102:       where: { id: { in: roomTypeIds }, hotelId },
103:       select: { id: true, name: true, price_per_night: true },
104:     });
105:     if (roomTypes.length !== roomTypeIds.length) {
106:       throw new BadRequestException('Some roomTypeId not belong to this hotel');
107:     }
108:     const priceMap = new Map<string, Prisma.Decimal>(
109:       roomTypes.map((rt) => [rt.id, rt.price_per_night]),
110:     );
111:     const hotelCommission = await this.prisma.hotel.findUnique({
112:       where: { id: hotelId },
113:       select: {
114:         ownerId: true,
115:         commissionPackage: {
116:           select: { commissionRate: true, isActive: true },
117:         },
118:         members: {
119:           select: { userId: true },
120:         },
121:       },
122:     });
123:     const commissionRate = hotelCommission?.commissionPackage?.isActive
124:       ? hotelCommission.commissionPackage.commissionRate
125:       : 0;
126:     if (commissionRate < 0 || commissionRate > 1) {
127:       throw new BadRequestException('Invalid commissionRate on hotel package');
128:     }
129:     const result = await this.prisma.$transaction(async (tx) => {
130:       for (const item of dto.items) {
131:         for (const day of nights) {
132:           const inv = await tx.inventory.findUnique({
133:             where: {
134:               roomTypeId_hotelId_date: {
135:                 roomTypeId: item.roomTypeId,
136:                 hotelId,
137:                 date: day,
138:               },
139:             },
140:             select: { id: true, availableRooms: true, stopSell: true },
141:           });
142:           if (!inv) {
143:             throw new BadRequestException(
144:               `Missing inventory for ${item.roomTypeId} on ${day.toISOString().slice(0, 10)}`,
145:             );
146:           }
147:           if (inv.stopSell) {
148:             throw new BadRequestException(
149:               `StopSell on ${day.toISOString().slice(0, 10)}`,
150:             );
151:           }
152:           if (inv.availableRooms < item.quantity) {
153:             throw new BadRequestException(
154:               `Not enough rooms on ${day.toISOString().slice(0, 10)}`,
155:             );
156:           }
157:         }
158:       }
159:       for (const item of dto.items) {
160:         for (const day of nights) {
161:           const updated = await tx.inventory.updateMany({
162:             where: {
163:               hotelId,
164:               roomTypeId: item.roomTypeId,
165:               date: day,
166:               stopSell: false,
167:               availableRooms: { gte: item.quantity },
168:             },
169:             data: { availableRooms: { decrement: item.quantity } },
170:           });
171:           if (updated.count !== 1) {
172:             throw new BadRequestException(
173:               `Inventory changed, cannot book ${day.toISOString().slice(0, 10)}`,
174:             );
175:           }
176:         }
177:       }
178:       const itemsCreate = dto.items.map((i) => {
179:         const unitPrice = priceMap.get(i.roomTypeId);
180:         if (!unitPrice) {
181:           throw new BadRequestException(
182:             `Missing price for roomTypeId ${i.roomTypeId}`,
183:           );
184:         }
185:         const lineTotal = unitPrice
186:           .mul(new Prisma.Decimal(i.quantity))
187:           .mul(new Prisma.Decimal(nightsCount));
188:         return {
189:           roomTypeId: i.roomTypeId,
190:           quantity: i.quantity,
191:           unitPrice,
192:           lineTotal,
193:         };
194:       });
195:       const totalAmount = itemsCreate.reduce(
196:         (sum, x) => sum.add(x.lineTotal),
197:         new Prisma.Decimal(0),
198:       );
199:       let discountAmount = new Prisma.Decimal(0);
200:       let finalTotal = totalAmount;
201:       let promotionId: string | null = null;
202:       if (dto.promotionCode) {
203:         const promotion = await tx.promotion.findUnique({
204:           where: { code: dto.promotionCode },
205:         });
206:         if (!promotion) {
207:           throw new BadRequestException('Invalid promotion code');
208:         }
209:         if (!promotion.isActive) {
210:           throw new BadRequestException('Promotion is inactive');
211:         }
212:         const now = new Date();
213:         if (now < promotion.startAt || now > promotion.endAt) {
214:           throw new BadRequestException('Promotion is expired or not started');
215:         }
216:         if (promotion.hotelId && promotion.hotelId !== hotelId) {
217:           throw new BadRequestException('Promotion not valid for this hotel');
218:         }
219:         if (
220:           promotion.totalUsageLimit !== null &&
221:           promotion.usedCount >= promotion.totalUsageLimit
222:         ) {
223:           throw new BadRequestException('Promotion usage limit exceeded');
224:         }
225:         if (promotion.perUserLimit !== null) {
226:           if (!userId) {
227:             throw new BadRequestException(
228:               'Login required to use this promotion',
229:             );
230:           }
231:           const userUsage = await tx.booking.count({
232:             where: {
233:               userId,
234:               promotionId: promotion.id,
235:               status: { not: BookingStatus.CANCELLED },
236:             },
237:           });
238:           if (userUsage >= promotion.perUserLimit) {
239:             throw new BadRequestException(
240:               'You have exceeded the usage limit for this promotion',
241:             );
242:           }
243:         }
244:         if (
245:           promotion.minBookingAmount &&
246:           totalAmount.lt(promotion.minBookingAmount)
247:         ) {
248:           throw new BadRequestException(
249:             `Minimum booking amount of ${promotion.minBookingAmount} required`,
250:           );
251:         }
252:         if (promotion.discountType === DiscountType.PERCENT) {
253:           const percent = new Prisma.Decimal(promotion.discountValue).div(100);
254:           let discount = totalAmount.mul(percent);
255:           if (
256:             promotion.maxDiscountAmount &&
257:             discount.gt(promotion.maxDiscountAmount)
258:           ) {
259:             discount = promotion.maxDiscountAmount;
260:           }
261:           discountAmount = discount;
262:         } else {
263:           discountAmount = new Prisma.Decimal(promotion.discountValue);
264:         }
265:         if (discountAmount.gt(totalAmount)) {
266:           discountAmount = totalAmount;
267:         }
268:         finalTotal = totalAmount.sub(discountAmount);
269:         promotionId = promotion.id;
270:         await tx.promotion.update({
271:           where: { id: promotion.id },
272:           data: { usedCount: { increment: 1 } },
273:         });
274:       }
275:       const commissionAmount = finalTotal
276:         .mul(new Prisma.Decimal(commissionRate))
277:         .toDecimalPlaces(0, Prisma.Decimal.ROUND_HALF_UP);
278:       const booking = await tx.booking.create({
279:         data: {
280:           hotelId,
281:           userId,
282:           status: BookingStatus.PENDING,
283:           checkIn,
284:           checkOut,
285:           guestName: dto.guestName,
286:           guestEmail: dto.guestEmail,
287:           guestPhone: dto.guestPhone,
288:           note: dto.note,
289:           totalAmount: finalTotal,
290:           discountAmount,
291:           promotionId,
292:           commissionRateSnapshot: commissionRate,
293:           commissionAmount: Number(commissionAmount.toString()),
294:           items: { create: itemsCreate },
295:         },
296:         include: { items: true },
297:       });
298:       return booking;
299:     });
300:     if (hotelCommission) {
301:       const recipients = new Set<string>();
302:       if (hotelCommission.ownerId) recipients.add(hotelCommission.ownerId);
303:       if (hotelCommission.members) {
304:         hotelCommission.members.forEach((m) => recipients.add(m.userId));
305:       }
306:       await Promise.all(
307:         Array.from(recipients).map((recipientId) =>
308:           this.notificationService.create({
309:             userId: recipientId,
310:             hotelId: hotelId,
311:             bookingId: result.id,
312:             type: NotificationType.NEW_BOOKING,
313:             title: 'New Booking',
314:             message: `You have a new booking from ${dto.guestName}`,
315:             actionUrl: `/admin/bookings/${hotelId}/booking/${result.id}`,
316:           }),
317:         ),
318:       );
319:     }
320:     return result;
321:   }
322:   async cancel(hotelId: string, bookingId: string) {
323:     return this.prisma.$transaction(async (tx) => {
324:       const booking = await tx.booking.findFirst({
325:         where: { id: bookingId, hotelId },
326:         include: { items: true },
327:       });
328:       if (!booking) throw new NotFoundException('Booking not found');
329:       if (booking.status === BookingStatus.CANCELLED) return booking;
330:       const nights = eachDateFixed(booking.checkIn, booking.checkOut);
331:       for (const item of booking.items) {
332:         for (const day of nights) {
333:           await tx.inventory.updateMany({
334:             where: { hotelId, roomTypeId: item.roomTypeId, date: day },
335:             data: { availableRooms: { increment: item.quantity } },
336:           });
337:         }
338:       }
339:       return tx.booking.update({
340:         where: { id: booking.id },
341:         data: { status: BookingStatus.CANCELLED },
342:         include: { items: true },
343:       });
344:     });
