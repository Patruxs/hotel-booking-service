529:         hotel: {
530:           select: {
531:             id: true,
532:             name: true,
533:             address: true,
534:             city: true,
535:             country: true,
536:             images: { take: 1, select: { url: true } },
537:           },
538:         },
539:         items: {
540:           include: {
541:             roomType: {
542:               select: {
543:                 id: true,
544:                 name: true,
545:               },
546:             },
547:           },
548:         },
549:         payments: true,
550:       },
