  1: "use client"
  2: import { useCallback, useEffect, useState } from "react"
  3: import { type Editor } from "@tiptap/react"
  4: import { NodeSelection, TextSelection } from "@tiptap/pm/state"
  5: import { useTiptapEditor } from "@/hooks/use-tiptap-editor"
  6: import { ListIcon } from "@/components/tiptap-icons/list-icon"
  7: import { ListOrderedIcon } from "@/components/tiptap-icons/list-ordered-icon"
  8: import { ListTodoIcon } from "@/components/tiptap-icons/list-todo-icon"
  9: import {
 10:   findNodePosition,
 11:   isNodeInSchema,
 12:   isNodeTypeSelected,
 13:   isValidPosition,
 14:   selectionWithinConvertibleTypes,
 15: } from "@/lib/tiptap-utils"
 16: export type ListType = "bulletList" | "orderedList" | "taskList"
 17: export interface UseListConfig {
 18:   editor?: Editor | null
 19:   type: ListType
 20:   hideWhenUnavailable?: boolean
 21:   onToggled?: () => void
 22: }
 23: export const listIcons = {
 24:   bulletList: ListIcon,
 25:   orderedList: ListOrderedIcon,
 26:   taskList: ListTodoIcon,
 27: }
 28: export const listLabels: Record<ListType, string> = {
 29:   bulletList: "Bullet List",
 30:   orderedList: "Ordered List",
 31:   taskList: "Task List",
 32: }
 33: export const LIST_SHORTCUT_KEYS: Record<ListType, string> = {
 34:   bulletList: "mod+shift+8",
 35:   orderedList: "mod+shift+7",
 36:   taskList: "mod+shift+9",
 37: }
 38: export function canToggleList(
 39:   editor: Editor | null,
 40:   type: ListType,
 41:   turnInto: boolean = true
 42: ): boolean {
 43:   if (!editor || !editor.isEditable) return false
 44:   if (!isNodeInSchema(type, editor) || isNodeTypeSelected(editor, ["image"]))
 45:     return false
 46:   if (!turnInto) {
 47:     switch (type) {
 48:       case "bulletList":
 49:         return editor.can().toggleBulletList()
 50:       case "orderedList":
 51:         return editor.can().toggleOrderedList()
 52:       case "taskList":
 53:         return editor.can().toggleList("taskList", "taskItem")
 54:       default:
 55:         return false
 56:     }
 57:   }
 58:   if (
 59:     !selectionWithinConvertibleTypes(editor, [
 60:       "paragraph",
 61:       "heading",
 62:       "bulletList",
 63:       "orderedList",
 64:       "taskList",
 65:       "blockquote",
 66:       "codeBlock",
 67:     ])
 68:   )
 69:     return false
 70:   switch (type) {
 71:     case "bulletList":
 72:       return editor.can().toggleBulletList() || editor.can().clearNodes()
 73:     case "orderedList":
 74:       return editor.can().toggleOrderedList() || editor.can().clearNodes()
 75:     case "taskList":
 76:       return (
 77:         editor.can().toggleList("taskList", "taskItem") ||
 78:         editor.can().clearNodes()
 79:       )
 80:     default:
 81:       return false
 82:   }
 83: }
 84: export function isListActive(editor: Editor | null, type: ListType): boolean {
 85:   if (!editor || !editor.isEditable) return false
 86:   switch (type) {
 87:     case "bulletList":
 88:       return editor.isActive("bulletList")
 89:     case "orderedList":
 90:       return editor.isActive("orderedList")
 91:     case "taskList":
 92:       return editor.isActive("taskList")
 93:     default:
 94:       return false
 95:   }
 96: }
 97: export function toggleList(editor: Editor | null, type: ListType): boolean {
 98:   if (!editor || !editor.isEditable) return false
 99:   if (!canToggleList(editor, type)) return false
100:   try {
101:     const view = editor.view
102:     let state = view.state
103:     let tr = state.tr
104:     if (state.selection.empty || state.selection instanceof TextSelection) {
105:       const pos = findNodePosition({
106:         editor,
107:         node: state.selection.$anchor.node(1),
108:       })?.pos
109:       if (!isValidPosition(pos)) return false
110:       tr = tr.setSelection(NodeSelection.create(state.doc, pos))
111:       view.dispatch(tr)
112:       state = view.state
113:     }
114:     const selection = state.selection
115:     let chain = editor.chain().focus()
116:     if (selection instanceof NodeSelection) {
117:       const firstChild = selection.node.firstChild?.firstChild
118:       const lastChild = selection.node.lastChild?.lastChild
119:       const from = firstChild
120:         ? selection.from + firstChild.nodeSize
121:         : selection.from + 1
122:       const to = lastChild
123:         ? selection.to - lastChild.nodeSize
124:         : selection.to - 1
125:       const resolvedFrom = state.doc.resolve(from)
126:       const resolvedTo = state.doc.resolve(to)
127:       chain = chain
128:         .setTextSelection(TextSelection.between(resolvedFrom, resolvedTo))
129:         .clearNodes()
130:     }
131:     if (editor.isActive(type)) {
132:       chain
133:         .liftListItem("listItem")
134:         .lift("bulletList")
135:         .lift("orderedList")
136:         .lift("taskList")
137:         .run()
138:     } else {
139:       const toggleMap: Record<ListType, () => typeof chain> = {
140:         bulletList: () => chain.toggleBulletList(),
141:         orderedList: () => chain.toggleOrderedList(),
142:         taskList: () => chain.toggleList("taskList", "taskItem"),
143:       }
144:       const toggle = toggleMap[type]
145:       if (!toggle) return false
146:       toggle().run()
147:     }
148:     editor.chain().focus().selectTextblockEnd().run()
149:     return true
150:   } catch {
151:     return false
152:   }
153: }
154: export function shouldShowButton(props: {
155:   editor: Editor | null
156:   type: ListType
157:   hideWhenUnavailable: boolean
158: }): boolean {
159:   const { editor, type, hideWhenUnavailable } = props
160:   if (!editor || !editor.isEditable) return false
161:   if (!isNodeInSchema(type, editor)) return false
162:   if (hideWhenUnavailable && !editor.isActive("code")) {
163:     return canToggleList(editor, type)
164:   }
165:   return true
166: }
167: export function useList(config: UseListConfig) {
168:   const {
169:     editor: providedEditor,
170:     type,
171:     hideWhenUnavailable = false,
172:     onToggled,
173:   } = config
174:   const { editor } = useTiptapEditor(providedEditor)
175:   const [isVisible, setIsVisible] = useState<boolean>(true)
176:   const canToggle = canToggleList(editor, type)
177:   const isActive = isListActive(editor, type)
178:   useEffect(() => {
179:     if (!editor) return
180:     const handleSelectionUpdate = () => {
181:       setIsVisible(shouldShowButton({ editor, type, hideWhenUnavailable }))
182:     }
183:     handleSelectionUpdate()
184:     editor.on("selectionUpdate", handleSelectionUpdate)
185:     return () => {
186:       editor.off("selectionUpdate", handleSelectionUpdate)
187:     }
188:   }, [editor, type, hideWhenUnavailable])
189:   const handleToggle = useCallback(() => {
190:     if (!editor) return false
191:     const success = toggleList(editor, type)
192:     if (success) {
193:       onToggled?.()
194:     }
195:     return success
196:   }, [editor, type, onToggled])
197:   return {
198:     isVisible,
199:     isActive,
200:     handleToggle,
201:     canToggle,
202:     label: listLabels[type],
203:     shortcutKeys: LIST_SHORTCUT_KEYS[type],
204:     Icon: listIcons[type],
205:   }
206: }
</file>

