14:   const { data: hotel, isLoading, isError } = useHotelDetailQuery(id, isEditing);
15:   const createMutation = useCreateHotelMutation();
16:   const updateMutation = useUpdateHotelMutation(id);
17:   const isSaving = createMutation.isPending || updateMutation.isPending;
18:   if (isLoading && isEditing) {
19:      return <div className="p-6">Loading...</div>;
20:   }
21:   if (isEditing && isError) {
22:     return (
23:       <div className="p-6">
24:         <h1 className="text-2xl font-bold text-red-500">Error loading hotel</h1>
25:         <Button onClick={() => router.push('/admin/hotels')} className="mt-4">
26:           Go Back
27:         </Button>
28:       </div>
29:     );
30:   }
31:   const initialData: HotelFormValues | undefined = hotel
32:     ? {
33:         name: hotel.name,
34:         address: hotel.address,
35:         description: hotel.description,
36:         city: hotel.city,
37:         country: hotel.country,
38:         status: hotel.status,
39:         images: (hotel.images ?? []).map((img: any) => ({
40:           id: img.id ?? img.image_id ?? undefined,
41:           url: img.url,
42:         })),
43:       }
44:     : undefined;
45:   const handleSubmit = async (data: HotelFormValues) => {
46:     const payload = {
47:       ...data,
48:       images: (data.images ?? []).map((x) => ({ id: x.id, url: x.url })),
49:     };
50:     if (isEditing) {
51:       await updateMutation.mutateAsync(payload);
52:     } else {
53:       await createMutation.mutateAsync(payload);
54:     }
55:     router.push('/admin/hotels');
56:   };
57:   return (
58:     <div className="container mx-auto py-6 space-y-8 flex-col">
59:       {}
60:       <div className="flex items-center gap-4">
61:         <Button
62:           variant="ghost"
63:           size="icon"
64:           onClick={() => router.back()}
65:         >
66:           <ArrowLeft className="h-4 w-4" />
67:         </Button>
68:         <h1 className="text-2xl font-bold tracking-tight">
69:           {isEditing ? 'Edit Hotel' : 'Create Hotel'}
70:         </h1>
71:       </div>
72:       {}
73:       <div className="bg-card rounded-lg border p-6 shadow-sm w-full">
74:         <h2 className="text-lg font-semibold mb-4">Hotel Details</h2>
75:         <HotelForm
76:             initialData={initialData}
77:             onSubmit={handleSubmit}
78:             isLoading={isSaving}
79:         />
80:       </div>
81:     </div>
82:   );
83: }
