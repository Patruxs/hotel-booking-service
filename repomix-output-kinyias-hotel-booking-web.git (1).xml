  1: "use client"
  2: import { useEffect, useMemo, useState } from "react"
  3: import type { Editor } from "@tiptap/react"
  4: import { useTiptapEditor } from "@/hooks/use-tiptap-editor"
  5: import { ListIcon } from "@/components/tiptap-icons/list-icon"
  6: import { ListOrderedIcon } from "@/components/tiptap-icons/list-ordered-icon"
  7: import { ListTodoIcon } from "@/components/tiptap-icons/list-todo-icon"
  8: import { isNodeInSchema } from "@/lib/tiptap-utils"
  9: import {
 10:   canToggleList,
 11:   isListActive,
 12:   listIcons,
 13:   type ListType,
 14: } from "@/components/tiptap-ui/list-button"
 15: export interface UseListDropdownMenuConfig {
 16:   editor?: Editor | null
 17:   types?: ListType[]
 18:   hideWhenUnavailable?: boolean
 19: }
 20: export interface ListOption {
 21:   label: string
 22:   type: ListType
 23:   icon: React.ElementType
 24: }
 25: export const listOptions: ListOption[] = [
 26:   {
 27:     label: "Bullet List",
 28:     type: "bulletList",
 29:     icon: ListIcon,
 30:   },
 31:   {
 32:     label: "Ordered List",
 33:     type: "orderedList",
 34:     icon: ListOrderedIcon,
 35:   },
 36:   {
 37:     label: "Task List",
 38:     type: "taskList",
 39:     icon: ListTodoIcon,
 40:   },
 41: ]
 42: export function canToggleAnyList(
 43:   editor: Editor | null,
 44:   listTypes: ListType[]
 45: ): boolean {
 46:   if (!editor || !editor.isEditable) return false
 47:   return listTypes.some((type) => canToggleList(editor, type))
 48: }
 49: export function isAnyListActive(
 50:   editor: Editor | null,
 51:   listTypes: ListType[]
 52: ): boolean {
 53:   if (!editor || !editor.isEditable) return false
 54:   return listTypes.some((type) => isListActive(editor, type))
 55: }
 56: export function getFilteredListOptions(
 57:   availableTypes: ListType[]
 58: ): typeof listOptions {
 59:   return listOptions.filter(
 60:     (option) => !option.type || availableTypes.includes(option.type)
 61:   )
 62: }
 63: export function shouldShowListDropdown(params: {
 64:   editor: Editor | null
 65:   listTypes: ListType[]
 66:   hideWhenUnavailable: boolean
 67:   listInSchema: boolean
 68:   canToggleAny: boolean
 69: }): boolean {
 70:   const { editor, hideWhenUnavailable, listInSchema, canToggleAny } = params
 71:   if (!listInSchema || !editor) {
 72:     return false
 73:   }
 74:   if (hideWhenUnavailable && !editor.isActive("code")) {
 75:     return canToggleAny
 76:   }
 77:   return true
 78: }
 79: export function getActiveListType(
 80:   editor: Editor | null,
 81:   availableTypes: ListType[]
 82: ): ListType | undefined {
 83:   if (!editor || !editor.isEditable) return undefined
 84:   return availableTypes.find((type) => isListActive(editor, type))
 85: }
 86: export function useListDropdownMenu(config?: UseListDropdownMenuConfig) {
 87:   const {
 88:     editor: providedEditor,
 89:     types = ["bulletList", "orderedList", "taskList"],
 90:     hideWhenUnavailable = false,
 91:   } = config || {}
 92:   const { editor } = useTiptapEditor(providedEditor)
 93:   const [isVisible, setIsVisible] = useState(true)
 94:   const listInSchema = types.some((type) => isNodeInSchema(type, editor))
 95:   const filteredLists = useMemo(() => getFilteredListOptions(types), [types])
 96:   const canToggleAny = canToggleAnyList(editor, types)
 97:   const isAnyActive = isAnyListActive(editor, types)
 98:   const activeType = getActiveListType(editor, types)
 99:   const activeList = filteredLists.find((option) => option.type === activeType)
100:   useEffect(() => {
101:     if (!editor) return
102:     const handleSelectionUpdate = () => {
103:       setIsVisible(
104:         shouldShowListDropdown({
105:           editor,
106:           listTypes: types,
107:           hideWhenUnavailable,
108:           listInSchema,
109:           canToggleAny,
110:         })
111:       )
112:     }
113:     handleSelectionUpdate()
114:     editor.on("selectionUpdate", handleSelectionUpdate)
115:     return () => {
116:       editor.off("selectionUpdate", handleSelectionUpdate)
117:     }
118:   }, [canToggleAny, editor, hideWhenUnavailable, listInSchema, types])
119:   return {
120:     isVisible,
121:     activeType,
122:     isActive: isAnyActive,
123:     canToggle: canToggleAny,
124:     types,
125:     filteredLists,
126:     label: "List",
127:     Icon: activeList ? listIcons[activeList.type] : ListIcon,
128:   }
129: }
