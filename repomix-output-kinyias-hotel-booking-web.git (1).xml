  6: import { cn } from '@/lib/utils';
  7: interface ImageUploadProps {
  8:   value: { url: string }[];
  9:   onChange: (value: { url: string }[]) => void;
 10:   onRemove: (url: string) => void;
 11:   disabled?: boolean;
 12: }
 13: export default function ImageUpload({
 14:   value,
 15:   onChange,
 16:   onRemove,
 17:   disabled,
 18: }: ImageUploadProps) {
 19:   const [dragActive, setDragActive] = useState(false);
 20:   const inputRef = useRef<HTMLInputElement>(null);
 21:   const replacingIndexRef = useRef<number | null>(null);
 22:   const replaceInputRef = useRef<HTMLInputElement>(null);
 23:   const handleDrag = (e: React.DragEvent) => {
 24:     e.preventDefault();
 25:     e.stopPropagation();
 26:     if (e.type === 'dragenter' || e.type === 'dragover') {
 27:       setDragActive(true);
 28:     } else if (e.type === 'dragleave') {
 29:       setDragActive(false);
 30:     }
 31:   };
 32:   const handleDrop = (e: React.DragEvent) => {
 33:     e.preventDefault();
 34:     e.stopPropagation();
 35:     setDragActive(false);
 36:     if (e.dataTransfer.files && e.dataTransfer.files[0]) {
 37:       handleFiles(Array.from(e.dataTransfer.files));
 38:     }
 39:   };
 40:   const handleChange = (e: ChangeEvent<HTMLInputElement>) => {
 41:     e.preventDefault();
 42:     if (e.target.files && e.target.files[0]) {
 43:       handleFiles(Array.from(e.target.files));
 44:     }
 45:     if (e.target) {
 46:         e.target.value = '';
 47:     }
 48:   };
 49:   const handleReplaceChange = (e: ChangeEvent<HTMLInputElement>) => {
 50:     e.preventDefault();
 51:     const index = replacingIndexRef.current;
 52:     if (e.target.files && e.target.files[0] && index !== null) {
 53:       const file = e.target.files[0];
 54:       const newImage = {
 55:         url: URL.createObjectURL(file),
 56:         file,
 57:       };
 58:       const updatedValues = [...value];
 59:       updatedValues[index] = newImage;
 60:       onChange(updatedValues);
 61:       replacingIndexRef.current = null;
 62:     }
 63:      // Reset input value
 64:      if (e.target) {
 65:         e.target.value = '';
 66:     }
 67:   };
 68:   const handleFiles = (files: File[]) => {
 69:     // In a real app, we would upload these files to a server here.
 70:     // For this demo, we'll create object URLs.
 71:     const newImages = files.map((file) => ({
 72:       url: URL.createObjectURL(file),
 73:       file,
 74:     }));
 75:     onChange([...value, ...newImages]);
 76:   };
 77:   const onButtonClick = () => {
 78:     console.log('Button clicked');
 79:     inputRef.current?.click();
 80:   };
 81:   const onReplaceClick = (e: React.MouseEvent, index: number) => {
 82:       e.stopPropagation();
 83:       console.log('Replace clicked');
 84:       replacingIndexRef.current = index;
 85:       replaceInputRef.current?.click();
 86:   };
 87:   return (
 88:     <div className="space-y-4">
 89:       <div
 90:         className={cn(
 91:           'relative flex flex-col items-center justify-center w-full h-32 rounded-lg border-2 border-dashed transition-colors cursor-pointer',
 92:           dragActive
 93:             ? 'border-primary bg-primary/10'
 94:             : 'border-border bg-card hover:bg-muted/50',
 95:           disabled && 'opacity-50 cursor-not-allowed'
 96:         )}
 97:         onDragEnter={handleDrag}
 98:         onDragLeave={handleDrag}
 99:         onDragOver={handleDrag}
100:         onDrop={handleDrop}
101:         onClick={onButtonClick}
102:       >
103:         <input
104:           ref={inputRef}
105:           type="file"
106:           className="hidden"
107:           multiple
108:           accept="image/*"
109:           onChange={handleChange}
110:           disabled={disabled}
111:         />
112:         <div className="flex flex-col items-center justify-center pt-5 pb-6 text-center">
113:             <Upload className="w-8 h-8 mb-2 text-muted-foreground" />
114:             <p className="mb-2 text-sm text-muted-foreground">
115:             <span className="font-semibold">
116:                 Click to upload
117:             </span>{' '}
118:             or drag and drop
119:             </p>
120:             <p className="text-xs text-muted-foreground">
121:             SVG, PNG, JPG or GIF (max. 5MB)
122:             </p>
123:         </div>
124:       </div>
125:       {value.length > 0 && (
126:         <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
127:         <input
128:           ref={replaceInputRef}
129:           type="file"
130:           className="hidden"
131:           accept="image/*"
132:           onChange={handleReplaceChange}
133:           disabled={disabled}
134:         />
135:           {value.map((image, index) => (
136:             <div
137:               key={index}
138:               className="relative aspect-square rounded-md overflow-hidden border border-border group"
139:             >
140:               <div className="absolute top-2 right-2 z-10 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
141:                 <Button
142:                   type="button"
143:                   onClick={(e) => onReplaceClick(e, index)}
144:                   variant="secondary"
145:                   size="icon"
146:                   className="h-6 w-6 rounded-full bg-white/80 hover:bg-white text-gray-700"
147:                   title="Replace"
148:                 >
149:                   <Upload className="h-3 w-3" />
150:                 </Button>
151:                 <Button
152:                   type="button"
153:                   onClick={(e) => {
154:                       e.stopPropagation();
155:                       onRemove(image.url);
156:                   }}
157:                   variant="destructive"
158:                   size="icon"
159:                   className="h-6 w-6 rounded-full"
160:                   title="Remove"
161:                 >
162:                   <X className="h-3 w-3" />
163:                 </Button>
164:               </div>
165:               <Image
166:                 fill
167:                 src={image.url}
168:                 alt="Room Image"
169:                 className="object-cover"
170:               />
171:             </div>
172:           ))}
173:         </div>
174:       )}
175:     </div>
176:   );
177: }
