<file path="apps/web/src/providers/PermissionProvider.tsx">
 1: 'use client';import React, { createContext, useContext, useMemo } from "react";
 2: import { useAuth } from "./AuthProvider";
 3: type PermissionContextType = {
 4:   actions: Set<string>;
 5:   can: (action: string) => boolean;
 6:   canAny: (actions: string[]) => boolean;
 7:   canAll: (actions: string[]) => boolean;
 8: };
 9: const PermissionContext = createContext<PermissionContextType | null>(null);
10: export const PermissionProvider = ({ children }: { children: React.ReactNode }) => {
11:   const { loading, user } = useAuth();
12:   const actionsSet = useMemo(() => {
13:     if (!user) return new Set<string>();
14:     return new Set(user.allowedActions || []);
15:   }, [user]);
16:   const value = useMemo<PermissionContextType>(() => {
17:     return {
18:       actions: actionsSet,
19:       can: (action: string) => actionsSet.has(action),
20:       canAny: (actions: string[]) =>
21:         actions.some((a) => actionsSet.has(a)),
22:       canAll: (actions: string[]) =>
23:         actions.every((a) => actionsSet.has(a)),
24:     };
25:   }, [actionsSet]);
26:   if (loading) return null;
27:   return (
28:     <PermissionContext.Provider value={value}>
29:       {children}
30:     </PermissionContext.Provider>
31:   );
32: };
33: export function usePermission() {
34:   const ctx = useContext(PermissionContext);
35:   if (!ctx) {
36:     throw new Error("usePermission must be used inside PermissionProvider");
37:   }
38:   return ctx;
39: }
</file>

