<file path="apps/web/src/hooks/use-composed-ref.ts">
 1: "use client"
 2: import { useCallback, useRef } from "react"
 3: type UserRef<T> =
 4:   | ((instance: T | null) => void)
 5:   | React.RefObject<T | null>
 6:   | null
 7:   | undefined
 8: const updateRef = <T>(ref: NonNullable<UserRef<T>>, value: T | null) => {
 9:   if (typeof ref === "function") {
10:     ref(value)
11:   } else if (ref && typeof ref === "object" && "current" in ref) {
12:     ;(ref as { current: T | null }).current = value
13:   }
14: }
15: export const useComposedRef = <T extends HTMLElement>(
16:   libRef: React.RefObject<T | null>,
17:   userRef: UserRef<T>
18: ) => {
19:   const prevUserRef = useRef<UserRef<T>>(null)
20:   return useCallback(
21:     (instance: T | null) => {
22:       if (libRef && "current" in libRef) {
23:         ;(libRef as { current: T | null }).current = instance
24:       }
25:       if (prevUserRef.current) {
26:         updateRef(prevUserRef.current, null)
27:       }
28:       prevUserRef.current = userRef
29:       if (userRef) {
30:         updateRef(userRef, instance)
31:       }
32:     },
33:     [libRef, userRef]
34:   )
35: }
36: export default useComposedRef
</file>

<file path="apps/web/src/hooks/use-cursor-visibility.ts">
 1: "use client"
 2: import type { Editor } from "@tiptap/react"
 3: import { useWindowSize } from "@/hooks/use-window-size"
 4: import { useBodyRect } from "@/hooks/use-element-rect"
 5: import { useEffect } from "react"
 6: export interface CursorVisibilityOptions {
 7:   editor?: Editor | null
 8:   overlayHeight?: number
 9: }
10: export function useCursorVisibility({
11:   editor,
12:   overlayHeight = 0,
13: }: CursorVisibilityOptions) {
14:   const { height: windowHeight } = useWindowSize()
15:   const rect = useBodyRect({
16:     enabled: true,
17:     throttleMs: 100,
18:     useResizeObserver: true,
19:   })
20:   useEffect(() => {
21:     const ensureCursorVisibility = () => {
22:       if (!editor) return
23:       const { state, view } = editor
24:       if (!view.hasFocus()) return
25:       const { from } = state.selection
26:       const cursorCoords = view.coordsAtPos(from)
27:       if (windowHeight < rect.height && cursorCoords) {
28:         const availableSpace = windowHeight - cursorCoords.top
29:         if (availableSpace < overlayHeight) {
30:           const targetCursorY = Math.max(windowHeight / 2, overlayHeight)
31:           const currentScrollY = window.scrollY
32:           const cursorAbsoluteY = cursorCoords.top + currentScrollY
33:           const newScrollY = cursorAbsoluteY - targetCursorY
34:           window.scrollTo({
35:             top: Math.max(0, newScrollY),
36:             behavior: "smooth",
37:           })
38:         }
39:       }
40:     }
41:     ensureCursorVisibility()
42:   }, [editor, overlayHeight, windowHeight, rect.height])
43:   return rect
44: }
</file>

<file path="apps/web/src/hooks/use-element-rect.ts">
  1: "use client"
  2: import { useCallback, useEffect, useState } from "react"
  3: import { useThrottledCallback } from "@/hooks/use-throttled-callback"
  4: export type RectState = Omit<DOMRect, "toJSON">
  5: export interface ElementRectOptions {
  6:   element?: Element | React.RefObject<Element> | string | null
  7:   enabled?: boolean
  8:   throttleMs?: number
  9:   useResizeObserver?: boolean
 10: }
 11: const initialRect: RectState = {
 12:   x: 0,
 13:   y: 0,
 14:   width: 0,
 15:   height: 0,
 16:   top: 0,
 17:   right: 0,
 18:   bottom: 0,
 19:   left: 0,
 20: }
 21: const isSSR = typeof window === "undefined"
 22: const hasResizeObserver = !isSSR && typeof ResizeObserver !== "undefined"
 23: const isClientSide = (): boolean => !isSSR
 24: export function useElementRect({
 25:   element,
 26:   enabled = true,
 27:   throttleMs = 100,
 28:   useResizeObserver = true,
 29: }: ElementRectOptions = {}): RectState {
 30:   const [rect, setRect] = useState<RectState>(initialRect)
 31:   const getTargetElement = useCallback((): Element | null => {
 32:     if (!enabled || !isClientSide()) return null
 33:     if (!element) {
 34:       return document.body
 35:     }
 36:     if (typeof element === "string") {
 37:       return document.querySelector(element)
 38:     }
 39:     if ("current" in element) {
 40:       return element.current
 41:     }
 42:     return element
 43:   }, [element, enabled])
 44:   const updateRect = useThrottledCallback(
 45:     () => {
 46:       if (!enabled || !isClientSide()) return
 47:       const targetElement = getTargetElement()
 48:       if (!targetElement) {
 49:         setRect(initialRect)
 50:         return
 51:       }
 52:       const newRect = targetElement.getBoundingClientRect()
 53:       setRect({
 54:         x: newRect.x,
 55:         y: newRect.y,
 56:         width: newRect.width,
 57:         height: newRect.height,
 58:         top: newRect.top,
 59:         right: newRect.right,
 60:         bottom: newRect.bottom,
 61:         left: newRect.left,
 62:       })
 63:     },
 64:     throttleMs,
 65:     [enabled, getTargetElement],
 66:     { leading: true, trailing: true }
 67:   )
 68:   useEffect(() => {
 69:     if (!enabled || !isClientSide()) {
 70:       setRect(initialRect)
 71:       return
 72:     }
 73:     const targetElement = getTargetElement()
 74:     if (!targetElement) return
 75:     updateRect()
 76:     const cleanup: (() => void)[] = []
 77:     if (useResizeObserver && hasResizeObserver) {
 78:       const resizeObserver = new ResizeObserver(() => {
 79:         window.requestAnimationFrame(updateRect)
 80:       })
 81:       resizeObserver.observe(targetElement)
 82:       cleanup.push(() => resizeObserver.disconnect())
 83:     }
 84:     const handleUpdate = () => updateRect()
 85:     window.addEventListener("scroll", handleUpdate, true)
 86:     window.addEventListener("resize", handleUpdate, true)
 87:     cleanup.push(() => {
 88:       window.removeEventListener("scroll", handleUpdate)
 89:       window.removeEventListener("resize", handleUpdate)
 90:     })
 91:     return () => {
 92:       cleanup.forEach((fn) => fn())
 93:       setRect(initialRect)
 94:     }
 95:   }, [enabled, getTargetElement, updateRect, useResizeObserver])
 96:   return rect
 97: }
 98: export function useBodyRect(
 99:   options: Omit<ElementRectOptions, "element"> = {}
100: ): RectState {
101:   return useElementRect({
102:     ...options,
103:     element: isClientSide() ? document.body : null,
104:   })
105: }
106: export function useRefRect<T extends Element>(
107:   ref: React.RefObject<T>,
108:   options: Omit<ElementRectOptions, "element"> = {}
109: ): RectState {
110:   return useElementRect({ ...options, element: ref })
111: }
</file>

