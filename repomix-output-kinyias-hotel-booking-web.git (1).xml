21:   async findAllByUser(userId: string, page = 1, limit = 10) {
22:     const offset = (page - 1) * limit;
23:     const [total, items] = await this.prisma.$transaction([
24:       this.prisma.notification.count({ where: { userId } }),
25:       this.prisma.notification.findMany({
26:         where: { userId },
27:         skip: offset,
28:         take: Number(limit),
29:         orderBy: { createdAt: 'desc' },
30:       }),
31:     ]);
32:     return {
33:       data: items,
34:       meta: {
35:         total,
36:         page,
37:         limit,
38:         totalPages: Math.ceil(total / limit),
39:       },
40:     };
41:   }
