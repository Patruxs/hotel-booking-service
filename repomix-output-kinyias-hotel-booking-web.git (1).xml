 1: import { z } from "zod";
 2: export const BulkSetInventorySchema = z
 3:   .object({
 4:     from: z
 5:       .string()
 6:       .regex(/^\d{4}-\d{2}-\d{2}$/, "from must be YYYY-MM-DD"),
 7:     to: z
 8:       .string()
 9:       .regex(/^\d{4}-\d{2}-\d{2}$/, "to must be YYYY-MM-DD"),
10:     roomTypeId: z.string().min(1),
11:     totalRooms: z
12:       .number()
13:       .int()
14:       .min(0)
15:       .optional(),
16:     availableRooms: z
17:       .number()
18:       .int()
19:       .min(0)
20:       .optional(),
21:     stopSell: z.boolean().optional(),
22:   })
23:   .refine(
24:     (data) => data.totalRooms === undefined || data.availableRooms === undefined
25:       ? true
26:       : data.availableRooms <= data.totalRooms,
27:     {
28:       message: "availableRooms must be <= totalRooms",
29:       path: ["availableRooms"],
30:     }
31:   );
32: export const UpdateInventorySchema = z
33:   .object({
34:     totalRooms: z
35:       .number()
36:       .int()
37:       .min(0)
38:       .optional(),
39:     availableRooms: z
40:       .number()
41:       .int()
42:       .min(0)
43:       .optional(),
44:     stopSell: z.boolean().optional(),
45:   })
46:   .refine(
47:     (data) =>
48:       data.totalRooms === undefined ||
49:       data.availableRooms === undefined ||
50:       data.availableRooms <= data.totalRooms,
51:     {
52:       message: "availableRooms must be <= totalRooms",
53:       path: ["availableRooms"],
54:     }
55:   );
