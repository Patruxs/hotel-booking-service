 1: import { Injectable, Inject } from '@nestjs/common';
 2: import { Readable } from 'stream';
 3: import { v2 as Cloudinary } from 'cloudinary';
 4: import { PrismaService } from '../../../modules/prisma/prisma.service';
 5: @Injectable()
 6: export class UserAvatarService {
 7:   constructor(
 8:     private prisma: PrismaService,
 9:     @Inject('CLOUDINARY') private readonly cloudinary: typeof Cloudinary,
10:   ) {}
11:   async setAvatar(userId: string, file: Express.Multer.File) {
12:     const uploaded = await new Promise<any>((resolve, reject) => {
13:       const stream = this.cloudinary.uploader.upload_stream(
14:         { folder: `stayra/avatars/${userId}` },
15:         (error, result) => (error ? reject(error) : resolve(result)),
16:       );
17:       Readable.from(file.buffer).pipe(stream);
18:     });
19:     const current = await this.prisma.user.findUnique({
20:       where: { id: userId },
21:       select: { avatarId: true, avatar: { select: { publicId: true } } },
22:     });
23:     if (current?.avatarId && current.avatar?.publicId) {
24:       await this.cloudinary.uploader
25:         .destroy(current.avatar.publicId)
26:         .catch(() => {});
27:       await this.prisma.imageAsset
28:         .delete({ where: { id: current.avatarId } })
29:         .catch(() => {});
30:     }
31:     const image = await this.prisma.imageAsset.create({
32:       data: {
33:         publicId: uploaded.public_id,
34:         url: uploaded.url,
35:         secureUrl: uploaded.secure_url,
36:       },
37:     });
38:     await this.prisma.user.update({
39:       where: { id: userId },
40:       data: { avatarId: image.id },
41:     });
42:     return image;
43:   }
44:   async removeAvatar(userId: string) {
45:     const user = await this.prisma.user.findUnique({
46:       where: { id: userId },
47:       select: { avatarId: true, avatar: { select: { publicId: true } } },
48:     });
49:     if (!user?.avatarId) return;
50:     if (user.avatar?.publicId) {
51:       await this.cloudinary.uploader
52:         .destroy(user.avatar.publicId)
53:         .catch(() => {});
54:     }
55:     await this.prisma.user.update({
56:       where: { id: userId },
57:       data: { avatarId: null },
58:     });
59:     await this.prisma.imageAsset
60:       .delete({ where: { id: user.avatarId } })
61:       .catch(() => {});
62:   }
63: }
