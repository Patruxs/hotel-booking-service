468:   private assertTransition(from: BookingStatus, to: BookingStatus) {
469:     const terminal = new Set<BookingStatus>([
470:       BookingStatus.CANCELLED,
471:       BookingStatus.NO_SHOW,
472:       BookingStatus.COMPLETED,
473:     ]);
474:     if (terminal.has(from)) {
475:       throw new BadRequestException(`Booking is ${from}, cannot change status`);
476:     }
477:     const allowed: Record<BookingStatus, BookingStatus[]> = {
478:       [BookingStatus.PENDING]: [
479:         BookingStatus.CONFIRMED,
480:         BookingStatus.CANCELLED,
481:       ],
482:       [BookingStatus.CONFIRMED]: [
483:         BookingStatus.CANCELLED,
484:         BookingStatus.CHECKED_IN,
485:         BookingStatus.NO_SHOW,
486:       ],
487:       [BookingStatus.CHECKED_IN]: [BookingStatus.COMPLETED],
488:       [BookingStatus.CANCELLED]: [],
489:       [BookingStatus.NO_SHOW]: [],
490:       [BookingStatus.COMPLETED]: [],
491:     };
492:     if (!allowed[from]?.includes(to)) {
493:       throw new BadRequestException(`Invalid transition: ${from} -> ${to}`);
494:     }
495:   }
496:   async updateStatus(
497:     hotelId: string,
498:     userId: string,
499:     bookingId: string,
500:     dto: UpdateBookingStatusDto,
501:   ) {
502:     await this.assertHotelAccess(hotelId, userId);
503:     const booking = await this.prisma.booking.findFirst({
504:       where: { id: bookingId, hotelId },
505:       select: { id: true, status: true },
506:     });
507:     if (!booking) throw new NotFoundException('Booking not found');
508:     if (booking.status === dto.status) {
509:       return this.prisma.booking.findUnique({
510:         where: { id: bookingId },
511:         include: { items: true, payments: true },
512:       });
513:     }
514:     this.assertTransition(booking.status, dto.status);
515:     return this.prisma.booking.update({
516:       where: { id: bookingId },
517:       data: { status: dto.status },
518:       include: {
519:         items: true,
520:         payments: true,
521:         hotel: { select: { id: true, name: true } },
522:       },
523:     });
524:   }
