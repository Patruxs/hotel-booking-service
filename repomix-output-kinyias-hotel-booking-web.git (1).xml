110:                             selectedIcon={field.value}
111:                         />
112:                     </div>
113:                 </FormControl>
114:                 <FormMessage />
115:               </FormItem>
116:             )}
117:           />
118:         </form>
119:       </Form>
120:     </div>
121:   );
