  1: import {
  2:   BadRequestException,
  3:   Injectable,
  4:   NotFoundException,
  5: } from '@nestjs/common';
  6: import { PrismaService } from '../prisma/prisma.service';
  7: import { CreateContactDto } from './dto/create-contact.dto';
  8: import { ListContactDto } from './dto/list-contact.dto';
  9: import { UpdateContactDto } from './dto/update-contact.dto';
 10: import { Prisma, NotificationType } from '@prisma/client';
 11: import { MailService } from '../mail/mail.service';
 12: import { NotificationService } from '../notification/notification.service';
 13: @Injectable()
 14: export class ContactService {
 15:   constructor(
 16:     private readonly prisma: PrismaService,
 17:     private readonly mail: MailService,
 18:     private readonly notificationService: NotificationService,
 19:   ) {}
 20:   async create(
 21:     dto: CreateContactDto,
 22:     meta: { ip?: string; userAgent?: string },
 23:   ) {
 24:     if (!dto.email && !dto.phone) {
 25:       throw new BadRequestException(
 26:         'Vui lòng để lại email hoặc số điện thoại để chúng tôi liên hệ lại.',
 27:       );
 28:     }
 29:     const row = await this.prisma.contactMessage.create({
 30:       data: {
 31:         name: dto.name,
 32:         email: dto.email ?? null,
 33:         phone: dto.phone ?? null,
 34:         subject: dto.subject ?? null,
 35:         message: dto.message,
 36:         ip: meta.ip ?? null,
 37:         userAgent: meta.userAgent ?? null,
 38:       },
 39:     });
 40:     await this.mail.sendContactNotification({
 41:       id: row.id,
 42:       name: row.name,
 43:       email: row.email ?? undefined,
 44:       phone: row.phone ?? undefined,
 45:       subject: row.subject ?? undefined,
 46:       message: row.message,
 47:       createdAt: row.createdAt,
 48:     });
 49:     const recipients = await this.prisma.user.findMany({
 50:       where: {
 51:         roles: {
 52:           some: {
 53:             role: {
 54:               name: { in: ['ADMIN', 'OWNER', 'STAFF'] },
 55:             },
 56:           },
 57:         },
 58:       },
 59:       select: { id: true },
 60:     });
 61:     await Promise.all(
 62:       recipients.map((user) =>
 63:         this.notificationService.create({
 64:           userId: user.id,
 65:           type: NotificationType.SYSTEM,
 66:           title: 'New Contact Message',
 67:           message: `New contact message from ${dto.name}`,
 68:           actionUrl: `/admin/contacts/${row.id}`,
 69:         }),
 70:       ),
 71:     );
 72:     return { id: row.id, ok: true };
 73:   }
 74:   async list(q: ListContactDto) {
 75:     const limit = q.limit ?? 20;
 76:     const page = q.page ?? 1;
 77:     const offset = (page - 1) * limit;
 78:     const where: Prisma.ContactMessageWhereInput = {
 79:       ...(q.status ? { status: q.status as any } : {}),
 80:       ...(q.q
 81:         ? {
 82:             OR: [
 83:               { name: { contains: q.q, mode: 'insensitive' } },
 84:               { email: { contains: q.q, mode: 'insensitive' } },
 85:               { phone: { contains: q.q, mode: 'insensitive' } },
 86:               { subject: { contains: q.q, mode: 'insensitive' } },
 87:               { message: { contains: q.q, mode: 'insensitive' } },
 88:             ],
 89:           }
 90:         : {}),
 91:     };
 92:     const [data, total] = await this.prisma.$transaction([
 93:       this.prisma.contactMessage.findMany({
 94:         where,
 95:         take: limit,
 96:         skip: offset,
 97:         include: {
 98:           handledBy: {select: {id: true, email: true}},
 99:         },
100:         orderBy: { createdAt: 'desc' },
101:       }),
102:       this.prisma.contactMessage.count({ where }),
103:     ]);
104:     return {
105:       data,
106:       meta: {
107:         limit,
108:         offset,
109:         total,
110:       },
111:     };
112:   }
113:   async get(id: string) {
114:     const row = await this.prisma.contactMessage.findUnique({ where: { id } });
115:     if (!row) throw new NotFoundException('Contact not found');
116:     return row;
117:   }
118:   async update(id: string, dto: UpdateContactDto) {
119:     const exists = await this.prisma.contactMessage.findUnique({
120:       where: { id },
121:       select: { id: true },
122:     });
123:     if (!exists) throw new NotFoundException('Contact not found');
124:     return this.prisma.contactMessage.update({
125:       where: { id },
126:       data: {
127:         status: dto.status as any,
128:         handledById: dto.handledById ?? undefined,
129:         note: dto.note ?? undefined,
130:       },
131:     });
132:   }
133: }
