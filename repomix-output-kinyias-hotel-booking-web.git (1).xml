251:       if (q) {
252:         andWhere.push({
253:           OR: [
254:             { name: { contains: q, mode: 'insensitive' } },
255:             { address: { contains: q, mode: 'insensitive' } },
256:             { city: { contains: q, mode: 'insensitive' } },
257:             { country: { contains: q, mode: 'insensitive' } },
258:           ],
259:         });
260:       }
261:     }
262:     const where: Prisma.HotelWhereInput =
263:       andWhere.length > 0 ? { AND: andWhere } : {};
264:     const [total, items] = await this.prisma.$transaction([
265:       this.prisma.hotel.count({ where }),
266:       this.prisma.hotel.findMany({
267:         where,
268:         skip: offset,
269:         take: limit,
270:         orderBy: { createdAt: 'desc' },
271:         include: {
272:           images: true,
273:           owner: {
274:             select: {
275:               id: true,
276:               email: true,
277:               firstName: true,
278:               lastName: true,
279:             },
280:           },
281:           commissionPackage: true,
282:           _count: { select: { members: true } },
283:         },
284:       }),
285:     ]);
286:     return {
287:       data: items,
288:       meta: {
289:         limit,
290:         offset,
291:         total,
292:       },
293:     };
294:   }
295:   async listPublicHotels(query: ListHotelsQueryDto) {
