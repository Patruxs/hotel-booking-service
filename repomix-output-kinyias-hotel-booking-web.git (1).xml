297:     const limit = query.limit ?? 20;
298:     const offset = (page - 1) * limit;
299:     const andWhere: Prisma.HotelWhereInput[] = [];
300:     andWhere.push({ deletedAt: null });
301:     andWhere.push({
302:       roomTypes: {
303:         some: {
304:           deletedAt: null,
305:         },
306:       },
307:     });
308:     andWhere.push({ status: 'ACTIVE' });
309:     if (query.minPrice !== undefined || query.maxPrice !== undefined) {
310:       if (query.minPrice !== undefined && query.maxPrice !== undefined) {
311:         andWhere.push({
312:           roomTypes: {
313:             some: {
314:               deletedAt: null,
315:               price_per_night: {
316:                 gte: query.minPrice,
317:                 lte: query.maxPrice,
318:               },
319:             },
320:           },
321:         });
322:       } else if (query.minPrice !== undefined) {
323:         andWhere.push({
324:           roomTypes: {
325:             some: {
326:               deletedAt: null,
327:               price_per_night: {
328:                 gte: query.minPrice,
329:               },
330:             },
331:           },
332:         });
333:       } else if (query.maxPrice !== undefined) {
334:         andWhere.push({
335:           roomTypes: {
336:             some: {
337:               deletedAt: null,
338:               price_per_night: {
339:                 lte: query.maxPrice,
340:               },
341:             },
342:           },
343:         });
344:       }
345:     }
346:     if (query.checkIn && query.checkOut) {
347:       const dates: Date[] = [];
348:       const currentDate = new Date(query.checkIn);
349:       const endDate = new Date(query.checkOut);
350:       while (currentDate < endDate) {
351:         dates.push(new Date(currentDate));
352:         currentDate.setDate(currentDate.getDate() + 1);
353:       }
354:       andWhere.push({
355:         inventories: {
356:           some: {
357:             date: {
358:               in: dates,
359:             },
360:             availableRooms: {
361:               gt: 0,
362:             },
363:             stopSell: false,
364:             deletedAt: null,
365:           },
366:         },
367:       });
368:     }
369:     if (query.city) {
370:       andWhere.push({
371:         OR: [
372:           { city: { contains: query.city, mode: 'insensitive' } },
373:           { address: { contains: query.city, mode: 'insensitive' } },
374:         ],
375:       });
376:     }
377:     if (query.q) {
378:       const q = query.q.trim();
379:       if (q) {
380:         andWhere.push({
381:           OR: [
382:             { name: { contains: q, mode: 'insensitive' } },
383:             { address: { contains: q, mode: 'insensitive' } },
384:             { city: { contains: q, mode: 'insensitive' } },
385:             { country: { contains: q, mode: 'insensitive' } },
386:           ],
387:         });
388:       }
389:     }
390:     if (query.sortBy === 'price_asc' || query.sortBy === 'price_desc') {
391:       const allMatchingHotels = await this.prisma.hotel.findMany({
392:         where: { AND: andWhere },
393:         select: {
394:           id: true,
395:           roomTypes: {
396:             where: { deletedAt: null },
397:             select: { price_per_night: true },
398:           },
399:         },
400:       });
401:       const hotelsWithPrice = allMatchingHotels.map((h) => {
402:         const prices = h.roomTypes.map((rt) => Number(rt.price_per_night));
403:         const minPrice = prices.length > 0 ? Math.min(...prices) : Infinity;
404:         return { id: h.id, minPrice };
405:       });
406:       hotelsWithPrice.sort((a, b) => {
407:         if (query.sortBy === 'price_asc') {
408:           return a.minPrice - b.minPrice;
409:         } else {
410:           return b.minPrice - a.minPrice;
411:         }
412:       });
413:       const total = hotelsWithPrice.length;
414:       const sliced = hotelsWithPrice.slice(offset, offset + limit);
415:       const slicedIds = sliced.map((h) => h.id);
416:       const items = await this.prisma.hotel.findMany({
417:         where: { id: { in: slicedIds } },
418:         include: {
419:           images: true,
420:           roomTypes: {
421:             where: { deletedAt: null },
422:             select: { price_per_night: true },
423:           },
424:         },
425:       });
426:       const data = sliced.map((item) => {
427:         const hotel = items.find((i) => i.id === item.id);
428:         if (!hotel) return null;
429:         return {
430:           ...hotel,
431:           minPrice: item.minPrice === Infinity ? null : item.minPrice,
432:           roomTypes: undefined,
433:         };
434:       }).filter(Boolean);
435:       return {
436:         data,
437:         meta: {
438:           limit,
439:           offset,
440:           total,
441:         },
442:       };
443:     } else {
444:       const where: Prisma.HotelWhereInput = { AND: andWhere };
445:       const [total, items] = await this.prisma.$transaction([
446:         this.prisma.hotel.count({ where }),
447:         this.prisma.hotel.findMany({
448:           where,
449:           skip: offset,
450:           take: limit,
451:           orderBy: { createdAt: 'desc' },
452:           include: {
453:             images: true,
454:             roomTypes: {
455:               where: { deletedAt: null },
456:               select: {
457:                 price_per_night: true,
458:               },
459:             },
460:           },
461:         }),
462:       ]);
463:       const data = items.map((hotel) => {
464:         const prices = hotel.roomTypes.map((rt) => Number(rt.price_per_night));
465:         const minPrice = prices.length > 0 ? Math.min(...prices) : null;
466:         return {
467:           ...hotel,
468:           minPrice,
469:           roomTypes: undefined,
470:         };
471:       });
472:       return {
473:         data,
474:         meta: {
475:           limit,
476:           offset,
477:           total,
478:         },
479:       };
480:     }
481:   }
482: }
</file>

