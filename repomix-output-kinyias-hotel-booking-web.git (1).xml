 14: const MAX_PRICE = 50000000;
 15: const STEP_PRICE = 10000;
 16: const PAGE_LIMIT = 12;
 17: export function HotelSearch() {
 18:   const searchParams = useSearchParams();
 19:   const router = useRouter();
 20:   const urlMinPrice = searchParams.get('minPrice');
 21:   const urlMaxPrice = searchParams.get('maxPrice');
 22:   const urlCheckIn = searchParams.get('check_in');
 23:   const urlCheckOut = searchParams.get('check_out');
 24:   const urlCity = searchParams.get('city');
 25:   const [priceRange, setPriceRange] = useState<[number, number]>([
 26:     urlMinPrice ? Number(urlMinPrice) : 0,
 27:     urlMaxPrice ? Number(urlMaxPrice) : MAX_PRICE
 28:   ]);
 29:   const [page, setPage] = useState(1);
 30:   const [sortBy, setSortBy] = useState<string>('recommended');
 31:   const { data: hotelsData, isLoading, isFetching } = usePublicHotelsQuery({
 32:     page,
 33:     limit: PAGE_LIMIT,
 34:     minPrice: urlMinPrice ? Number(urlMinPrice) : undefined,
 35:     maxPrice: urlMaxPrice ? Number(urlMaxPrice) : undefined,
 36:     checkIn: urlCheckIn || undefined,
 37:     checkOut: urlCheckOut || undefined,
 38:     city: urlCity || undefined,
 39:     sortBy: sortBy as any,
 40:   });
 41:   useEffect(() => {
 42:     setPage(1);
 43:   }, [urlMinPrice, urlMaxPrice, urlCheckIn, urlCheckOut, urlCity, sortBy]);
 44:   const hotels = hotelsData?.data || [];
 45:   const meta = hotelsData?.meta;
 46:   const totalPages = meta ? Math.ceil(meta.total / meta.limit) : 0;
 47:   const handlePageChange = (newPage: number) => {
 48:     setPage(newPage);
 49:     window.scrollTo({ top: 0, behavior: 'smooth' });
 50:   };
 51:   const handleApplyFilters = () => {
 52:     const params = new URLSearchParams(searchParams.toString());
 53:     if (priceRange[0] > 0) {
 54:       params.set('minPrice', priceRange[0].toString());
 55:     } else {
 56:       params.delete('minPrice');
 57:     }
 58:     if (priceRange[1] < MAX_PRICE) {
 59:       params.set('maxPrice', priceRange[1].toString());
 60:     } else {
 61:       params.delete('maxPrice');
 62:     }
 63:     router.push(`/hotels?${params.toString()}`);
 64:   };
 65:   return (
 66:     <div className="min-h-screen bg-gray-50 pb-20">
 67:       <PageTitle
 68:         title="Our Hotels"
 69:         description="Discover the perfect stay for your next adventure"
