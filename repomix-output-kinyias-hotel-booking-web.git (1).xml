100:                   </div>
101:                 </div>
102:                 <Button
103:                   onClick={handleApplyFilters}
104:                   className="w-full mt-4 bg-primary hover:bg-primary/90"
105:                 >
106:                   Apply Filters
107:                 </Button>
108:               </div>
109:             </div>
110:           </div>
111:           {}
112:           <div className="lg:col-span-3 space-y-6">
113:             <div className="flex items-center justify-between mb-4">
114:               <h2 className="text-2xl font-bold text-gray-900">
115:                 {isLoading ? 'Loading hotels...' : `${meta?.total || 0} Hotels Found`}
116:               </h2>
117:               <div className="flex items-center gap-2 text-sm text-gray-600">
118:                 <span>Sort by:</span>
119:                 <select
120:                   className="bg-white border border-gray-300 rounded-md px-2 py-1 focus:outline-none focus:ring-1 focus:ring-primary"
121:                   value={sortBy}
122:                   onChange={(e) => setSortBy(e.target.value)}
123:                 >
124:                   <option value="recommended">Recommended</option>
125:                   <option value="price_asc">Price: Low to High</option>
126:                   <option value="price_desc">Price: High to Low</option>
127:                 </select>
128:               </div>
129:             </div>
130:             {isLoading || isFetching ? (
131:                 <div className="flex justify-center py-20">
132:                     <Loader2 className="h-8 w-8 animate-spin text-primary" />
133:                 </div>
134:             ) : hotels.length === 0 ? (
135:               <div className="text-center py-20 bg-white rounded-xl border border-gray-100 shadow-sm">
136:                 <h3 className="text-xl font-semibold text-gray-900 mb-2">No hotels found</h3>
137:                 <p className="text-gray-500">Try adjusting your filters to find what you're looking for.</p>
138:                 <Button
139:                   variant="link"
140:                   onClick={() => {
141:                     setPriceRange([0, MAX_PRICE]);
142:                   }}
143:                   className="mt-4 text-primary font-bold"
144:                 >
145:                   Clear all filters
146:                 </Button>
147:               </div>
148:             ) : (
149:               hotels.map((hotel) => {
150:                 return (
151:                   <div key={hotel.id} className="group bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow border border-gray-100 overflow-hidden flex flex-col md:flex-row h-auto md:h-64">
152:                     {}
153:                     <div className="relative w-full md:w-1/3 min-h-[200px] md:min-h-full">
154:                     <Link href={`/hotels/${hotel.id}`}>
155:                       <Image
