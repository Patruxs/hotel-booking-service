<file path="apps/api/src/modules/actions/actions.service.ts">
 1: import { BadRequestException, Injectable, NotFoundException } from '@nestjs/common';
 2: import { PrismaService } from '../prisma/prisma.service';
 3: @Injectable()
 4: export class ActionsService {
 5:   constructor(private prisma: PrismaService) {}
 6:   upsert(dto: {
 7:     key: string;
 8:     description?: string;
 9:     mode?: 'ANY' | 'ALL';
10:     enabled?: boolean;
11:   }) {
12:     return this.prisma.apiAction.upsert({
13:       where: { key: dto.key },
14:       create: {
15:         key: dto.key,
16:         description: dto.description,
17:         mode: (dto.mode ?? 'ANY') as any,
18:         enabled: dto.enabled ?? true,
19:       },
20:       update: {
21:         description: dto.description,
22:         mode: (dto.mode ?? 'ANY') as any,
23:         enabled: dto.enabled ?? true,
24:       },
25:     });
26:   }
27:   findAll() {
28:     return this.prisma.apiAction.findMany({
29:       orderBy: { key: 'asc' },
30:       include: { policies: { include: { permission: true } } },
31:     });
32:   }
33:   async findOneByKey(key: string) {
34:     const item = await this.prisma.apiAction.findUnique({
35:       where: { key },
36:       include: { policies: { include: { permission: true } } },
37:     });
38:     if (!item) throw new NotFoundException('Action not found');
39:     return item;
40:   }
41:  async setActionPermissions(id: string, permissionIds: string[]) {
42:   const cleanIds = permissionIds.filter((x) => typeof x === 'string' && x.trim().length > 0);
43:   const seen = new Set<string>();
44:   const dupes: string[] = [];
45:   for (const pid of cleanIds) {
46:     const key = pid.trim();
47:     if (seen.has(key)) dupes.push(key);
48:     else seen.add(key);
49:   }
50:   if (dupes.length > 0) {
51:     const uniqDupes = [...new Set(dupes)];
52:     throw new BadRequestException(`Duplicate permissionIds: ${uniqDupes.join(', ')}`);
53:   }
54:   const action = await this.prisma.apiAction.findUnique({ where: { id } });
55:   if (!action) throw new NotFoundException('Action not found');
56:   const perms = await this.prisma.permission.findMany({
57:     where: { id: { in: cleanIds } },
58:     select: { id: true, name: true },
59:   });
60:   const foundIds = new Set(perms.map((p) => p.id));
61:   const missingIds = cleanIds.filter((pid) => !foundIds.has(pid));
62:   if (missingIds.length > 0) {
63:     throw new NotFoundException(`Permissions not found (by id): ${missingIds.join(', ')}`);
64:   }
65:   return this.prisma.$transaction(async (tx) => {
66:     await tx.apiActionPolicy.deleteMany({ where: { actionId: action.id } });
67:     await tx.apiActionPolicy.createMany({
68:       data: cleanIds.map((pid) => ({ actionId: action.id, permissionId: pid })),
69:       skipDuplicates: true,
70:     });
71:     return tx.apiAction.findUnique({
72:       where: { id: action.id },
73:       include: { policies: { include: { permission: true } } },
74:     });
75:   });
76: }
77: }
</file>

