<file path="apps/api/src/modules/payment/vnpay-signature.service.ts">
 1: import { Injectable } from '@nestjs/common';
 2: import * as crypto from 'crypto';
 3: import * as qs from 'qs';
 4: @Injectable()
 5: export class VnpaySignatureService {
 6:   private readonly secret = process.env.VNPAY_HASH_SECRET!;
 7:   sortObject(obj: Record<string, any>) {
 8:     const sorted: Record<string, any> = {};
 9:     const keys = Object.keys(obj)
10:       .filter((k) => obj[k] !== undefined && obj[k] !== null)
11:       .map((k) => encodeURIComponent(k))
12:       .sort();
13:     for (const k of keys) {
14:       sorted[k] = encodeURIComponent(obj[decodeURIComponent(k)]).replace(
15:         /%20/g,
16:         '+',
17:       );
18:     }
19:     return sorted;
20:   }
21:   sign(params: Record<string, any>) {
22:     const sorted = this.sortObject(params);
23:     const signData = qs.stringify(sorted, { encode: false });
24:     return crypto
25:       .createHmac('sha512', this.secret)
26:       .update(Buffer.from(signData, 'utf-8'))
27:       .digest('hex');
28:   }
29:   verify(params: Record<string, any>, secureHash: string) {
30:     const signed = this.sign(params);
31:     return signed === secureHash;
32:   }
33: }
</file>

