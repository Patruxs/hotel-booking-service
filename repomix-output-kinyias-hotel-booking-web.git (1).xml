141:       </Card>
142:       <ConfirmDialog
143:         open={confirmOpen}
144:         title="Deactivate Commission Package"
145:         description="Are you sure you want to deactivate this commission package? Hotels using this package will need to be reassigned."
146:         confirmText="Deactivate"
147:         cancelText="Cancel"
148:         isLoading={deactivateMutation.isPending}
149:         onConfirm={handleConfirmDeactivate}
150:         onCancel={() => setConfirmOpen(false)}
151:       />
152:       <CommissionAssignToHotelsDialog
153:         open={assignOpen}
154:         onOpenChange={setAssignOpen}
155:         commissionPackage={selectedPackage}
156:       />
157:     </>
158:   );
159: }
</file>

