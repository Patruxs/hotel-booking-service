221:       (ur) => ur.role.name.toUpperCase() === 'ADMIN',
222:     );
223:     const andWhere: Prisma.HotelWhereInput[] = [];
224:     if (!query.includeDeleted) {
225:       andWhere.push({ deletedAt: null });
226:     }
227:     if (!isAdmin) {
228:       andWhere.push({
229:         members: {
230:           some: {
231:             userId,
232:           },
233:         },
234:       });
235:     }
236:     if (query.ownerId) {
237:       andWhere.push({ ownerId: query.ownerId });
238:     }
239:     if (query.city) {
240:       andWhere.push({
241:         city: { contains: query.city, mode: 'insensitive' },
242:       });
243:     }
244:     if (query.name) {
245:       andWhere.push({
246:         name: { contains: query.name, mode: 'insensitive' },
247:       });
