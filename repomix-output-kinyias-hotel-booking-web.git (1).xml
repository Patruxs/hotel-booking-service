155:               { content: { contains: q.q, mode: 'insensitive' } },
156:             ],
157:           }
158:         : {}),
159:     };
160:     const [items, total] = await this.prisma.$transaction([
161:       this.prisma.review.findMany({
162:         where,
163:         skip,
164:         take: limit,
165:         orderBy: { createdAt: 'desc' },
166:         include: {
167:           images: true,
168:           hotel: { select: { id: true, name: true } },
169:           user: {
170:             select: {
171:               id: true,
172:               firstName: true,
173:               lastName: true,
174:               avatar: {
175:                 select: {
176:                   id: true,
177:                   secureUrl: true,
178:                 },
179:               },
180:             },
181:           },
182:         },
183:       }),
184:       this.prisma.review.count({ where }),
185:     ]);
186:     return { page, limit, total, items };
187:   }
188:   async listMy(userId: string, q: ListReviewsDto) {
189:     const page = q.page ?? 1;
