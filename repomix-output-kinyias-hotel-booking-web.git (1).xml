11:   shouldShowButton,
12: } from "@/components/tiptap-ui/heading-button"
13: export interface UseHeadingDropdownMenuConfig {
14:   editor?: Editor | null
15:   levels?: Level[]
16:   hideWhenUnavailable?: boolean
17: }
18: export function getActiveHeadingLevel(
19:   editor: Editor | null,
20:   levels: Level[] = [1, 2, 3, 4, 5, 6]
21: ): Level | undefined {
22:   if (!editor || !editor.isEditable) return undefined
23:   return levels.find((level) => isHeadingActive(editor, level))
24: }
25: export function useHeadingDropdownMenu(config?: UseHeadingDropdownMenuConfig) {
26:   const {
27:     editor: providedEditor,
28:     levels = [1, 2, 3, 4, 5, 6],
29:     hideWhenUnavailable = false,
30:   } = config || {}
31:   const { editor } = useTiptapEditor(providedEditor)
32:   const [isVisible, setIsVisible] = useState(true)
33:   const activeLevel = getActiveHeadingLevel(editor, levels)
34:   const isActive = isHeadingActive(editor)
35:   const canToggleState = canToggle(editor)
36:   useEffect(() => {
37:     if (!editor) return
38:     const handleSelectionUpdate = () => {
39:       setIsVisible(
40:         shouldShowButton({ editor, hideWhenUnavailable, level: levels })
41:       )
42:     }
43:     handleSelectionUpdate()
44:     editor.on("selectionUpdate", handleSelectionUpdate)
45:     return () => {
46:       editor.off("selectionUpdate", handleSelectionUpdate)
47:     }
48:   }, [editor, hideWhenUnavailable, levels])
49:   return {
50:     isVisible,
51:     activeLevel,
52:     isActive,
53:     canToggle: canToggleState,
54:     levels,
55:     label: "Heading",
56:     Icon: activeLevel ? headingIcons[activeLevel] : HeadingIcon,
