 9: import { PrismaService } from '../prisma/prisma.service';
10: @Injectable()
11: export class PolicyService {
12:   constructor(private prisma: PrismaService) {}
13:   async assertHotelAccess(hotelId: string, userId: string) {
14:     const hotel = await this.prisma.hotel.findUnique({
15:       where: { id: hotelId },
16:       select: { ownerId: true },
17:     });
18:     if (!hotel) throw new NotFoundException('Hotel not found');
19:     if (hotel.ownerId === userId) return;
20:     const member = await this.prisma.hotelMember.findUnique({
21:       where: {
22:         hotelId_userId: { hotelId, userId },
23:       },
24:     });
25:     if (!member) throw new ForbiddenException('Not a member of this hotel');
26:   }
27:   async listPublic(hotelId: string) {
28:     return this.prisma.hotelPolicy.findMany({
29:       where: { hotelId, enabled: true },
30:       orderBy: { order: 'asc' },
31:     });
32:   }
33:   async listAdmin(hotelId: string, userId: string) {
34:     await this.assertHotelAccess(hotelId, userId);
35:     return this.prisma.hotelPolicy.findMany({
36:       where: { hotelId },
37:       orderBy: { order: 'asc' },
38:     });
39:   }
40:   async getOne(hotelId: string, userId: string, id: string) {
41:     await this.assertHotelAccess(hotelId, userId);
42:     const policy = await this.prisma.hotelPolicy.findUnique({
43:       where: { id },
44:     });
45:     if (!policy || policy.hotelId !== hotelId) {
46:       throw new NotFoundException('Policy not found');
47:     }
48:     return policy;
49:   }
50:   async create(hotelId: string, userId: string, dto: CreatePolicyDto) {
51:     await this.assertHotelAccess(hotelId, userId);
52:     const order = dto.order ?? 0;
53:     const existingPolicy = await this.prisma.hotelPolicy.findFirst({
54:       where: { hotelId, order },
55:     });
56:     if (existingPolicy) {
57:       const total = await this.prisma.hotelPolicy.count({ where: { hotelId } });
58:       throw new BadRequestException(
59:         `Order ${order} is already taken in this hotel. Total policies: ${total}`,
60:       );
61:     }
62:     return this.prisma.hotelPolicy.create({
63:       data: { hotelId, ...dto },
64:     });
65:   }
66:   async update(
67:     hotelId: string,
68:     userId: string,
69:     id: string,
70:     dto: UpdatePolicyDto,
71:   ) {
72:     await this.assertHotelAccess(hotelId, userId);
73:     if (dto.order !== undefined) {
74:       const existingPolicy = await this.prisma.hotelPolicy.findFirst({
75:         where: {
76:           hotelId,
77:           order: dto.order,
78:           id: { not: id },
79:         },
80:       });
81:       if (existingPolicy) {
82:         const total = await this.prisma.hotelPolicy.count({
83:           where: { hotelId },
84:         });
85:         throw new BadRequestException(
86:           `Order ${dto.order} is already taken in this hotel. Total policies: ${total}. Please choose a different order.`,
87:         );
88:       }
89:     }
90:     return this.prisma.hotelPolicy.update({
91:       where: { id },
92:       data: dto,
93:     });
94:   }
95:   async remove(hotelId: string, userId: string, id: string) {
96:     await this.assertHotelAccess(hotelId, userId);
97:     return this.prisma.hotelPolicy.delete({ where: { id } });
98:   }
99: }
