135:                             {selectedRoles.map((role) => (
136:                               <Badge
137:                                 key={role.id}
138:                                 variant="secondary"
139:                                 className="cursor-pointer"
140:                                 onClick={() => removeRole(role.id)}
141:                               >
142:                                 {role.name} ✕
143:                               </Badge>
144:                             ))}
145:                           </div>
146:                         )}
147:                         {/* Autocomplete input with popover */}
148:                         <div className="relative">
149:                           <Input
150:                             ref={inputRef}
151:                             placeholder="Search roles..."
152:                             value={inputValue}
153:                             onChange={(e) => {
154:                               setInputValue(e.target.value);
155:                               setOpenPopover(e.target.value.length > 0);
156:                             }}
157:                             onFocus={() => {
158:                               setOpenPopover(true);
159:                             }}
160:                             onBlur={() => {
161:                               // Delay to allow clicking on popover items
162:                               setTimeout(() => setOpenPopover(false), 200);
163:                             }}
164:                             onKeyDown={(e) => {
165:                               if (e.key === 'Enter' && inputValue.trim()) {
166:                                 e.preventDefault();
167:                                 let found = roles?.find(
168:                                   (r) =>
169:                                     r.name.toLowerCase() ===
170:                                     inputValue.toLowerCase()
171:                                 );
172:                                 if (!found && filteredSuggestions.length > 0) {
173:                                   found = filteredSuggestions[0];
174:                                 }
175:                                 if (!found && filteredSuggestions.length == 0) {
176:                                   toast.error('Role not found');
177:                                 }
178:                                 if (found && !field.value.includes(found.id)) {
179:                                   addRole(found.id);
180:                                 }
181:                               }
182:                               if (e.key === 'Escape') {
183:                                 setOpenPopover(false);
184:                               }
185:                             }}
186:                           />
187:                           {openPopover && filteredSuggestions.length > 0 && (
188:                             <div className="absolute z-50 w-full mt-1 rounded-md border bg-popover text-popover-foreground shadow-md outline-none animate-in">
189:                               <Command>
190:                                 <CommandList>
191:                                   {filteredSuggestions.map((role) => (
192:                                     <CommandItem
193:                                       key={role.id}
194:                                       onMouseDown={(e) => {
195:                                         e.preventDefault();
196:                                         addRole(role.id);
197:                                       }}
198:                                       className="cursor-pointer"
199:                                     >
200:                                       {role.name}
201:                                     </CommandItem>
202:                                   ))}
203:                                 </CommandList>
204:                               </Command>
205:                             </div>
206:                           )}
207:                         </div>
208:                         <FormMessage />
209:                       </div>
210:                     </FormControl>
211:                   </FormItem>
212:                 );
213:               }}
214:             />
215:             <DialogFooter>
216:               <Button
217:                 type="button"
218:                 variant="outline"
219:                 onClick={() => onOpenChange(false)}
220:               >
221:                 Cancel
222:               </Button>
223:               <Button type="submit" disabled={isSubmitting}>
224:                 {isSubmitting ? 'Assigning' : 'Assign Roles'}
225:               </Button>
226:             </DialogFooter>
227:           </form>
228:         </Form>
229:       </DialogContent>
230:     </Dialog>
231:   );
232: }
