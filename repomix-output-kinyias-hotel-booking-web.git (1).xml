11:       toast.success('Policy created successfully');
12:     },
13:     onError: (error: any) => {
14:       toast.error(error?.response?.data?.message || 'Failed to create policy');
15:     },
16:   });
17: };
18: export const useUpdatePolicyMutation = (hotelId: string, policyId: string) => {
19:   const queryClient = useQueryClient();
20:   return useMutation({
21:     mutationFn: (data: UpdatePolicyPayload) => updatePolicy(hotelId, policyId, data),
22:     onSuccess: () => {
23:       queryClient.invalidateQueries({ queryKey: ['policies', hotelId] });
24:       queryClient.invalidateQueries({ queryKey: ['policy', hotelId, policyId] });
25:       toast.success('Policy updated successfully');
26:     },
27:     onError: (error: any) => {
28:       toast.error(error?.response?.data?.message || 'Failed to update policy');
