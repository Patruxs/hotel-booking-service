344:     const node = $pos.node(depth)
345:     const pos = $pos.start(depth)
346:     if (node.isBlock && node.textContent.trim()) {
347:       blockNode = node
348:       blockPos = pos
349:       break
350:     }
351:   }
352:   if (blockNode && blockPos >= 0) {
