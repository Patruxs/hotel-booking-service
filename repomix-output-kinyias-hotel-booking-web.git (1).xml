 12: @Injectable()
 13: export class ReviewService {
 14:   constructor(private prisma: PrismaService) {}
 15:   private async assertHotelAccess(hotelId: string, userId: string) {
 16:     const hotel = await this.prisma.hotel.findUnique({
 17:       where: { id: hotelId },
 18:       select: { id: true, ownerId: true },
 19:     });
 20:     if (!hotel) throw new NotFoundException('Hotel not found');
 21:     if (hotel.ownerId === userId) return;
 22:     const member = await this.prisma.hotelMember.findUnique({
 23:       where: { hotelId_userId: { hotelId, userId } },
 24:       select: { userId: true },
 25:     });
 26:     if (!member) throw new ForbiddenException('No permission on this hotel');
 27:   }
 28:   async create(hotelId: string, userId: string, dto: CreateReviewDto) {
 29:     const booking = await this.prisma.booking.findFirst({
 30:       where: { id: dto.bookingId, hotelId, userId },
 31:       select: { id: true, status: true },
 32:     });
 33:     if (!booking)
 34:       throw new NotFoundException(
 35:         'Booking not found (or not belong to you / this hotel)',
 36:       );
 37:     if (booking.status !== 'COMPLETED')
 38:       throw new BadRequestException('Only COMPLETED bookings can be reviewed');
 39:     const imageIds = (dto.imageIds ?? []).filter(Boolean);
 40:     let galleryImages: { id: string; secureUrl: string; url: string }[] = [];
 41:     if (imageIds.length > 0) {
 42:       galleryImages = await this.prisma.imageGallery.findMany({
 43:         where: {
 44:           id: { in: imageIds },
 45:           userId,
 46:         },
 47:         select: { id: true, secureUrl: true, url: true },
 48:       });
 49:       if (galleryImages.length !== imageIds.length) {
 50:         throw new ForbiddenException(
 51:           'Some images are not in your gallery (or not found)',
 52:         );
 53:       }
 54:     }
 55:     try {
 56:       const result = await this.prisma.$transaction(async (tx) => {
 57:         const review = await tx.review.create({
 58:           data: {
 59:             hotelId,
 60:             userId,
 61:             bookingId: booking.id,
 62:             rating: dto.rating,
 63:             title: dto.title,
 64:             content: dto.content,
 65:           },
 66:         });
 67:         if (galleryImages.length > 0) {
 68:           await tx.reviewImage.createMany({
 69:             data: galleryImages.map((img) => ({
 70:               reviewId: review.id,
 71:               url: img.secureUrl || img.url,
 72:             })),
 73:           });
 74:         }
 75:         return tx.review.findUnique({
 76:           where: { id: review.id },
 77:           include: {
 78:             images: true,
 79:             user: {
 80:               select: {
 81:                 id: true,
 82:                 firstName: true,
 83:                 lastName: true,
 84:                 avatarId: true,
 85:               },
 86:             },
 87:           },
 88:         });
 89:       });
 90:       return result;
 91:     } catch (e: any) {
 92:       if (e?.code === 'P2002') {
 93:         throw new BadRequestException('This booking has already been reviewed');
 94:       }
 95:       throw e;
 96:     }
 97:   }
 98:   async listPublic(hotelId: string, q: ListReviewsDto) {
 99:     const page = q.page ?? 1;
100:     const limit = q.limit ?? 20;
101:     const skip = (page - 1) * limit;
102:     const where: Prisma.ReviewWhereInput = {
103:       hotelId,
104:       deletedAt: null,
105:       isHidden: false,
106:       ...(q.q
107:         ? {
108:             OR: [
109:               { title: { contains: q.q, mode: 'insensitive' } },
110:               { content: { contains: q.q, mode: 'insensitive' } },
111:             ],
112:           }
113:         : {}),
114:     };
115:     const [items, total] = await this.prisma.$transaction([
116:       this.prisma.review.findMany({
117:         where,
118:         skip,
119:         take: limit,
120:         orderBy: { createdAt: 'desc' },
121:         include: {
122:           images:true,
123:           user: {
124:             select: {
125:               id: true,
126:               firstName: true,
127:               lastName: true,
128:               avatar: {
129:                 select: {
130:                   id: true,
131:                   secureUrl: true,
132:                   publicId: true,
133:                 },
134:               },
135:             },
136:           },
137:         },
138:       }),
139:       this.prisma.review.count({ where }),
140:     ]);
141:     return { page, limit, total, items };
142:   }
143:   async listForModeration(hotelId: string, userId: string, q: ListReviewsDto) {
144:     await this.assertHotelAccess(hotelId, userId);
145:     const page = q.page ?? 1;
