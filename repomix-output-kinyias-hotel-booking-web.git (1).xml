  6: import {
  7:   isMarkInSchema,
  8:   isNodeTypeSelected,
  9:   sanitizeUrl,
 10: } from "@/lib/tiptap-utils"
 11: export interface UseLinkPopoverConfig {
 12:   editor?: Editor | null
 13:   hideWhenUnavailable?: boolean
 14:   onSetLink?: () => void
 15: }
 16: export interface LinkHandlerProps {
 17:   editor: Editor | null
 18:   onSetLink?: () => void
 19: }
 20: export function canSetLink(editor: Editor | null): boolean {
 21:   if (!editor || !editor.isEditable) return false
 22:   if (isNodeTypeSelected(editor, ["image"], true)) return false
 23:   return editor.can().setMark("link")
 24: }
 25: export function isLinkActive(editor: Editor | null): boolean {
 26:   if (!editor || !editor.isEditable) return false
 27:   return editor.isActive("link")
 28: }
 29: export function shouldShowLinkButton(props: {
 30:   editor: Editor | null
 31:   hideWhenUnavailable: boolean
 32: }): boolean {
 33:   const { editor, hideWhenUnavailable } = props
 34:   const linkInSchema = isMarkInSchema("link", editor)
 35:   if (!linkInSchema || !editor) {
 36:     return false
 37:   }
 38:   if (hideWhenUnavailable && !editor.isActive("code")) {
 39:     return canSetLink(editor)
 40:   }
 41:   return true
 42: }
 43: export function useLinkHandler(props: LinkHandlerProps) {
 44:   const { editor, onSetLink } = props
 45:   const [url, setUrl] = useState<string | null>(null)
 46:   useEffect(() => {
 47:     if (!editor) return
 48:     const { href } = editor.getAttributes("link")
 49:     if (isLinkActive(editor) && url === null) {
 50:       setUrl(href || "")
 51:     }
 52:   }, [editor, url])
 53:   useEffect(() => {
 54:     if (!editor) return
 55:     const updateLinkState = () => {
 56:       const { href } = editor.getAttributes("link")
 57:       setUrl(href || "")
 58:     }
 59:     editor.on("selectionUpdate", updateLinkState)
 60:     return () => {
 61:       editor.off("selectionUpdate", updateLinkState)
 62:     }
 63:   }, [editor])
 64:   const setLink = useCallback(() => {
 65:     if (!url || !editor) return
 66:     const { selection } = editor.state
 67:     const isEmpty = selection.empty
 68:     let chain = editor.chain().focus()
 69:     chain = chain.extendMarkRange("link").setLink({ href: url })
 70:     if (isEmpty) {
 71:       chain = chain.insertContent({ type: "text", text: url })
 72:     }
 73:     chain.run()
 74:     setUrl(null)
 75:     onSetLink?.()
 76:   }, [editor, onSetLink, url])
 77:   const removeLink = useCallback(() => {
 78:     if (!editor) return
 79:     editor
 80:       .chain()
 81:       .focus()
 82:       .extendMarkRange("link")
 83:       .unsetLink()
 84:       .setMeta("preventAutolink", true)
 85:       .run()
 86:     setUrl("")
 87:   }, [editor])
 88:   const openLink = useCallback(
 89:     (target: string = "_blank", features: string = "noopener,noreferrer") => {
 90:       if (!url) return
 91:       const safeUrl = sanitizeUrl(url, window.location.href)
 92:       if (safeUrl !== "#") {
 93:         window.open(safeUrl, target, features)
 94:       }
 95:     },
 96:     [url]
 97:   )
 98:   return {
 99:     url: url || "",
100:     setUrl,
101:     setLink,
102:     removeLink,
103:     openLink,
104:   }
105: }
106: /**
107:  * Custom hook for link popover state management
108:  */
109: export function useLinkState(props: {
110:   editor: Editor | null
111:   hideWhenUnavailable: boolean
112: }) {
113:   const { editor, hideWhenUnavailable = false } = props
114:   const canSet = canSetLink(editor)
115:   const isActive = isLinkActive(editor)
116:   const [isVisible, setIsVisible] = useState(true)
117:   useEffect(() => {
118:     if (!editor) return
119:     const handleSelectionUpdate = () => {
120:       setIsVisible(
121:         shouldShowLinkButton({
122:           editor,
123:           hideWhenUnavailable,
124:         })
125:       )
126:     }
127:     handleSelectionUpdate()
128:     editor.on("selectionUpdate", handleSelectionUpdate)
129:     return () => {
130:       editor.off("selectionUpdate", handleSelectionUpdate)
131:     }
132:   }, [editor, hideWhenUnavailable])
133:   return {
134:     isVisible,
135:     canSet,
136:     isActive,
137:   }
138: }
139: export function useLinkPopover(config?: UseLinkPopoverConfig) {
140:   const {
141:     editor: providedEditor,
142:     hideWhenUnavailable = false,
143:     onSetLink,
144:   } = config || {}
145:   const { editor } = useTiptapEditor(providedEditor)
146:   const { isVisible, canSet, isActive } = useLinkState({
147:     editor,
148:     hideWhenUnavailable,
149:   })
150:   const linkHandler = useLinkHandler({
151:     editor,
152:     onSetLink,
153:   })
154:   return {
155:     isVisible,
156:     canSet,
157:     isActive,
158:     label: "Link",
159:     Icon: LinkIcon,
160:     ...linkHandler,
