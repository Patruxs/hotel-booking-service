<file path="apps/api/src/modules/amentity/amenity.service.ts">
 1: import { BadRequestException, Injectable, NotFoundException } from '@nestjs/common';
 2: import { PrismaClientKnownRequestError } from '@prisma/client/runtime/library';
 3: import { CreateAmenityDto } from './dto/create-amenity.dto';
 4: import { UpdateAmenityDto } from './dto/update-amenity.dto';
 5: import { ListAmenityDto } from './dto/list-amenity.dto';
 6: import { PrismaService } from '../prisma/prisma.service';
 7: import { Prisma } from '@prisma/client';
 8: @Injectable()
 9: export class AmenityService {
10:   constructor(private readonly prisma: PrismaService) {}
11:   async create(dto: CreateAmenityDto) {
12:     try {
13:       return await this.prisma.amenity.create({
14:         data: {
15:           key: dto.key.trim(),
16:           label: dto.label.trim(),
17:           sortOrder: dto.sortOrder ?? 0,
18:           isActive: dto.isActive ?? true,
19:         },
20:       });
21:     } catch (e) {
22:       if (e instanceof PrismaClientKnownRequestError && e.code === 'P2002') {
23:         throw new BadRequestException('Amenity key already exists');
24:       }
25:       throw e;
26:     }
27:   }
28:   async list(q: ListAmenityDto) {
29:     const limit = q.limit ?? 50;
30:     const offset = q.page ? (q.page - 1) * limit : 0;
31:     const where: Prisma.AmenityWhereInput = {
32:       ...(q.isActive !== undefined ? { isActive: q.isActive } : {}),
33:       ...(q.q
34:         ? {
35:             OR: [
36:               { key: { contains: q.q, mode: Prisma.QueryMode.insensitive } },
37:               { label: { contains: q.q, mode: Prisma.QueryMode.insensitive } },
38:             ],
39:           }
40:         : {}),
41:     };
42:     const [items, total] = await this.prisma.$transaction([
43:       this.prisma.amenity.findMany({
44:         where,
45:         orderBy: [{ sortOrder: 'desc' }, { createdAt: 'desc' }],
46:         take: limit,
47:         skip: offset,
48:       }),
49:       this.prisma.amenity.count({ where }),
50:     ]);
51:     return {
52:       data: items,
53:       meta: {
54:         limit,
55:         offset,
56:         total,
57:       },
58:     };
59:   }
60:   async getOne(id: string) {
61:     const amenity = await this.prisma.amenity.findUnique({ where: { id } });
62:     if (!amenity) throw new NotFoundException('Amenity not found');
63:     return amenity;
64:   }
65:   async update(id: string, dto: UpdateAmenityDto) {
66:     try {
67:       return await this.prisma.amenity.update({
68:         where: { id },
69:         data: {
70:           ...(dto.key !== undefined
71:             ? { key: dto.key.trim() }
72:             : {}),
73:           ...(dto.label !== undefined ? { label: dto.label.trim() } : {}),
74:           ...(dto.sortOrder !== undefined ? { sortOrder: dto.sortOrder } : {}),
75:           ...(dto.isActive !== undefined ? { isActive: dto.isActive } : {}),
76:         },
77:       });
78:     } catch (e) {
79:       if (e instanceof PrismaClientKnownRequestError && e.code === 'P2002') {
80:         throw new BadRequestException('Amenity key already exists');
81:       }
82:       throw e;
83:     }
84:   }
85:   async disable(id: string) {
86:     await this.getOne(id);
87:     return this.prisma.amenity.update({
88:       where: { id },
89:       data: { isActive: false },
90:     });
91:   }
92: }
</file>

