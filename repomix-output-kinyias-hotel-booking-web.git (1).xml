 5:   phone: z.string().max(20, 'Phone number is too long').optional().or(z.literal('')),
 6:   subject: z.string().max(200, 'Subject is too long').optional().or(z.literal('')),
 7:   message: z.string().min(1, 'Message is required').max(5000, 'Message is too long'),
 8: }).refine(
