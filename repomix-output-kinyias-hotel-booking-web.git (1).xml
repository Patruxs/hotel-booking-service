  1: import { Injectable } from '@nestjs/common';
  2: import { PrismaService } from '../prisma/prisma.service';
  3: import { PaymentStatus, BookingStatus } from '@prisma/client';
  4: @Injectable()
  5: export class DashboardService {
  6:   constructor(private readonly prisma: PrismaService) {}
  7:   async getStats(hotelId?: string) {
  8:     const whereHotel = hotelId ? { hotelId } : {};
  9:     let totalUsers = 0;
 10:     if (hotelId) {
 11:       const distinctUsers = await this.prisma.booking.findMany({
 12:         where: { hotelId, userId: { not: null } },
 13:         select: { userId: true },
 14:         distinct: ['userId'],
 15:       });
 16:       totalUsers = distinctUsers.length;
 17:     } else {
 18:       totalUsers = await this.prisma.user.count();
 19:     }
 20:     const totalBookings = await this.prisma.booking.count({
 21:       where: whereHotel,
 22:     });
 23:     const revenueAgg = await this.prisma.booking.aggregate({
 24:       where: {
 25:         status: BookingStatus.COMPLETED,
 26:         ...(hotelId ? { hotelId } : {}),
 27:       },
 28:       _sum: {
 29:         totalAmount: true,
 30:       },
 31:     });
 32:     const revenue = Number(revenueAgg._sum.totalAmount || 0);
 33:     let activeHotels = 0;
 34:     if (hotelId) {
 35:        const hotel = await this.prisma.hotel.findUnique({
 36:          where: { id: hotelId },
 37:          select: { status: true }
 38:        });
 39:        activeHotels = hotel?.status === 'ACTIVE' ? 1 : 0;
 40:     } else {
 41:       activeHotels = await this.prisma.hotel.count({
 42:         where: { status: 'ACTIVE' },
 43:       });
 44:     }
 45:     return {
 46:       totalUsers,
 47:       totalBookings,
 48:       revenue,
 49:       activeHotels,
 50:     };
 51:   }
 52:   async getRevenueChart(
 53:     hotelId?: string,
 54:     groupBy: 'day' | 'week' | 'month' = 'month',
 55:     year: number = new Date().getFullYear(),
 56:     from?: string,
 57:     to?: string,
 58:   ) {
 59:     let startDate: Date;
 60:     let endDate: Date;
 61:     if (from && to) {
 62:         startDate = new Date(from);
 63:         endDate = new Date(to);
 64:     } else {
 65:         startDate = new Date(year, 0, 1);
 66:         endDate = new Date(year, 11, 31, 23, 59, 59);
 67:     }
 68:     const bookings = await this.prisma.booking.findMany({
 69:       where: {
 70:         ...(hotelId ? { hotelId } : {}),
 71:         status: BookingStatus.COMPLETED,
 72:         createdAt: {
 73:           gte: startDate,
 74:           lte: endDate,
 75:         },
 76:       },
 77:       select: {
 78:         totalAmount: true,
 79:         createdAt: true,
 80:       },
 81:     });
 82:     const result = new Map<string, number>();
 83:     if (groupBy === 'month' && !from) {
 84:       for (let i = 0; i < 12; i++) {
 85:         result.set(`${i}`, 0);
 86:       }
 87:     }
 88:     bookings.forEach((b) => {
 89:       const date = new Date(b.createdAt);
 90:       let key = '';
 91:       if (groupBy === 'month') {
 92:         key = date.getMonth().toString();
 93:       } else {
 94:          key = date.toISOString().split('T')[0];
 95:       }
 96:       const current = result.get(key) || 0;
 97:       result.set(key, current + Number(b.totalAmount));
 98:     });
 99:     if (groupBy === 'month' && !from) {
100:        return Array.from(result.entries()).sort((a,b) => parseInt(a[0]) - parseInt(b[0])).map(([, value]) => value);
101:     }
102:     return Array.from(result.entries()).map(([date, revenue]) => ({ date, revenue }));
103:   }
104:   async getLatestReviews(hotelId?: string, limit = 5) {
105:     return this.prisma.review.findMany({
106:       where: hotelId ? { hotelId } : undefined,
107:       orderBy: { createdAt: 'desc' },
108:       take: Number(limit),
109:       include: {
110:         user: {
111:           select: {
112:             id: true,
113:             firstName: true,
114:             lastName: true,
115:             avatar: true,
116:           }
117:         }
118:       }
119:     });
120:   }
121:   async getNewestBookings(hotelId?: string, limit = 5) {
122:     return this.prisma.booking.findMany({
123:       where: hotelId ? { hotelId } : undefined,
124:       orderBy: { createdAt: 'desc' },
125:       take: Number(limit),
126:       include: {
127:          items: {
128:           include: {
129:             roomType: true
130:           }
131:          }
132:       }
133:     });
134:   }
135: }
