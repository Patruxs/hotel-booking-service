  1: import {
  2:   BadRequestException,
  3:   Injectable,
  4:   NotFoundException,
  5: } from '@nestjs/common';
  6: import { Prisma, NewsStatus } from '@prisma/client';
  7: import { PrismaService } from '../prisma/prisma.service';
  8: import { CreateNewsDto, NewsStatusDto } from './dto/create-news.dto';
  9: import { UpdateNewsDto } from './dto/update-news.dto';
 10: import { ListNewsDto } from './dto/list-news.dto';
 11: function slugify(input: string) {
 12:   return input
 13:     .trim()
 14:     .toLowerCase()
 15:     .normalize('NFKD')
 16:     .replace(/[\u0300-\u036f]/g, '')
 17:     .replace(/[^a-z0-9]+/g, '-')
 18:     .replace(/(^-|-$)+/g, '');
 19: }
 20: @Injectable()
 21: export class NewsService {
 22:   constructor(private prisma: PrismaService) {}
 23:   private mapStatus(s?: NewsStatusDto): NewsStatus | undefined {
 24:     if (!s) return undefined;
 25:     return s as unknown as NewsStatus;
 26:   }
 27:   private async loadGalleryImagesOrThrow(userId: string, imageIds?: string[]) {
 28:     if (!imageIds || imageIds.length === 0) return [];
 29:     const imgs = await this.prisma.imageGallery.findMany({
 30:       where: { id: { in: imageIds }, userId }, // đảm bảo ảnh thuộc user
 31:       select: { id: true, secureUrl: true, url: true },
 32:     });
 33:     if (imgs.length !== imageIds.length) {
 34:       throw new BadRequestException(
 35:         'Some imageIds are invalid or not belong to current user',
 36:       );
 37:     }
 38:     return imgs.map((i) => i.secureUrl || i.url);
 39:   }
 40:   async create(userId: string, dto: CreateNewsDto) {
 41:     const status = this.mapStatus(dto.status) ?? NewsStatus.DRAFT;
 42:     const baseSlug = slugify(dto.title);
 43:     let slug = baseSlug || `news-${Date.now()}`;
 44:     const existed = await this.prisma.news.findUnique({
 45:       where: { slug },
 46:       select: { id: true },
 47:     });
 48:     if (existed) slug = `${slug}-${Date.now()}`;
 49:     const imageUrls = await this.loadGalleryImagesOrThrow(userId, dto.imageIds);
 50:     const data: Prisma.NewsCreateInput = {
 51:       title: dto.title,
 52:       slug,
 53:       summary: dto.summary,
 54:       content: dto.content,
 55:       status,
 56:       publishedAt: status === NewsStatus.PUBLISHED ? new Date() : null,
 57:       createdBy: { connect: { id: userId } },
 58:       images: imageUrls.length
 59:         ? { create: imageUrls.map((url) => ({ url })) }
 60:         : undefined,
 61:     };
 62:     return this.prisma.news.create({
 63:       data,
 64:       include: {
 65:         images: true,
 66:         createdBy: {
 67:           select: { id: true, email: true, firstName: true, lastName: true },
 68:         },
 69:       },
 70:     });
 71:   }
 72:   async list(q: ListNewsDto, isAdmin = false) {
 73:     const page = q.page ?? 1;
 74:     const limit = q.limit ?? 20;
 75:     const skip = (page - 1) * limit;
 76:     const where: Prisma.NewsWhereInput = {
 77:       deletedAt: null,
 78:       ...(q.q
 79:         ? {
 80:             OR: [
 81:               { title: { contains: q.q, mode: 'insensitive' } },
 82:               { summary: { contains: q.q, mode: 'insensitive' } },
 83:             ],
 84:           }
 85:         : {}),
 86:       ...(q.status ? { status: this.mapStatus(q.status) } : {}),
 87:     };
 88:     if (!isAdmin) where.status = NewsStatus.PUBLISHED;
 89:     const [items, total] = await this.prisma.$transaction([
 90:       this.prisma.news.findMany({
 91:         where,
 92:         skip,
 93:         take: limit,
 94:         orderBy: [{ publishedAt: 'desc' }, { createdAt: 'desc' }],
 95:         include: { images: true },
 96:       }),
 97:       this.prisma.news.count({ where }),
 98:     ]);
 99:     return { page, limit, total, items };
100:   }
101:   async getById(id: string, isAdmin = false) {
102:     const news = await this.prisma.news.findFirst({
103:       where: {
104:         id,
105:         deletedAt: null,
106:         ...(isAdmin ? {} : { status: NewsStatus.PUBLISHED }),
107:       },
108:       include: { images: true },
109:     });
110:     if (!news) throw new NotFoundException('News not found');
111:     return news;
112:   }
113:   async getBySlug(slug: string, isAdmin = false) {
114:     const news = await this.prisma.news.findFirst({
115:       where: {
116:         slug,
117:         deletedAt: null,
118:         ...(isAdmin ? {} : { status: NewsStatus.PUBLISHED }),
119:       },
120:       include: { images: true },
121:     });
122:     if (!news) throw new NotFoundException('News not found');
123:     return news;
124:   }
125:   async update(userId: string, id: string, dto: UpdateNewsDto) {
126:     const current = await this.prisma.news.findFirst({
127:       where: { id, deletedAt: null },
128:       select: { id: true, status: true },
129:     });
130:     if (!current) throw new NotFoundException('News not found');
131:     const status = this.mapStatus(dto.status);
132:     const imageUrls = dto.imageIds
133:       ? await this.loadGalleryImagesOrThrow(userId, dto.imageIds)
134:       : null;
135:     const data: Prisma.NewsUpdateInput = {
136:       title: dto.title,
137:       summary: dto.summary,
138:       content: dto.content,
139:       ...(status
140:         ? {
141:             status,
142:             publishedAt: status === NewsStatus.PUBLISHED ? new Date() : null,
143:           }
144:         : {}),
145:     };
146:     return this.prisma.$transaction(async (tx) => {
147:       if (imageUrls) {
148:         await tx.newsImage.deleteMany({ where: { newsId: id } });
149:         if (imageUrls.length) {
150:           await tx.newsImage.createMany({
151:             data: imageUrls.map((url) => ({ newsId: id, url })),
152:           });
153:         }
154:       }
155:       return tx.news.update({
156:         where: { id },
157:         data,
158:         include: { images: true },
159:       });
160:     });
161:   }
162:   async remove(id: string) {
163:     const exists = await this.prisma.news.findFirst({
164:       where: { id, deletedAt: null },
165:       select: { id: true },
166:     });
167:     if (!exists) throw new NotFoundException('News not found');
168:     return this.prisma.news.update({
169:       where: { id },
170:       data: { deletedAt: new Date() },
171:     });
172:   }
173: }
</file>

