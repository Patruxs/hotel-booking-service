143:                           )
144:                         ) : (
145:                           <span>Pick a date range</span>
146:                         )}
147:                       </Button>
148:                     </PopoverTrigger>
149:                     <PopoverContent className="w-auto p-0" align="start">
150:                       <Calendar
151:                         initialFocus
152:                         mode="range"
153:                         defaultMonth={dateRange?.from}
154:                         selected={{
155:                           from: dateRange?.from,
156:                           to: dateRange?.to,
157:                         }}
158:                         onSelect={(range) => {
