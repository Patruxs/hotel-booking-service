 90:     .filter((color): color is (typeof HIGHLIGHT_COLORS)[number] => !!color)
 91: }
 92: export function canColorHighlight(
 93:   editor: Editor | null,
 94:   mode: HighlightMode = "mark"
 95: ): boolean {
 96:   if (!editor || !editor.isEditable) return false
 97:   if (mode === "mark") {
 98:     if (
 99:       !isMarkInSchema("highlight", editor) ||
100:       isNodeTypeSelected(editor, ["image"])
101:     )
102:       return false
103:     return editor.can().setMark("highlight")
104:   } else {
105:     if (!isExtensionAvailable(editor, ["nodeBackground"])) return false
106:     try {
107:       return editor.can().toggleNodeBackgroundColor("test")
108:     } catch {
109:       return false
110:     }
111:   }
112: }
113: export function isColorHighlightActive(
114:   editor: Editor | null,
115:   highlightColor?: string,
116:   mode: HighlightMode = "mark"
117: ): boolean {
118:   if (!editor || !editor.isEditable) return false
119:   if (mode === "mark") {
120:     return highlightColor
121:       ? editor.isActive("highlight", { color: highlightColor })
122:       : editor.isActive("highlight")
123:   } else {
124:     if (!highlightColor) return false
125:     try {
126:       const { state } = editor
127:       const { selection } = state
128:       const $pos = selection.$anchor
129:       for (let depth = $pos.depth; depth >= 0; depth--) {
130:         const node = $pos.node(depth)
131:         if (node && node.attrs?.backgroundColor === highlightColor) {
132:           return true
133:         }
134:       }
135:       return false
136:     } catch {
137:       return false
138:     }
139:   }
140: }
141: export function removeHighlight(
142:   editor: Editor | null,
143:   mode: HighlightMode = "mark"
144: ): boolean {
145:   if (!editor || !editor.isEditable) return false
146:   if (!canColorHighlight(editor, mode)) return false
147:   if (mode === "mark") {
148:     return editor.chain().focus().unsetMark("highlight").run()
149:   } else {
150:     return editor.chain().focus().unsetNodeBackgroundColor().run()
151:   }
152: }
153: export function shouldShowButton(props: {
154:   editor: Editor | null
155:   hideWhenUnavailable: boolean
156:   mode: HighlightMode
157: }): boolean {
158:   const { editor, hideWhenUnavailable, mode } = props
159:   if (!editor || !editor.isEditable) return false
160:   if (mode === "mark") {
161:     if (!isMarkInSchema("highlight", editor)) return false
162:   } else {
163:     if (!isExtensionAvailable(editor, ["nodeBackground"])) return false
164:   }
165:   if (hideWhenUnavailable && !editor.isActive("code")) {
166:     return canColorHighlight(editor, mode)
167:   }
168:   return true
169: }
170: export function useColorHighlight(config: UseColorHighlightConfig) {
171:   const {
172:     editor: providedEditor,
173:     label,
174:     highlightColor,
175:     hideWhenUnavailable = false,
176:     mode = "mark",
177:     onApplied,
178:   } = config
179:   const { editor } = useTiptapEditor(providedEditor)
180:   const isMobile = useIsBreakpoint()
181:   const [isVisible, setIsVisible] = useState<boolean>(true)
182:   const canColorHighlightState = canColorHighlight(editor, mode)
183:   const isActive = isColorHighlightActive(editor, highlightColor, mode)
184:   useEffect(() => {
185:     if (!editor) return
186:     const handleSelectionUpdate = () => {
187:       setIsVisible(shouldShowButton({ editor, hideWhenUnavailable, mode }))
188:     }
189:     handleSelectionUpdate()
190:     editor.on("selectionUpdate", handleSelectionUpdate)
191:     return () => {
192:       editor.off("selectionUpdate", handleSelectionUpdate)
193:     }
194:   }, [editor, hideWhenUnavailable, mode])
195:   const handleColorHighlight = useCallback(() => {
196:     if (!editor || !canColorHighlightState || !highlightColor || !label)
197:       return false
198:     if (mode === "mark") {
199:       if (editor.state.storedMarks) {
200:         const highlightMarkType = editor.schema.marks.highlight
201:         if (highlightMarkType) {
202:           editor.view.dispatch(
203:             editor.state.tr.removeStoredMark(highlightMarkType)
204:           )
205:         }
206:       }
207:       setTimeout(() => {
208:         const success = editor
209:           .chain()
210:           .focus()
211:           .toggleMark("highlight", { color: highlightColor })
212:           .run()
213:         if (success) {
214:           onApplied?.({ color: highlightColor, label, mode })
215:         }
216:         return success
217:       }, 0)
218:       return true
219:     } else {
220:       const success = editor
221:         .chain()
222:         .focus()
223:         .toggleNodeBackgroundColor(highlightColor)
224:         .run()
225:       if (success) {
226:         onApplied?.({ color: highlightColor, label, mode })
227:       }
228:       return success
229:     }
230:   }, [canColorHighlightState, highlightColor, editor, label, onApplied, mode])
231:   const handleRemoveHighlight = useCallback(() => {
232:     const success = removeHighlight(editor, mode)
233:     if (success) {
234:       onApplied?.({ color: "", label: "Remove highlight", mode })
235:     }
236:     return success
237:   }, [editor, onApplied, mode])
238:   useHotkeys(
239:     COLOR_HIGHLIGHT_SHORTCUT_KEY,
240:     (event) => {
241:       event.preventDefault()
242:       handleColorHighlight()
243:     },
244:     {
245:       enabled: isVisible && canColorHighlightState,
246:       enableOnContentEditable: !isMobile,
247:       enableOnFormTags: true,
248:     }
249:   )
250:   return {
251:     isVisible,
252:     isActive,
253:     handleColorHighlight,
254:     handleRemoveHighlight,
255:     canColorHighlight: canColorHighlightState,
256:     label: label || `Highlight`,
257:     shortcutKeys: COLOR_HIGHLIGHT_SHORTCUT_KEY,
258:     Icon: HighlighterIcon,
259:     mode,
260:   }
261: }
</file>

