<file path="apps/api/src/modules/inventory/inventory.service.ts">
  1: import {
  2:   BadRequestException,
  3:   Injectable,
  4:   NotFoundException,
  5: } from '@nestjs/common';
  6: import { Prisma, Inventory } from '@prisma/client';
  7: import { PrismaService } from '../prisma/prisma.service';
  8: import { ListInventoryDto } from './dto/list-inventory.dto';
  9: import { BulkSetInventoryDto } from './dto/bulk-set-inventory.dto';
 10: import { UpdateInventoryDto } from './dto/update-inventory.dto';
 11: function toDateOnly(d: string) {
 12:   return new Date(`${d}T00:00:00.000Z`);
 13: }
 14: function eachDay(from: Date, to: Date) {
 15:   const days: Date[] = [];
 16:   const cur = new Date(from);
 17:   while (cur <= to) {
 18:     days.push(new Date(cur));
 19:     cur.setUTCDate(cur.getUTCDate() + 1);
 20:   }
 21:   return days;
 22: }
 23: @Injectable()
 24: export class InventoryService {
 25:   constructor(private prisma: PrismaService) {}
 26:   private async assertHotelAccess(hotelId: string, userId: string) {
 27:     const hotel = await this.prisma.hotel.findUnique({
 28:       where: { id: hotelId },
 29:       select: { id: true, ownerId: true },
 30:     });
 31:     if (!hotel) throw new NotFoundException('Hotel not found');
 32:     if (hotel.ownerId === userId) return;
 33:     const member = await this.prisma.hotelMember.findUnique({
 34:       where: { hotelId_userId: { hotelId, userId } },
 35:       select: { userId: true },
 36:     });
 37:     if (!member) throw new BadRequestException('No access to this hotel');
 38:   }
 39:   async list(hotelId: string, userId: string, q: ListInventoryDto) {
 40:     await this.assertHotelAccess(hotelId, userId);
 41:     const from = toDateOnly(q.from);
 42:     const to = toDateOnly(q.to);
 43:     if (from > to) throw new BadRequestException('from must be <= to');
 44:     const where: Prisma.InventoryWhereInput = {
 45:       hotelId,
 46:       deletedAt: null,
 47:       date: { gte: from, lte: to },
 48:       ...(q.roomTypeId ? { roomTypeId: q.roomTypeId } : {}),
 49:       ...(q.includeStopped ? {} : { stopSell: false }),
 50:     };
 51:     const items = await this.prisma.inventory.findMany({
 52:       where,
 53:       orderBy: [{ roomTypeId: 'asc' }, { date: 'asc' }],
 54:       include: { roomType: { select: { id: true, name: true } } },
 55:     });
 56:     return { from: q.from, to: q.to, items };
 57:   }
 58:   async bulkSet(hotelId: string, userId: string, dto: BulkSetInventoryDto) {
 59:     await this.assertHotelAccess(hotelId, userId);
 60:     const from = toDateOnly(dto.from);
 61:     const to = toDateOnly(dto.to);
 62:     if (from > to) throw new BadRequestException('from must be <= to');
 63:     const rt = await this.prisma.roomType.findFirst({
 64:       where: { id: dto.roomTypeId, hotelId },
 65:       select: { id: true },
 66:     });
 67:     if (!rt) throw new NotFoundException('RoomType not found in this hotel');
 68:     const days = eachDay(from, to);
 69:     const ops = days.map((date) =>
 70:       this.prisma.inventory.upsert({
 71:         where: {
 72:           roomTypeId_hotelId_date: {
 73:             roomTypeId: dto.roomTypeId,
 74:             hotelId,
 75:             date,
 76:           },
 77:         },
 78:         create: {
 79:           hotelId,
 80:           roomTypeId: dto.roomTypeId,
 81:           date,
 82:           ...(dto.totalRooms !== undefined
 83:             ? { totalRooms: dto.totalRooms }
 84:             : {}),
 85:           ...(dto.availableRooms !== undefined
 86:             ? { availableRooms: dto.availableRooms }
 87:             : {}),
 88:           stopSell: dto.stopSell ?? false,
 89:         },
 90:         update: {
 91:           deletedAt: null,
 92:           ...(dto.totalRooms !== undefined
 93:             ? { totalRooms: dto.totalRooms }
 94:             : {}),
 95:           ...(dto.availableRooms !== undefined
 96:             ? { availableRooms: dto.availableRooms }
 97:             : {}),
 98:           ...(dto.stopSell !== undefined ? { stopSell: dto.stopSell } : {}),
 99:         },
100:       }),
101:     );
102:     const result = await this.prisma.$transaction(ops);
103:     return { count: result.length };
104:   }
105:   async updateOne(
106:     hotelId: string,
107:     userId: string,
108:     id: string,
109:     dto: UpdateInventoryDto,
110:   ) {
111:     await this.assertHotelAccess(hotelId, userId);
112:     const inv = await this.prisma.inventory.findFirst({
113:       where: { id, hotelId, deletedAt: null },
114:       select: { id: true },
115:     });
116:     if (!inv) throw new NotFoundException('Inventory not found');
117:     return this.prisma.inventory.update({
118:       where: { id },
119:       data: {
120:         ...(dto.totalRooms !== undefined ? { totalRooms: dto.totalRooms } : {}),
121:         ...(dto.availableRooms !== undefined
122:           ? { availableRooms: dto.availableRooms }
123:           : {}),
124:         ...(dto.stopSell !== undefined ? { stopSell: dto.stopSell } : {}),
125:       },
126:     });
127:   }
128:   async softDelete(hotelId: string, userId: string, id: string) {
129:     await this.assertHotelAccess(hotelId, userId);
130:     const inv = await this.prisma.inventory.findFirst({
131:       where: { id, hotelId, deletedAt: null },
132:       select: { id: true },
133:     });
134:     if (!inv) throw new NotFoundException('Inventory not found');
135:     await this.prisma.inventory.update({
136:       where: { id },
137:       data: { deletedAt: new Date() },
138:     });
139:     return { deleted: true };
140:   }
141: }
</file>

