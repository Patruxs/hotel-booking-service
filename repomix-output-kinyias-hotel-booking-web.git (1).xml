 1: import { Injectable, NotFoundException, BadRequestException } from '@nestjs/common';
 2: import { Prisma } from '@prisma/client';
 3: import { CreatePermissionDto } from '../permissions/dto/create-permission.dto';
 4: import { UpdatePermissionDto } from '../permissions/dto/update-permission.dto';
 5: import { PrismaService } from '../prisma/prisma.service';
 6: import { ListPermissionsQueryDto } from './dto/list-permissions-query.dto';
 7: @Injectable()
 8: export class PermissionsService {
 9:   constructor(private prisma: PrismaService) {}
10:   create(dto: CreatePermissionDto) {
11:     return this.prisma.permission.create({ data: dto });
12:   }
13:   async listPermissions(query: ListPermissionsQueryDto = {}) {
14:   const {
15:     q,
16:     limit = 50,
17:     offset = 0,
18:     sortBy = 'name',
19:     order = 'asc',
20:   } = query;
21:   const MAX_LIMIT = 200;
22:   const take = Math.min(Math.max(0, limit), MAX_LIMIT);
23:   const skip = Math.max(0, offset);
24:   const allowedSort: Record<string, true> = {
25:     id: true,
26:     name: true,
27:     createdAt: true,
28:     updatedAt: true,
29:   };
30:   const sanitizedSort = allowedSort[sortBy] ? sortBy : 'name';
31:   const sanitizedOrder: Prisma.SortOrder =
32:     order?.toLowerCase() === 'desc' ? 'desc' : 'asc';
33:   const where: Prisma.PermissionWhereInput = {
34:     AND: [
35:       q
36:         ? {
37:             OR: [
38:               { name: { contains: q, mode: Prisma.QueryMode.insensitive } },
39:               {
40:                 description: {
41:                   contains: q,
42:                   mode: Prisma.QueryMode.insensitive,
43:                 },
44:               },
45:             ],
46:           }
47:         : {},
48:     ],
49:   };
50:   const [items, total] = await this.prisma.$transaction([
51:     this.prisma.permission.findMany({
52:       where,
53:       select: {
54:         id: true,
55:         name: true,
56:         description: true,
57:       },
58:       orderBy: { [sanitizedSort]: sanitizedOrder },
59:       skip,
60:       take,
61:     }),
62:     this.prisma.permission.count({ where }),
63:   ]);
64:   return {
65:     data: items,
66:     meta: {
67:       limit: take,
68:       offset: skip,
69:       total,
70:     },
71:   };
72: }
73:   async findOne(id: string) {
74:     const item = await this.prisma.permission.findUnique({ where: { id } });
75:     if (!item) throw new NotFoundException('Permission not found');
76:     return item;
77:   }
78:   async update(id: string, dto: UpdatePermissionDto) {
79:     await this.findOne(id);
80:     return this.prisma.permission.update({ where: { id }, data: dto });
81:   }
82:   async remove(id: string) {
83:     await this.findOne(id);
84:     return this.prisma.$transaction([
85:       this.prisma.rolePermission.deleteMany({ where: { permissionId: id } }),
86:       this.prisma.permission.delete({ where: { id } }),
87:     ]);
88:   }
89: }
</file>

