<file path="apps/api/src/common/filters/prisma-exception.filter.ts">
 1: import {
 2:   ArgumentsHost,
 3:   Catch,
 4:   ExceptionFilter,
 5:   HttpStatus,
 6: } from '@nestjs/common';
 7: import { Prisma } from '@prisma/client';
 8: @Catch(Prisma.PrismaClientKnownRequestError)
 9: export class PrismaExceptionFilter implements ExceptionFilter {
10:   catch(exception: Prisma.PrismaClientKnownRequestError, host: ArgumentsHost) {
11:     const ctx = host.switchToHttp();
12:     const response = ctx.getResponse();
13:     let status = HttpStatus.BAD_REQUEST;
14:     let message = exception.message;
15:     if (exception.code === 'P2002') {
16:       status = HttpStatus.CONFLICT;
17:       message = `Unique constraint failed on fields: ${(exception.meta?.target as string[])?.join(', ')}`;
18:     } else if (exception.code === 'P2025') {
19:       status = HttpStatus.NOT_FOUND;
20:       message = 'Record not found';
21:     }
22:     response
23:       .status(status)
24:       .json({ statusCode: status, error: 'PrismaError', message });
25:   }
26: }
</file>

