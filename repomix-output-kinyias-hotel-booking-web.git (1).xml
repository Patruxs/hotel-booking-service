274:             <span className="tiptap-image-upload-subtext">
275:               {formatFileSize(fileItem.file.size)}
276:             </span>
277:           </div>
278:         </div>
279:         <div className="tiptap-image-upload-actions">
280:           {fileItem.status === "uploading" && (
281:             <span className="tiptap-image-upload-progress-text">
282:               {fileItem.progress}%
283:             </span>
284:           )}
285:           <Button
286:             type="button"
287:             data-style="ghost"
288:             onClick={(e) => {
289:               e.stopPropagation()
290:               onRemove()
291:             }}
292:           >
293:             <CloseIcon className="tiptap-button-icon" />
294:           </Button>
295:         </div>
296:       </div>
297:     </div>
298:   )
299: }
300: const DropZoneContent: React.FC<{ maxSize: number; limit: number }> = ({
301:   maxSize,
302:   limit,
303: }) => (
304:   <>
305:     <div className="tiptap-image-upload-dropzone">
306:       <FileIcon />
307:       <FileCornerIcon />
308:       <div className="tiptap-image-upload-icon-container">
309:         <CloudUploadIcon />
310:       </div>
311:     </div>
312:     <div className="tiptap-image-upload-content">
313:       <span className="tiptap-image-upload-text">
314:         <em>Click to upload</em> or drag and drop
315:       </span>
316:       <span className="tiptap-image-upload-subtext">
317:         Maximum {limit} file{limit === 1 ? "" : "s"}, {maxSize / 1024 / 1024}MB
318:         each.
319:       </span>
320:     </div>
321:   </>
322: )
323: export const ImageUploadNode: React.FC<NodeViewProps> = (props) => {
324:   const { accept, limit, maxSize } = props.node.attrs
325:   const inputRef = useRef<HTMLInputElement>(null)
326:   const extension = props.extension
327:   const uploadOptions: UploadOptions = {
328:     maxSize,
329:     limit,
330:     accept,
331:     upload: extension.options.upload,
332:     onSuccess: extension.options.onSuccess,
333:     onError: extension.options.onError,
334:   }
335:   const { fileItems, uploadFiles, removeFileItem, clearAllFiles } =
336:     useFileUpload(uploadOptions)
337:   const handleUpload = async (files: File[]) => {
338:     const urls = await uploadFiles(files)
339:     if (urls.length > 0) {
340:       const pos = props.getPos()
341:       if (isValidPosition(pos)) {
342:         const imageNodes = urls.map((url, index) => {
343:           const filename =
344:             files[index]?.name.replace(/\.[^/.]+$/, "") || "unknown"
345:           return {
346:             type: extension.options.type,
347:             attrs: {
348:               ...extension.options,
349:               src: url,
350:               alt: filename,
351:               title: filename,
352:             },
353:           }
354:         })
355:         props.editor
356:           .chain()
357:           .focus()
358:           .deleteRange({ from: pos, to: pos + props.node.nodeSize })
359:           .insertContentAt(pos, imageNodes)
360:           .run()
361:         focusNextNode(props.editor)
362:       }
363:     }
364:   }
365:   const handleChange = (e: React.ChangeEvent<HTMLInputElement>) => {
366:     const files = e.target.files
367:     if (!files || files.length === 0) {
368:       extension.options.onError?.(new Error("No file selected"))
369:       return
370:     }
371:     handleUpload(Array.from(files))
372:   }
373:   const handleClick = () => {
374:     if (inputRef.current && fileItems.length === 0) {
375:       inputRef.current.value = ""
376:       inputRef.current.click()
377:     }
378:   }
379:   const hasFiles = fileItems.length > 0
380:   return (
381:     <NodeViewWrapper
382:       className="tiptap-image-upload"
383:       tabIndex={0}
384:       onClick={handleClick}
385:     >
386:       {!hasFiles && (
387:         <ImageUploadDragArea onFile={handleUpload}>
388:           <DropZoneContent maxSize={maxSize} limit={limit} />
389:         </ImageUploadDragArea>
390:       )}
391:       {hasFiles && (
392:         <div className="tiptap-image-upload-previews">
393:           {fileItems.length > 1 && (
394:             <div className="tiptap-image-upload-header">
395:               <span>Uploading {fileItems.length} files</span>
396:               <Button
397:                 type="button"
398:                 data-style="ghost"
399:                 onClick={(e) => {
400:                   e.stopPropagation()
401:                   clearAllFiles()
402:                 }}
403:               >
404:                 Clear All
405:               </Button>
406:             </div>
407:           )}
408:           {fileItems.map((fileItem) => (
409:             <ImageUploadPreview
410:               key={fileItem.id}
411:               fileItem={fileItem}
412:               onRemove={() => removeFileItem(fileItem.id)}
413:             />
414:           ))}
415:         </div>
416:       )}
417:       <input
418:         ref={inputRef}
419:         name="file"
420:         accept={accept}
421:         type="file"
422:         multiple={limit > 1}
423:         onChange={handleChange}
424:         onClick={(e: React.MouseEvent<HTMLInputElement>) => e.stopPropagation()}
425:       />
426:     </NodeViewWrapper>
427:   )
428: }
</file>

