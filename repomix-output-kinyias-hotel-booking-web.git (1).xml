129:                   </SelectTrigger>
130:                   <SelectContent>
131:                     {Array.from({ length: 5 }, (_, i) => currentYear - i).map(
132:                       (year) => (
133:                         <SelectItem key={year} value={year.toString()}>
134:                           {year}
135:                         </SelectItem>
136:                       )
137:                     )}
138:                   </SelectContent>
139:                 </Select>
140:               ) : (
141:                 <>
142:                   {}
143:                   <Popover>
144:                     <PopoverTrigger asChild>
145:                       <Button
146:                         variant="outline"
147:                         className="w-[280px] justify-start text-left font-normal"
148:                       >
149:                         <CalendarIcon className="mr-2 h-4 w-4" />
150:                         {dateRange?.from ? (
151:                           dateRange.to ? (
152:                             <>
153:                               {format(dateRange.from, 'dd/MM/yyyy')} -{' '}
154:                               {format(dateRange.to, 'dd/MM/yyyy')}
155:                             </>
156:                           ) : (
157:                             format(dateRange.from, 'dd/MM/yyyy')
158:                           )
159:                         ) : (
160:                           <span>Chọn khoảng thời gian</span>
161:                         )}
162:                       </Button>
163:                     </PopoverTrigger>
164:                     <PopoverContent className="w-auto p-0" align="start">
165:                       <Calendar
166:                         initialFocus
167:                         mode="range"
168:                         defaultMonth={dateRange?.from}
169:                         selected={{
170:                           from: dateRange?.from,
171:                           to: dateRange?.to,
172:                         }}
173:                         onSelect={(range) => {
174:                           setDateRange({
175:                             from: range?.from,
176:                             to: range?.to,
177:                           });
178:                         }}
179:                         numberOfMonths={2}
180:                       />
181:                     </PopoverContent>
182:                   </Popover>
183:                   {}
184:                   <Select
185:                     value={groupBy}
186:                     onValueChange={(value: RevenueGroupBy) => setGroupBy(value)}
187:                   >
188:                     <SelectTrigger className="w-[120px]">
189:                       <SelectValue placeholder="By group" />
190:                     </SelectTrigger>
191:                     <SelectContent>
192:                       <SelectItem value="week">Week</SelectItem>
193:                       <SelectItem value="month">Month</SelectItem>
194:                     </SelectContent>
195:                   </Select>
196:                 </>
197:               )}
198:             </div>
199:           </div>
200:         </CardHeader>
201:         <CardContent>
202:           {isLoading ? (
203:             <div className="flex items-center justify-center h-[400px]">
204:               <p className="text-muted-foreground">Loading...</p>
205:             </div>
206:           ) : (
207:             <ResponsiveContainer width="100%" height={400}>
208:               <BarChart data={chartData}>
209:                 <CartesianGrid strokeDasharray="3 3" vertical={false} />
210:                 <XAxis
211:                   dataKey="name"
212:                   tickLine={false}
213:                   axisLine={false}
214:                   fontSize={12}
215:                   tickMargin={8}
216:                   interval={0}
217:                   angle={viewType === 'range' ? -45 : 0}
218:                   textAnchor={viewType === 'range' ? 'end' : 'middle'}
