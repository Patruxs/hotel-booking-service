 65:   placement = "top",
 66:   open: controlledOpen,
 67:   onOpenChange: setControlledOpen,
 68:   delay = 600,
 69:   closeDelay = 0,
 70: }: Omit<TooltipProviderProps, "children"> = {}) {
 71:   const [uncontrolledOpen, setUncontrolledOpen] = useState<boolean>(initialOpen)
 72:   const open = controlledOpen ?? uncontrolledOpen
 73:   const setOpen = setControlledOpen ?? setUncontrolledOpen
 74:   const data = useFloating({
 75:     placement,
 76:     open,
 77:     onOpenChange: setOpen,
 78:     whileElementsMounted: autoUpdate,
 79:     middleware: [
 80:       offset(4),
 81:       flip({
 82:         crossAxis: placement.includes("-"),
 83:         fallbackAxisSideDirection: "start",
 84:         padding: 4,
 85:       }),
 86:       shift({ padding: 4 }),
 87:     ],
 88:   })
 89:   const context = data.context
