 94:               Action ID:{' '}
 95:               <span className="font-medium text-foreground">{action?.id}</span>
 96:             </div>
 97:             <FormField
 98:               control={form.control}
 99:               name="permissionIds"
100:               render={({ field }) => {
101:                 const selectedIds = [
102:                   ...(field.value ?? []),
103:                   ...(action?.policies
104:                     .map((p) => p.permissionId)
105:                     .filter((id) => !removedBasePermissions.includes(id)) ??
106:                     []),
107:                 ];
108:                 const selectedPermissions =
109:                   permissions?.filter((p) => selectedIds.includes(p.id)) || [];
110:                 const filteredSuggestions =
111:                   permissions?.filter(
112:                     (p) =>
113:                       p.name.toLowerCase().includes(inputValue.toLowerCase()) &&
114:                       !selectedIds.includes(p.id)
115:                   ) || [];
116:                 const addPermission = (id: string) => {
117:                   field.onChange([...field.value, id]);
118:                   setInputValue('');
119:                   inputRef.current?.focus();
120:                 };
121:                 const removePermission = (id: string) => {
122:                   if (action?.policies.some((p) => p.permissionId === id)) {
123:                     setRemovedBasePermissions((prev) => [...prev, id]);
124:                   }
125:                   field.onChange(
126:                     field.value?.filter((pid) => pid !== id) ?? []
127:                   );
128:                 };
129:                 return (
130:                   <FormItem>
131:                     <FormLabel>Permissions</FormLabel>
132:                     <FormControl>
133:                       <div className="space-y-3">
134:                         {/* Display selected permissions as badges */}
135:                         {selectedPermissions.length > 0 && (
136:                           <div className="flex flex-wrap gap-2">
137:                             {selectedPermissions.map((permission) => (
138:                               <Badge
139:                                 key={permission.id}
140:                                 variant="secondary"
141:                                 className="cursor-pointer"
142:                                 onClick={() => removePermission(permission.id)}
143:                               >
144:                                 {permission.name} ✕
145:                               </Badge>
146:                             ))}
147:                           </div>
148:                         )}
149:                         {/* Autocomplete input with popover */}
150:                         <div className="relative">
151:                           <Input
152:                             ref={inputRef}
153:                             placeholder="Search permissions..."
154:                             value={inputValue}
155:                             onChange={(e) => {
156:                               setInputValue(e.target.value);
157:                               setOpenPopover(e.target.value.length > 0);
158:                             }}
159:                             onFocus={() => {
160:                               setOpenPopover(true);
161:                             }}
162:                             onBlur={() => {
163:                               setTimeout(() => setOpenPopover(false), 200);
164:                             }}
165:                             onKeyDown={(e) => {
166:                               if (e.key === 'Enter' && inputValue.trim()) {
167:                                 e.preventDefault();
168:                                 let found = permissions?.find(
169:                                   (p) =>
170:                                     p.name.toLowerCase() ===
171:                                     inputValue.toLowerCase()
172:                                 );
173:                                 if (!found && filteredSuggestions.length > 0) {
174:                                   found = filteredSuggestions[0];
175:                                 }
176:                                 if (!found && filteredSuggestions.length == 0) {
177:                                   toast.error('Permission not found');
178:                                 }
179:                                 if (found && !field.value.includes(found.id)) {
180:                                   addPermission(found.id);
181:                                 }
182:                               }
183:                               if (e.key === 'Escape') {
184:                                 setOpenPopover(false);
185:                               }
186:                             }}
187:                           />
188:                           {openPopover && filteredSuggestions.length > 0 && (
189:                             <div className="absolute z-50 w-full mt-1 rounded-md border bg-popover text-popover-foreground shadow-md outline-none animate-in">
190:                               <Command>
191:                                 <CommandList>
192:                                   {filteredSuggestions.map((permission) => (
193:                                     <CommandItem
194:                                       key={permission.id}
195:                                       onMouseDown={(e) => {
196:                                         e.preventDefault();
197:                                         addPermission(permission.id);
198:                                       }}
199:                                       className="cursor-pointer"
200:                                     >
201:                                       {permission.name}
202:                                     </CommandItem>
203:                                   ))}
204:                                 </CommandList>
205:                               </Command>
206:                             </div>
207:                           )}
208:                         </div>
