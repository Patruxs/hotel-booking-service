 60:   const yearlyQuery = useCommissionRevenueQuery(
 61:     viewType === 'year' ? { year: selectedYear.toString() } : undefined
 62:   );
 63:   const fromDateString = dateRange.from?.toISOString().split('T')[0] || null;
 64:   const toDateString = dateRange.to?.toISOString().split('T')[0] || null;
 65:   const rangeQuery = useCommissionRevenueQuery(
 66:     viewType === 'range' && fromDateString && toDateString
 67:       ? { from: fromDateString, to: toDateString }
 68:       : undefined
 69:   );
 70:   const chartData =
 71:     viewType === 'year'
 72:       ? (yearlyQuery.data as number[] | undefined)?.map((total, index) => ({
 73:           name: monthNames[index],
 74:           revenue: total,
 75:         })) || []
 76:       : (rangeQuery.data as { date: string; revenue: number }[] | undefined)
 77:           ?.reduce((acc, item) => {
 78:             const formattedDate = format(
 79:               new Date(item.date),
 80:               groupBy === 'month' ? 'MM/yyyy' : 'dd/MM/yyyy',
 81:               { locale: vi }
 82:             );
 83:             const existingItem = acc.find((i) => i.name === formattedDate);
 84:             if (existingItem) {
 85:               existingItem.revenue += item.revenue;
 86:             } else {
 87:               acc.push({
 88:                 name: formattedDate,
 89:                 revenue: item.revenue,
 90:               });
 91:             }
 92:             return acc;
 93:           }, [] as { name: string; revenue: number }[])
 94:           .sort((a, b) => {
 95:             const [aMonth, aYear] = a.name.split('/').reverse();
 96:             const [bMonth, bYear] = b.name.split('/').reverse();
 97:             const dateA = new Date(Number(aYear), Number(aMonth) - 1);
 98:             const dateB = new Date(Number(bYear), Number(bMonth) - 1);
 99:             return dateA.getTime() - dateB.getTime();
100:           }) || [];
101:   const isLoading = viewType === 'year' ? yearlyQuery.isLoading : rangeQuery.isLoading;
102:   return (
103:     <>
104:       <Card>
