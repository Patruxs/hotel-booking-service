<file path="apps/web/src/proxy.ts">
 1: import { NextRequest, NextResponse } from 'next/server';
 2: import { ROUTES } from './constants';
 3: const protectedRoutes = ['/admin', '/me'];
 4: export default async function proxy(req: NextRequest) {
 5:   const path = req.nextUrl.pathname;
 6:   const isProtectedRoute = protectedRoutes.some(
 7:     (route) => path.startsWith(route)
 8:   );
 9:   const accessToken = req.cookies.get('accessToken')?.value;
10:   if (isProtectedRoute && !accessToken) {
11:     return NextResponse.redirect(
12:       new URL(ROUTES.LOGIN, req.nextUrl)
13:     );
14:   }
15:   if(path.startsWith(ROUTES.LOGIN) && accessToken){
16:     return NextResponse.redirect(new URL(ROUTES.PROFILE, req.nextUrl));
17:   }
18:   return NextResponse.next();
19: }
</file>

