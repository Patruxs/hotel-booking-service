  1: "use client"
  2: import { useCallback, useEffect, useState } from "react"
  3: import type { Editor } from "@tiptap/react"
  4: import { NodeSelection, TextSelection } from "@tiptap/pm/state"
  5: import { useTiptapEditor } from "@/hooks/use-tiptap-editor"
  6: import { BlockquoteIcon } from "@/components/tiptap-icons/blockquote-icon"
  7: import {
  8:   findNodePosition,
  9:   isNodeInSchema,
 10:   isNodeTypeSelected,
 11:   isValidPosition,
 12:   selectionWithinConvertibleTypes,
 13: } from "@/lib/tiptap-utils"
 14: export const BLOCKQUOTE_SHORTCUT_KEY = "mod+shift+b"
 15: export interface UseBlockquoteConfig {
 16:   editor?: Editor | null
 17:   hideWhenUnavailable?: boolean
 18:   onToggled?: () => void
 19: }
 20: export function canToggleBlockquote(
 21:   editor: Editor | null,
 22:   turnInto: boolean = true
 23: ): boolean {
 24:   if (!editor || !editor.isEditable) return false
 25:   if (
 26:     !isNodeInSchema("blockquote", editor) ||
 27:     isNodeTypeSelected(editor, ["image"])
 28:   )
 29:     return false
 30:   if (!turnInto) {
 31:     return editor.can().toggleWrap("blockquote")
 32:   }
 33:   if (
 34:     !selectionWithinConvertibleTypes(editor, [
 35:       "paragraph",
 36:       "heading",
 37:       "bulletList",
 38:       "orderedList",
 39:       "taskList",
 40:       "blockquote",
 41:       "codeBlock",
 42:     ])
 43:   )
 44:     return false
 45:   return editor.can().toggleWrap("blockquote") || editor.can().clearNodes()
 46: }
 47: export function toggleBlockquote(editor: Editor | null): boolean {
 48:   if (!editor || !editor.isEditable) return false
 49:   if (!canToggleBlockquote(editor)) return false
 50:   try {
 51:     const view = editor.view
 52:     let state = view.state
 53:     let tr = state.tr
 54:     if (state.selection.empty || state.selection instanceof TextSelection) {
 55:       const pos = findNodePosition({
 56:         editor,
 57:         node: state.selection.$anchor.node(1),
 58:       })?.pos
 59:       if (!isValidPosition(pos)) return false
 60:       tr = tr.setSelection(NodeSelection.create(state.doc, pos))
 61:       view.dispatch(tr)
 62:       state = view.state
 63:     }
 64:     const selection = state.selection
 65:     let chain = editor.chain().focus()
 66:     if (selection instanceof NodeSelection) {
 67:       const firstChild = selection.node.firstChild?.firstChild
 68:       const lastChild = selection.node.lastChild?.lastChild
 69:       const from = firstChild
 70:         ? selection.from + firstChild.nodeSize
 71:         : selection.from + 1
 72:       const to = lastChild
 73:         ? selection.to - lastChild.nodeSize
 74:         : selection.to - 1
 75:       const resolvedFrom = state.doc.resolve(from)
 76:       const resolvedTo = state.doc.resolve(to)
 77:       chain = chain
 78:         .setTextSelection(TextSelection.between(resolvedFrom, resolvedTo))
 79:         .clearNodes()
 80:     }
 81:     const toggle = editor.isActive("blockquote")
 82:       ? chain.lift("blockquote")
 83:       : chain.wrapIn("blockquote")
 84:     toggle.run()
 85:     editor.chain().focus().selectTextblockEnd().run()
 86:     return true
 87:   } catch {
 88:     return false
 89:   }
 90: }
 91: export function shouldShowButton(props: {
 92:   editor: Editor | null
 93:   hideWhenUnavailable: boolean
 94: }): boolean {
 95:   const { editor, hideWhenUnavailable } = props
 96:   if (!editor || !editor.isEditable) return false
 97:   if (!isNodeInSchema("blockquote", editor)) return false
 98:   if (hideWhenUnavailable && !editor.isActive("code")) {
 99:     return canToggleBlockquote(editor)
100:   }
101:   return true
102: }
103: export function useBlockquote(config?: UseBlockquoteConfig) {
104:   const {
105:     editor: providedEditor,
106:     hideWhenUnavailable = false,
107:     onToggled,
108:   } = config || {}
109:   const { editor } = useTiptapEditor(providedEditor)
110:   const [isVisible, setIsVisible] = useState<boolean>(true)
111:   const canToggle = canToggleBlockquote(editor)
112:   const isActive = editor?.isActive("blockquote") || false
113:   useEffect(() => {
114:     if (!editor) return
115:     const handleSelectionUpdate = () => {
116:       setIsVisible(shouldShowButton({ editor, hideWhenUnavailable }))
117:     }
118:     handleSelectionUpdate()
119:     editor.on("selectionUpdate", handleSelectionUpdate)
120:     return () => {
121:       editor.off("selectionUpdate", handleSelectionUpdate)
122:     }
123:   }, [editor, hideWhenUnavailable])
124:   const handleToggle = useCallback(() => {
125:     if (!editor) return false
126:     const success = toggleBlockquote(editor)
127:     if (success) {
128:       onToggled?.()
129:     }
130:     return success
131:   }, [editor, onToggled])
132:   return {
133:     isVisible,
134:     isActive,
135:     handleToggle,
136:     canToggle,
137:     label: "Blockquote",
138:     shortcutKeys: BLOCKQUOTE_SHORTCUT_KEY,
139:     Icon: BlockquoteIcon,
140:   }
141: }
</file>

