 22: } from "@/features/amentites/mutations";
 23: import { amenityFormSchema, AmenityFormSchema } from "@/features/amentites/validator";
 24: export default function AmenityPage() {
 25:   const params = useParams();
 26:   const id = params.id as string;
 27:   const isEditing = id !== "new";
 28:   const router = useRouter();
 29:   const { data: amenity, isLoading: isLoadingAmenity } = useGetAmenityByIdQuery(id, isEditing);
 30:   const createMutation = useCreateAmenityMutation();
 31:   const updateMutation = useUpdateAmenityMutation(id);
 32:   const form = useForm<AmenityFormSchema>({
 33:     resolver: zodResolver(amenityFormSchema),
 34:     defaultValues: {
 35:       label: "",
 36:       key: "",
 37:     },
 38:   });
 39:   useEffect(() => {
 40:     if (amenity) {
 41:       form.reset({
 42:         label: amenity.label,
 43:         key: amenity.key,
 44:       });
 45:     }
 46:   }, [amenity, form]);
 47:   const onSubmit = (data: AmenityFormSchema) => {
 48:     if (isEditing) {
 49:       updateMutation.mutate(data);
 50:     } else {
 51:       createMutation.mutate(data);
 52:     }
 53:   };
 54:   const isLoading = isLoadingAmenity && isEditing;
 55:   const isSaving = createMutation.isPending || updateMutation.isPending;
 56:   if (isLoading) {
 57:     return (
 58:       <div className="flex items-center justify-center h-full">
 59:         <Loader2 className="w-8 h-8 animate-spin" />
 60:       </div>
 61:     );
 62:   }
 63:   return (
 64:     <div className="p-6">
 65:       <div className="flex items-center justify-between mb-8">
 66:         <h1 className="text-2xl font-bold">
 67:           {isEditing ? "Edit Amenity" : "Create Amenity"}
 68:         </h1>
 69:       </div>
 70:       <Form {...form}>
 71:         <form onSubmit={form.handleSubmit(onSubmit)} className="space-y-8 w-full">
 72:           <FormField
 73:             control={form.control}
 74:             name="label"
 75:             render={({ field }) => (
 76:               <FormItem>
 77:                 <FormLabel>Label</FormLabel>
 78:                 <FormControl>
 79:                   <Input placeholder="Wifi, Pool, etc." {...field} />
 80:                 </FormControl>
 81:                 <FormMessage />
 82:               </FormItem>
 83:             )}
 84:           />
 85:           <FormField
 86:             control={form.control}
 87:             name="key"
 88:             render={({ field }) => (
 89:               <FormItem>
 90:                 <FormLabel>Icon Key</FormLabel>
 91:                 <FormControl>
 92:                     <div className="space-y-4">
 93:                         <Input placeholder="Select an icon below" {...field} readOnly />
 94:                         <div className="flex justify-end gap-4">
 95:                             <Button
 96:                             type="button"
 97:                             variant="outline"
 98:                             onClick={() => router.back()}
 99:                             disabled={isSaving}
100:                             >
101:                             Cancel
102:                             </Button>
103:                             <Button type="submit" disabled={isSaving}>
104:                             {isSaving && <Loader2 className="w-4 h-4 mr-2 animate-spin" />}
105:                             {isEditing ? "Update" : "Create"}
106:                             </Button>
107:                         </div>
108:                         <IconExplorer
