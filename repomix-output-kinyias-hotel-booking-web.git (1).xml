 2: import { NestFactory } from '@nestjs/core';
 3: import { AppModule } from './app.module';
 4: import { PrismaExceptionFilter } from './common/filters/prisma-exception.filter';
 5: import cookieParser from 'cookie-parser';
 6: import { ValidationPipe } from '@nestjs/common';
 7: let cachedApp: any = null;
 8: async function createApp() {
 9:   if (cachedApp) return cachedApp;
10:   const app = await NestFactory.create(AppModule);
11:   app.use(cookieParser());
12:   app.useGlobalFilters(new PrismaExceptionFilter());
13:   app.useGlobalPipes(new ValidationPipe({ whitelist: true }));
14:   app.enableCors({
15:     origin: true,
16:     credentials: true,
17:   });
18:   app.setGlobalPrefix('api/v1');
19:   await app.init();
20:   cachedApp = app.getHttpAdapter().getInstance();
21:   return cachedApp;
22: }
23: const handler = async (req: any, res: any) => {
24:   const app = await createApp();
25:   return app(req, res);
26: };
27: if (process.env.NODE_ENV !== 'production') {
28:   createApp().then((app) => {
29:     const port = process.env.PORT ?? 3000;
30:     app.listen(port, () =>
31:       console.log(`🚀 Dev server running on http://localhost:${port}`),
32:     );
33:   });
34: }
35: export default handler;
