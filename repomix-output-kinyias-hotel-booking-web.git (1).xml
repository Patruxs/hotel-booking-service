157:                         alt={hotel.name}
158:                         fill
159:                         className="object-cover group-hover:scale-105 transition-transform duration-500"
160:                       />
161:                     </Link>
162:                     </div>
163:                     {}
164:                     <div className="flex-1 p-6 flex flex-col justify-between">
165:                       <div>
166:                         {}
167:                         <div className="flex justify-between items-start mb-2">
168:                           <div>
169:                             <Link href={`/hotels/${hotel.id}`}>
170:                             <h3 className="text-xl font-bold text-gray-900 group-hover:text-primary transition-colors">
171:                               {hotel.name}
172:                             </h3>
173:                             </Link>
174:                           </div>
175:                         </div>
176:                         {}
177:                         <div className="flex items-center gap-1 text-gray-500 text-sm mb-4">
178:                           <MapPin className="w-4 h-4" />
179:                           <span>{hotel.address}</span>
180:                         </div>
181:                        <div className="text-gray-600 text-sm line-clamp-2">
182:                           <div dangerouslySetInnerHTML={{ __html: hotel.description! }} />
183:                        </div>
184:                       </div>
185:                       {}
186:                       <div className="flex items-end justify-between mt-4 pt-4 border-t border-gray-50">
187:                          <div className="flex flex-col">
188:                             <span className="text-xs text-gray-500">From</span>
189:                             <div className="flex items-baseline gap-1">
190:                                <span className="text-2xl font-bold text-primary">{formatCurrency(hotel.minPrice ?? 0)}</span>
191:                                <span className="text-sm text-gray-500">/night</span>
192:                             </div>
193:                          </div>
194:                          <Link href={`/hotels/${hotel.id}`}>
195:                          <Button className="bg-primary hover:bg-primary/90 text-primary-foreground min-w-[120px]">
196:                            View Details
197:                          </Button>
198:                          </Link>
199:                       </div>
200:                     </div>
201:                   </div>
