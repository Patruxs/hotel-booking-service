 4: import Link from 'next/link';
 5: import { toast } from 'react-hot-toast';
 6: import { Button } from '@/components/ui/button';
 7: import { NewsForm } from '@/features/news/components/NewsForm';
 8: import { useCreateNewsMutation, useUpdateNewsMutation } from '@/features/news/mutations';
 9: import { useNewsDetailQuery } from '@/features/news/queries';
10: import { NewsFormValues } from '@/features/news/validator';
11: import { CreateNewsRequest, UpdateNewsRequest } from '@/features/news/types';
12: export default function AdminNewsDetailPage() {
13:   const params = useParams();
14:   const router = useRouter();
15:   const newsId = params.news_id as string;
16:   const isEditing = !!newsId && newsId !== 'new';
17:   const { data: news, isLoading, isError } = useNewsDetailQuery(newsId);
18:   const createMutation = useCreateNewsMutation();
19:   const updateMutation = useUpdateNewsMutation();
20:   const isSaving = createMutation.isPending || updateMutation.isPending;
21:   if (isEditing && isLoading) {
22:     return <div className="p-6">Loading...</div>;
23:   }
24:   if (isEditing && isError) {
25:     return (
26:       <div className="p-6">
27:         <h1 className="text-2xl font-bold text-red-500">Error loading news</h1>
28:         <Button onClick={() => router.push('/admin/news')} className="mt-4">
29:           Go Back
30:         </Button>
31:       </div>
32:     );
33:   }
34:   const initialData: NewsFormValues | undefined =
35:     isEditing && news
36:       ? {
37:           title: news.title,
38:           summary: news.summary || '',
39:           content: news.content || '',
40:           status: news.status,
41:           images: news.images.map((img) => ({
42:             id: img.id,
43:             url: img.url,
44:           })),
45:         }
46:       : undefined;
47:   const handleSubmit = async (values: NewsFormValues) => {
48:     try {
49:       // Transform images to imageIds for backend
50:       const imageIds = values.images?.map((img) => img.id).filter(Boolean) as string[] || [];
51:       const payload = {
52:         title: values.title,
53:         summary: values.summary,
54:         content: values.content,
55:         status: values.status,
56:         imageIds,
57:       };
58:       if (isEditing) {
59:         await updateMutation.mutateAsync({ id: newsId, data: payload as UpdateNewsRequest });
60:         toast.success('News updated successfully');
61:       } else {
62:         await createMutation.mutateAsync(payload as CreateNewsRequest);
63:         toast.success('News created successfully');
64:       }
65:       router.push('/admin/news');
66:     } catch (error: any) {
67:       toast.error(error?.response?.data?.message || 'Failed to save news');
68:     }
69:   };
70:   return (
71:     <div className="container mx-auto py-6 space-y-6 flex-col">
72:       <div className="flex items-center gap-4">
73:         <Link href="/admin/news">
74:           <Button variant="ghost" size="icon">
75:             <ArrowLeft className="h-4 w-4" />
76:           </Button>
77:         </Link>
78:         <h1 className="text-2xl font-bold tracking-tight">
79:           {isEditing ? 'Edit News' : 'Create News'}
80:         </h1>
81:       </div>
82:       <div className="bg-card rounded-lg border p-6 shadow-sm w-full mx-auto">
83:         <NewsForm
84:           initialData={initialData}
85:           onSubmit={handleSubmit}
86:           isLoading={isSaving}
87:         />
88:       </div>
89:     </div>
90:   );
91: }
</file>

