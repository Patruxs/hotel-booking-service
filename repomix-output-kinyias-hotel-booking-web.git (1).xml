<file path="apps/web/src/features/promotion/validator.ts">
 1: import { z } from 'zod';
 2: export const createPromotionSchema = z.object({
 3:   code: z.string().min(1, 'Code is required').max(50, 'Code is too long').toUpperCase(),
 4:   name: z.string().min(1, 'Name is required').max(200, 'Name is too long'),
 5:   description: z.string().max(1000, 'Description is too long').optional().or(z.literal('')),
 6:   discountType: z.enum(['PERCENT', 'FIXED'] as const),
 7:   discountValue: z.number().min(0, 'Discount value must be positive'),
 8:   maxDiscountAmount: z.number().min(0, 'Max discount amount must be positive').optional().nullable(),
 9:   minBookingAmount: z.number().min(0, 'Min booking amount must be positive').optional().nullable(),
10:   totalUsageLimit: z.number().int().min(1, 'Total usage limit must be at least 1').optional().nullable(),
11:   perUserLimit: z.number().int().min(1, 'Per user limit must be at least 1').optional().nullable(),
12:   startAt: z.string().min(1, 'Start date is required'),
13:   endAt: z.string().min(1, 'End date is required'),
14:   isActive: z.boolean().optional(),
15: }).refine(
16:   (data) => {
17:     if (data.discountType === 'PERCENT' && data.discountValue > 100) {
18:       return false;
19:     }
20:     return true;
21:   },
22:   {
23:     message: 'Percent discount cannot exceed 100%',
24:     path: ['discountValue'],
25:   }
26: ).refine(
27:   (data) => {
28:     const start = new Date(data.startAt);
29:     const end = new Date(data.endAt);
30:     return end > start;
31:   },
32:   {
33:     message: 'End date must be after start date',
34:     path: ['endAt'],
35:   }
36: );
37: export type CreatePromotionFormValues = z.infer<typeof createPromotionSchema>;
38: export const updatePromotionSchema = z.object({
39:   code: z.string().min(1, 'Code is required').max(50, 'Code is too long').toUpperCase().optional(),
40:   name: z.string().min(1, 'Name is required').max(200, 'Name is too long').optional(),
41:   description: z.string().max(1000, 'Description is too long').optional().nullable(),
42:   discountType: z.enum(['PERCENT', 'FIXED'] as const).optional(),
43:   discountValue: z.number().min(0, 'Discount value must be positive').optional(),
44:   maxDiscountAmount: z.number().min(0, 'Max discount amount must be positive').optional().nullable(),
45:   minBookingAmount: z.number().min(0, 'Min booking amount must be positive').optional().nullable(),
46:   totalUsageLimit: z.number().int().min(1, 'Total usage limit must be at least 1').optional().nullable(),
47:   perUserLimit: z.number().int().min(1, 'Per user limit must be at least 1').optional().nullable(),
48:   startAt: z.string().optional(),
49:   endAt: z.string().optional(),
50:   isActive: z.boolean().optional(),
51:   hotelId: z.string().optional().nullable(),
52: }).refine(
53:   (data) => {
54:     if (data.discountType === 'PERCENT' && data.discountValue && data.discountValue > 100) {
55:       return false;
56:     }
57:     return true;
58:   },
59:   {
60:     message: 'Percent discount cannot exceed 100%',
61:     path: ['discountValue'],
62:   }
63: ).refine(
64:   (data) => {
65:     if (data.startAt && data.endAt) {
66:       const start = new Date(data.startAt);
67:       const end = new Date(data.endAt);
68:       return end > start;
69:     }
70:     return true;
71:   },
72:   {
73:     message: 'End date must be after start date',
74:     path: ['endAt'],
75:   }
76: );
77: export type UpdatePromotionFormValues = z.infer<typeof updatePromotionSchema>;
</file>

