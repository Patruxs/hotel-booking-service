<file path="apps/web/src/components/tiptap-templates/simple/theme-toggle.tsx">
 1: "use client"
 2: import { Button } from "@/components/tiptap-ui-primitive/button"
 3: import { MoonStarIcon } from "@/components/tiptap-icons/moon-star-icon"
 4: import { SunIcon } from "@/components/tiptap-icons/sun-icon"
 5: import { useEffect, useState } from "react"
 6: export function ThemeToggle() {
 7:   const [isDarkMode, setIsDarkMode] = useState<boolean>(false)
 8:   useEffect(() => {
 9:     const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)")
10:     const handleChange = () => setIsDarkMode(mediaQuery.matches)
11:     mediaQuery.addEventListener("change", handleChange)
12:     return () => mediaQuery.removeEventListener("change", handleChange)
13:   }, [])
14:   useEffect(() => {
15:     const initialDarkMode =
16:       !!document.querySelector('meta[name="color-scheme"][content="dark"]') ||
17:       window.matchMedia("(prefers-color-scheme: dark)").matches
18:     setIsDarkMode(initialDarkMode)
19:   }, [])
20:   useEffect(() => {
21:     document.documentElement.classList.toggle("dark", isDarkMode)
22:   }, [isDarkMode])
23:   const toggleDarkMode = () => setIsDarkMode((isDark) => !isDark)
24:   return (
25:     <Button
26:       onClick={toggleDarkMode}
27:       aria-label={`Switch to ${isDarkMode ? "light" : "dark"} mode`}
28:       data-style="ghost"
29:     >
30:       {isDarkMode ? (
31:         <MoonStarIcon className="tiptap-button-icon" />
32:       ) : (
33:         <SunIcon className="tiptap-button-icon" />
34:       )}
35:     </Button>
36:   )
37: }
</file>

