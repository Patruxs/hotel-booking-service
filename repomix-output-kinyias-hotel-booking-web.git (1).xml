 2: import { Strategy, ExtractJwt } from 'passport-jwt';
 3: import { Injectable, UnauthorizedException } from '@nestjs/common';
 4: import { PrismaService } from '../../prisma/prisma.service';
 5: import { HotelMemberRole } from '@prisma/client';
 6: export type JwtUser = {
 7:   id: string;
 8:   email: string;
 9:   jti: string;
10:   hotelMemberships: Array<{
11:     hotelId: string;
12:   }>;
13: };
14: @Injectable()
15: export class JwtAccessStrategy extends PassportStrategy(Strategy, 'jwt') {
16:   constructor(private prisma: PrismaService) {
17:     super({
18:       jwtFromRequest: ExtractJwt.fromAuthHeaderAsBearerToken(),
19:       secretOrKey: process.env.JWT_SECRET!,
20:       ignoreExpiration: false,
21:     });
22:   }
23:   async validate(payload: any): Promise<JwtUser> {
24:     const user = await this.prisma.user.findUnique({
25:       where: { id: payload.sub },
26:       select: {
27:         id: true,
28:         email: true,
29:         hotelMemberships: {
30:           select: {
31:             hotelId: true,
32:           },
33:         },
34:       },
35:     });
36:     if (!user) throw new UnauthorizedException();
37:     return {
38:       id: user.id,
39:       email: user.email,
40:       jti: payload.jti,
41:       hotelMemberships: user.hotelMemberships,
42:     };
43:   }
44: }
