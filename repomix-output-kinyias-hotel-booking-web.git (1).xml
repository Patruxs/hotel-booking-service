307: export function updateNodesAttr<A extends string = string, V = unknown>(
308:   tr: Transaction,
309:   targets: readonly NodeWithPos[],
310:   attrName: A,
311:   next: V | ((prev: V | undefined) => V | undefined)
312: ): boolean {
313:   if (!targets.length) return false
314:   let changed = false
315:   for (const { pos } of targets) {
316:     const currentNode = tr.doc.nodeAt(pos)
317:     if (!currentNode) continue
318:     const prevValue = (currentNode.attrs as Record<string, unknown>)[
319:       attrName
320:     ] as V | undefined
321:     const resolvedNext =
322:       typeof next === "function"
323:         ? (next as (p: V | undefined) => V | undefined)(prevValue)
324:         : next
325:     if (prevValue === resolvedNext) continue
326:     const nextAttrs: Record<string, unknown> = { ...currentNode.attrs }
327:     if (resolvedNext === undefined) {
328:       delete nextAttrs[attrName]
329:     } else {
330:       nextAttrs[attrName] = resolvedNext
331:     }
332:     tr.setNodeMarkup(pos, undefined, nextAttrs)
333:     changed = true
334:   }
335:   return changed
336: }
337: export function selectCurrentBlockContent(editor: Editor) {
