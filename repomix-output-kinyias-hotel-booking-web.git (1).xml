<file path="apps/web/src/features/rooms/mutations.ts">
 1: import { useMutation, useQueryClient } from "@tanstack/react-query";
 2: import { createRoom, deleteRoom, updateRoom } from "./api";
 3: import { CreateRoomFormValues, UpdateRoomFormValues } from "./types";
 4: export const useMutationCreateRoom = (hotelId: string) => {
 5:     const queryClient = useQueryClient();
 6:     return useMutation({
 7:         mutationFn: (payload: CreateRoomFormValues) => createRoom(hotelId, payload),
 8:          onSuccess: () => {
 9:             queryClient.invalidateQueries({ queryKey: ['rooms', hotelId] });
10:         },
11:     });
12: }
13: export const useMutationUpdateRoom = (hotelId: string, roomId: string) => {
14:     const queryClient = useQueryClient();
15:     return useMutation({
16:         mutationFn: (payload: UpdateRoomFormValues) => updateRoom(hotelId, roomId, payload),
17:          onSuccess: () => {
18:             queryClient.invalidateQueries({ queryKey: ['rooms', hotelId] });
19:             queryClient.invalidateQueries({ queryKey: ['room', hotelId, roomId] });
20:         },
21:     });
22: }
23: export const useMutationDeleteRoom = (hotelId: string) =>{
24:     const queryClient = useQueryClient();
25:     return useMutation({
26:         mutationFn: (roomId: string) => deleteRoom(hotelId, roomId),
27:          onSuccess: () => {
28:             queryClient.invalidateQueries({ queryKey: ['rooms', hotelId] });
29:         },
30:     });
31: }
