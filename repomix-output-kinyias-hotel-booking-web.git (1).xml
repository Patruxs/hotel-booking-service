 61:     string[]
 62:   >([]);
 63:   const inputRef = useRef<HTMLInputElement>(null);
 64:   const permissions = data?.data || [];
 65:   const handleSubmit = async (values: PermissionAssignActionFormValues) => {
 66:     try {
 67:       await onSubmit(values);
 68:     } catch (error) {
 69:       console.error('Form submission error:', error);
 70:     }
 71:   };
 72:   useEffect(() => {
 73:     if (action) {
 74:       form.reset({
 75:         permissionIds: action?.policies.map((a) => a.permissionId) || [],
 76:       });
 77:     }
 78:   }, [action]);
 79:   return (
 80:     <Dialog open={open} onOpenChange={onOpenChange}>
 81:       <DialogContent className="max-w-lg">
 82:         <DialogHeader>
 83:           <DialogTitle>Assign Permissions to Action</DialogTitle>
 84:           <DialogDescription>
 85:             Search and select permissions to assign to this action.
 86:           </DialogDescription>
 87:         </DialogHeader>
 88:         <Form {...form}>
 89:           <form
 90:             onSubmit={form.handleSubmit(handleSubmit)}
 91:             className="space-y-6"
 92:           >
