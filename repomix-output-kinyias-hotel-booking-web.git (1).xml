 17: export interface UploadOptions {
 18:   maxSize: number
 19:   limit: number
 20:   accept: string
 21:   upload: (
 22:     file: File,
 23:     onProgress: (event: { progress: number }) => void,
 24:     signal: AbortSignal
 25:   ) => Promise<string>
 26:   onSuccess?: (url: string) => void
 27:   onError?: (error: Error) => void
 28: }
 29: function useFileUpload(options: UploadOptions) {
 30:   const [fileItems, setFileItems] = useState<FileItem[]>([])
 31:   const uploadFile = async (file: File): Promise<string | null> => {
 32:     if (file.size > options.maxSize) {
 33:       const error = new Error(
 34:         `File size exceeds maximum allowed (${options.maxSize / 1024 / 1024}MB)`
 35:       )
 36:       options.onError?.(error)
 37:       return null
 38:     }
 39:     const abortController = new AbortController()
 40:     const fileId = crypto.randomUUID()
 41:     const newFileItem: FileItem = {
 42:       id: fileId,
 43:       file,
 44:       progress: 0,
 45:       status: "uploading",
 46:       abortController,
 47:     }
 48:     setFileItems((prev) => [...prev, newFileItem])
 49:     try {
 50:       if (!options.upload) {
 51:         throw new Error("Upload function is not defined")
 52:       }
 53:       const url = await options.upload(
 54:         file,
 55:         (event: { progress: number }) => {
 56:           setFileItems((prev) =>
 57:             prev.map((item) =>
 58:               item.id === fileId ? { ...item, progress: event.progress } : item
 59:             )
 60:           )
 61:         },
 62:         abortController.signal
 63:       )
 64:       if (!url) throw new Error("Upload failed: No URL returned")
 65:       if (!abortController.signal.aborted) {
 66:         setFileItems((prev) =>
 67:           prev.map((item) =>
 68:             item.id === fileId
 69:               ? { ...item, status: "success", url, progress: 100 }
 70:               : item
 71:           )
 72:         )
 73:         options.onSuccess?.(url)
 74:         return url
 75:       }
 76:       return null
 77:     } catch (error) {
 78:       if (!abortController.signal.aborted) {
 79:         setFileItems((prev) =>
 80:           prev.map((item) =>
 81:             item.id === fileId
 82:               ? { ...item, status: "error", progress: 0 }
 83:               : item
 84:           )
 85:         )
 86:         options.onError?.(
 87:           error instanceof Error ? error : new Error("Upload failed")
 88:         )
 89:       }
 90:       return null
 91:     }
 92:   }
 93:   const uploadFiles = async (files: File[]): Promise<string[]> => {
 94:     if (!files || files.length === 0) {
 95:       options.onError?.(new Error("No files to upload"))
 96:       return []
 97:     }
 98:     if (options.limit && files.length > options.limit) {
 99:       options.onError?.(
100:         new Error(
101:           `Maximum ${options.limit} file${options.limit === 1 ? "" : "s"} allowed`
102:         )
103:       )
104:       return []
105:     }
106:     const uploadPromises = files.map((file) => uploadFile(file))
107:     const results = await Promise.all(uploadPromises)
108:     return results.filter((url): url is string => url !== null)
109:   }
110:   const removeFileItem = (fileId: string) => {
111:     setFileItems((prev) => {
112:       const fileToRemove = prev.find((item) => item.id === fileId)
113:       if (fileToRemove?.abortController) {
114:         fileToRemove.abortController.abort()
115:       }
116:       if (fileToRemove?.url) {
117:         URL.revokeObjectURL(fileToRemove.url)
118:       }
119:       return prev.filter((item) => item.id !== fileId)
120:     })
121:   }
122:   const clearAllFiles = () => {
123:     fileItems.forEach((item) => {
124:       if (item.abortController) {
125:         item.abortController.abort()
126:       }
127:       if (item.url) {
128:         URL.revokeObjectURL(item.url)
129:       }
130:     })
131:     setFileItems([])
132:   }
133:   return {
134:     fileItems,
135:     uploadFiles,
136:     removeFileItem,
137:     clearAllFiles,
138:   }
139: }
