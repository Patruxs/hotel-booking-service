 15:   const pad = (n: number) => String(n).padStart(2, '0');
 16:   return `${d.getFullYear()}${pad(d.getMonth() + 1)}${pad(d.getDate())}${pad(d.getHours())}${pad(d.getMinutes())}${pad(d.getSeconds())}`;
 17: }
 18: function parseVnpPayDate(vnpPayDate?: string) {
 19:   if (!vnpPayDate) return null;
 20:   const s = vnpPayDate;
 21:   if (!/^\d{14}$/.test(s)) return null;
 22:   const yyyy = Number(s.slice(0, 4));
 23:   const MM = Number(s.slice(4, 6)) - 1;
 24:   const dd = Number(s.slice(6, 8));
 25:   const HH = Number(s.slice(8, 10));
 26:   const mm = Number(s.slice(10, 12));
 27:   const ss = Number(s.slice(12, 14));
 28:   return new Date(yyyy, MM, dd, HH, mm, ss);
 29: }
 30: @Injectable()
 31: export class PaymentService {
 32:   constructor(
 33:     private prisma: PrismaService,
 34:     private config: ConfigService,
 35:     private readonly vnpSig: VnpaySignatureService,
 36:     private readonly mail: MailService,
 37:   ) {}
 38:   private formatMoneyVnd(amount: any) {
 39:     const n = Number(amount);
 40:     return n.toLocaleString('vi-VN');
 41:   }
 42:   private async sendPaymentSucceededMailOnce(paymentId: string) {
 43:     const existed = await this.prisma.paymentEvent.findFirst({
 44:       where: { paymentId, type: 'MAIL_PAYMENT_SUCCEEDED' },
 45:       select: { id: true },
 46:     });
 47:     if (existed) return;
 48:     const payment = await this.prisma.payment.findUnique({
 49:       where: { id: paymentId },
 50:       include: {
 51:         booking: {
 52:           select: {
 53:             id: true,
 54:             guestName: true,
 55:             guestEmail: true,
 56:             checkIn: true,
 57:             checkOut: true,
 58:             userId: true,
 59:             hotel: { select: { name: true } },
 60:           },
 61:         },
 62:       },
 63:     });
 64:     if (!payment) return;
 65:     let to = payment.booking.guestEmail ?? null;
 66:     if (!to && payment.booking.userId) {
 67:       const u = await this.prisma.user.findUnique({
 68:         where: { id: payment.booking.userId },
 69:         select: { email: true },
 70:       });
 71:       to = u?.email ?? null;
 72:     }
 73:     if (!to) return;
 74:     try {
 75:       await this.mail.sendPaymentSucceededEmail({
 76:         to,
 77:         guestName: payment.booking.guestName,
 78:         bookingId: payment.booking.id,
 79:         amountVnd: this.formatMoneyVnd(payment.amount),
 80:         hotelName: payment.booking.hotel?.name ?? null,
 81:         checkIn: payment.booking.checkIn.toISOString().slice(0, 10),
 82:         checkOut: payment.booking.checkOut.toISOString().slice(0, 10),
 83:       });
 84:       await this.prisma.paymentEvent.create({
 85:         data: {
 86:           paymentId,
 87:           type: 'MAIL_PAYMENT_SUCCEEDED',
 88:           payload: { to },
 89:         },
 90:       });
 91:     } catch (e) {
 92:       await this.prisma.paymentEvent.create({
 93:         data: {
 94:           paymentId,
 95:           type: 'MAIL_PAYMENT_FAILED',
 96:           payload: { error: String(e) },
 97:         },
 98:       });
 99:     }
100:   }
101:   async createVnpayPaymentUrl(
102:     userId: string,
103:     bookingId: string,
104:     dto: CreateVnpayPaymentDto,
105:     ipAddr: string,
106:   ) {
107:     const booking = await this.prisma.booking.findUnique({
108:       where: { id: bookingId },
109:     });
110:     if (!booking) throw new NotFoundException('Booking not found');
111:     if (booking.status !== 'PENDING')
112:       throw new BadRequestException('Booking is not payable');
113:     const tmnCode = this.config.getOrThrow<string>('VNPAY_TMN_CODE');
114:     const secret = this.config.getOrThrow<string>('VNPAY_HASH_SECRET');
115:     const vnpUrl = this.config.getOrThrow<string>('VNPAY_URL');
116:     const returnUrl = this.config.getOrThrow<string>('VNPAY_RETURN_URL');
117:     const merchantTxnRef = `BK_${booking.id}_${Date.now()}`;
118:     const payment = await this.prisma.payment.create({
119:       data: {
120:         provider: 'VNPAY',
121:         status: 'INIT',
122:         bookingId: booking.id,
123:         amount: booking.totalAmount,
124:         merchantTxnRef,
125:         secureHashAlg: 'sha512',
126:       },
127:     });
128:     const locale = dto.locale ?? 'vn';
129:     const now = new Date();
130:     const vnpParams: Record<string, any> = {
131:       vnp_Version: '2.1.0',
132:       vnp_Command: 'pay',
133:       vnp_TmnCode: tmnCode,
134:       vnp_Locale: locale,
135:       vnp_CurrCode: 'VND',
136:       vnp_TxnRef: merchantTxnRef,
137:       vnp_OrderInfo: `Thanh toan booking ${booking.id}`,
138:       vnp_OrderType: 'other',
139:       vnp_Amount: Number(booking.totalAmount) * 100,
140:       vnp_ReturnUrl: returnUrl,
141:       vnp_IpAddr: ipAddr,
142:       vnp_CreateDate: formatVnpDate(now),
143:     };
144:     if (dto.bankCode) vnpParams.vnp_BankCode = dto.bankCode;
145:     const sorted = sortObject(vnpParams);
146:     const secureHash = signParams(sorted, secret);
147:     sorted.vnp_SecureHash = secureHash;
148:     const paymentUrl = `${vnpUrl}?${qs.stringify(sorted, { encode: false })}`;
149:     await this.prisma.payment.update({
150:       where: { id: payment.id },
151:       data: { status: 'PENDING' },
152:     });
153:     return { paymentId: payment.id, merchantTxnRef, paymentUrl };
154:   }
155:   async handleVnpayReturn(query: Record<string, any>) {
156:     const secureHash = query.vnp_SecureHash;
157:     const params = { ...query };
158:     delete params.vnp_SecureHash;
159:     delete params.vnp_SecureHashType;
160:     const ok = this.vnpSig.verify(params, secureHash);
161:     const merchantTxnRef = params.vnp_TxnRef as string | undefined;
162:     if (!merchantTxnRef) {
163:       return { ok: false, responseCode: params.vnp_ResponseCode ?? null };
164:     }
165:     const payment = await this.prisma.payment.findUnique({
166:       where: { merchantTxnRef },
167:       include: { booking: { select: { id: true, status: true } } },
168:     });
169:     if (!payment) {
170:       return { ok, responseCode: params.vnp_ResponseCode ?? null };
171:     }
172:     await this.prisma.paymentEvent.create({
173:       data: {
174:         paymentId: payment.id,
175:         type: 'RETURN',
176:         payload: query,
177:       },
178:     });
179:     if (!ok) {
180:       return { ok: false, responseCode: params.vnp_ResponseCode ?? null };
181:     }
182:     const rspCode = (params.vnp_ResponseCode as string) ?? null;
183:     const payDate = parseVnpPayDate(params.vnp_PayDate);
184:     const bankCode = (params.vnp_BankCode as string) ?? null;
185:     const vnpTransactionNo = (params.vnp_TransactionNo as string) ?? null;
186:     const transactionStatus = (params.vnp_TransactionStatus as string) ?? null;
187:     if (
188:       payment.status !== PaymentStatus.INIT &&
189:       payment.status !== PaymentStatus.PENDING
190:     ) {
191:       return { ok: true, responseCode: rspCode };
192:     }
193:     if (rspCode === '00') {
194:       await this.prisma.$transaction([
195:         this.prisma.payment.update({
196:           where: { id: payment.id },
197:           data: {
198:             status: PaymentStatus.SUCCEEDED,
199:             responseCode: rspCode,
200:             transactionStatus,
201:             vnpTransactionNo,
202:             bankCode,
203:             payDate,
204:             secureHashAlg: 'sha512',
205:           },
206:         }),
207:         this.prisma.booking.update({
208:           where: { id: payment.bookingId },
209:           data: { status: BookingStatus.CONFIRMED },
210:         }),
211:       ]);
212:       await this.sendPaymentSucceededMailOnce(payment.id);
213:     } else {
214:       await this.prisma.payment.update({
215:         where: { id: payment.id },
216:         data: {
217:           status: PaymentStatus.FAILED,
218:           responseCode: rspCode,
219:           transactionStatus,
220:           vnpTransactionNo,
221:           bankCode,
222:           payDate,
223:           secureHashAlg: 'sha512',
224:         },
225:       });
226:     }
227:     return { ok: true, responseCode: rspCode, bookingId: payment.bookingId };
228:   }
229:   async handleVnpayIpn(query: Record<string, any>) {
230:     const secureHash = query.vnp_SecureHash;
231:     const params = { ...query };
232:     delete params.vnp_SecureHash;
233:     delete params.vnp_SecureHashType;
234:     const checksumOk = this.vnpSig.verify(params, secureHash);
235:     if (!checksumOk) {
236:       return { RspCode: '97', Message: 'Checksum failed' };
237:     }
238:     const merchantTxnRef = params.vnp_TxnRef as string;
239:     const rspCode = params.vnp_ResponseCode as string;
240:     const vnpAmount = Number(params.vnp_Amount);
241:     const amountVnd = vnpAmount / 100;
242:     const payment = await this.prisma.payment.findUnique({
243:       where: { merchantTxnRef },
244:       include: { booking: { select: { id: true, status: true } } },
245:     });
246:     if (!payment) return { RspCode: '01', Message: 'Order not found' };
247:     const expected = new Prisma.Decimal(amountVnd);
248:     if (!payment.amount.equals(expected)) {
249:       return { RspCode: '04', Message: 'Amount invalid' };
250:     }
251:     if (
252:       payment.status !== PaymentStatus.INIT &&
253:       payment.status !== PaymentStatus.PENDING
254:     ) {
255:       return {
256:         RspCode: '02',
257:         Message: 'This order has been updated to the payment status',
258:       };
259:     }
260:     await this.prisma.paymentEvent.create({
261:       data: {
262:         paymentId: payment.id,
263:         type: 'IPN',
264:         payload: query,
265:       },
266:     });
267:     const payDate = parseVnpPayDate(params.vnp_PayDate);
268:     if (rspCode === '00') {
269:       await this.prisma.$transaction([
270:         this.prisma.payment.update({
271:           where: { id: payment.id },
272:           data: {
273:             status: PaymentStatus.SUCCEEDED,
274:             responseCode: rspCode,
275:             transactionStatus: params.vnp_TransactionStatus ?? null,
276:             vnpTransactionNo: params.vnp_TransactionNo ?? null,
277:             bankCode: params.vnp_BankCode ?? null,
278:             payDate,
279:             secureHashAlg: 'sha512',
280:           },
281:         }),
282:         this.prisma.booking.update({
283:           where: { id: payment.bookingId },
284:           data: { status: BookingStatus.CONFIRMED },
285:         }),
286:       ]);
287:     } else {
288:       await this.prisma.payment.update({
289:         where: { id: payment.id },
290:         data: {
291:           status: PaymentStatus.FAILED,
292:           responseCode: rspCode,
293:           transactionStatus: params.vnp_TransactionStatus ?? null,
294:           vnpTransactionNo: params.vnp_TransactionNo ?? null,
295:           bankCode: params.vnp_BankCode ?? null,
296:           payDate,
297:           secureHashAlg: 'sha512',
298:         },
299:       });
300:     }
301:     return { RspCode: '00', Message: 'Success' };
302:   }
303: }
