191:     const skip = (page - 1) * limit;
192:     const where: Prisma.ReviewWhereInput = {
193:       userId,
194:       deletedAt: null,
195:     };
196:     const [items, total] = await this.prisma.$transaction([
197:       this.prisma.review.findMany({
