  1: import {
  2:   Injectable,
  3:   NotFoundException,
  4:   ConflictException,
  5:   BadRequestException,
  6: } from '@nestjs/common';
  7: import { CreateRoleDto } from './dto/create-role.dto';
  8: import { UpdateRoleDto } from './dto/update-role.dto';
  9: import { AssignRolesToUserDto } from './dto/assign-roles-to-user.dto';
 10: import { PrismaService } from '../prisma/prisma.service';
 11: import { AssignPermissionsDto } from './dto/assign-permissions.dto';
 12: import { Prisma } from '@prisma/client';
 13: @Injectable()
 14: export class RolesService {
 15:   constructor(private prisma: PrismaService) {}
 16:   async create(dto: CreateRoleDto) {
 17:     try {
 18:       return await this.prisma.role.create({ data: dto });
 19:     } catch (e) {
 20:       if (String(e?.code) === 'P2002') {
 21:         throw new ConflictException('Role name already exists');
 22:       }
 23:       throw e;
 24:     }
 25:   }
 26:   findAll(q?: { search?: string; skip?: number; take?: number }) {
 27:     const where = q?.search
 28:       ? {
 29:           OR: [
 30:             {
 31:               name: { contains: q.search, mode: Prisma.QueryMode.insensitive },
 32:             },
 33:             {
 34:               description: {
 35:                 contains: q.search,
 36:                 mode: Prisma.QueryMode.insensitive,
 37:               },
 38:             },
 39:           ],
 40:         }
 41:       : undefined;
 42:     return this.prisma.role.findMany({
 43:       where,
 44:       skip: q?.skip,
 45:       take: q?.take ?? 50,
 46:       orderBy: { name: 'asc' },
 47:       include: {
 48:         permissions: { include: { permission: true } },
 49:       },
 50:     });
 51:   }
 52:   async findOne(id: string) {
 53:     const role = await this.prisma.role.findUnique({
 54:       where: { id },
 55:       include: {
 56:         permissions: { include: { permission: true } },
 57:         users: { include: { user: true } },
 58:       },
 59:     });
 60:     if (!role) throw new NotFoundException('Role not found');
 61:     return role;
 62:   }
 63:   async update(id: string, dto: UpdateRoleDto) {
 64:     await this.findOne(id);
 65:     return this.prisma.role.update({ where: { id }, data: dto });
 66:   }
 67:   async remove(id: string) {
 68:     await this.findOne(id);
 69:     return this.prisma.$transaction([
 70:       this.prisma.rolePermission.deleteMany({ where: { roleId: id } }),
 71:       this.prisma.userRole.deleteMany({ where: { roleId: id } }),
 72:       this.prisma.role.delete({ where: { id } }),
 73:     ]);
 74:   }
 75:   async setRolePermissions(roleId: string, dto: AssignPermissionsDto) {
 76:     await this.findOne(roleId);
 77:     const cleanIds = dto.permissionIds
 78:       .map((x) => (typeof x === 'string' ? x.trim() : ''))
 79:       .filter((x) => x.length > 0);
 80:     if (cleanIds.length === 0) {
 81:       throw new BadRequestException('permissionIds contains no valid id');
 82:     }
 83:     const seen = new Set<string>();
 84:     const dupes = new Set<string>();
 85:     for (const pid of cleanIds) {
 86:       if (seen.has(pid)) dupes.add(pid);
 87:       else seen.add(pid);
 88:     }
 89:     if (dupes.size > 0) {
 90:       throw new BadRequestException(
 91:         `Duplicate permissionIds: ${[...dupes].join(', ')}`,
 92:       );
 93:     }
 94:     const perms = await this.prisma.permission.findMany({
 95:       where: { id: { in: cleanIds } },
 96:       select: { id: true, name: true },
 97:     });
 98:     const foundIds = new Set(perms.map((p) => p.id));
 99:     const missingIds = cleanIds.filter((pid) => !foundIds.has(pid));
100:     if (missingIds.length > 0) {
101:       throw new NotFoundException(
102:         `Permissions not found (by id): ${missingIds.join(', ')}`,
103:       );
104:     }
105:     return this.prisma.$transaction(async (tx) => {
106:       await tx.rolePermission.deleteMany({ where: { roleId } });
107:       await tx.rolePermission.createMany({
108:         data: cleanIds.map((permissionId) => ({ roleId, permissionId })),
109:         skipDuplicates: true,
110:       });
111:       return tx.role.findUnique({
112:         where: { id: roleId },
113:         include: { permissions: { include: { permission: true } } },
114:       });
115:     });
116:   }
117:   async setUserRoles(dto: AssignRolesToUserDto) {
118:     const user = await this.prisma.user.findUnique({
119:       where: { id: dto?.userId },
120:     });
121:     if (!user) throw new NotFoundException('User not found');
122:     const cleanIds = dto.roleIds
123:       .map((x) => (typeof x === 'string' ? x.trim() : ''))
124:       .filter((x) => x.length > 0);
125:     if (cleanIds.length === 0) {
126:       throw new BadRequestException('roleIds contains no valid id');
127:     }
128:     const seen = new Set<string>();
129:     const dupes = new Set<string>();
130:     for (const rid of cleanIds) {
131:       if (seen.has(rid)) dupes.add(rid);
132:       else seen.add(rid);
133:     }
134:     if (dupes.size > 0) {
135:       throw new BadRequestException(
136:         `Duplicate roleIds: ${[...dupes].join(', ')}`,
137:       );
138:     }
139:     const roles = await this.prisma.role.findMany({
140:       where: { id: { in: cleanIds } },
141:       select: { id: true, name: true },
142:     });
143:     const foundIds = new Set(roles.map((r) => r.id));
144:     const missingIds = cleanIds.filter((rid) => !foundIds.has(rid));
145:     if (missingIds.length > 0) {
146:       throw new NotFoundException(
147:         `Roles not found (by id): ${missingIds.join(', ')}`,
148:       );
149:     }
150:     return this.prisma.$transaction(async (tx) => {
151:       await tx.userRole.deleteMany({ where: { userId: dto.userId } });
152:       await tx.userRole.createMany({
153:         data: cleanIds.map((roleId) => ({ userId: dto.userId, roleId })),
154:         skipDuplicates: true,
155:       });
156:       return tx.user.findUnique({
157:         where: { id: dto.userId },
158:         include: { roles: { include: { role: true } } },
159:       });
160:     });
161:   }
162: }
