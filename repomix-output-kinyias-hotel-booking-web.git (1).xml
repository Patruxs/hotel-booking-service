386:               ...(q.from ? { gte: new Date(q.from) } : {}),
387:               ...(q.to ? { lt: new Date(q.to) } : {}),
388:             },
389:           }
390:         : {}),
391:       ...(q.q ? { OR: [
392:           { guestName: { contains: q.q, mode: Prisma.QueryMode.insensitive } },
393:           { guestEmail: { contains: q.q, mode: Prisma.QueryMode.insensitive } },
394:         ] } : {}),
395:     };
396:     const [total, items] = await this.prisma.$transaction([
397:       this.prisma.booking.count({ where }),
398:       this.prisma.booking.findMany({
399:         where,
400:         skip: offset,
401:         take: limit,
402:         orderBy: { createdAt: 'desc' },
403:         include: { items: true },
404:       }),
405:     ]);
