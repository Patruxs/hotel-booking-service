  1: "use client"
  2: import { useCallback, useEffect, useState } from "react"
  3: import { useHotkeys } from "react-hotkeys-hook"
  4: import { type Editor } from "@tiptap/react"
  5: import { useTiptapEditor } from "@/hooks/use-tiptap-editor"
  6: import { useIsBreakpoint } from "@/hooks/use-is-breakpoint"
  7: import { isExtensionAvailable } from "@/lib/tiptap-utils"
  8: import { ImagePlusIcon } from "@/components/tiptap-icons/image-plus-icon"
  9: export const IMAGE_UPLOAD_SHORTCUT_KEY = "mod+shift+i"
 10: export interface UseImageUploadConfig {
 11:   editor?: Editor | null
 12:   hideWhenUnavailable?: boolean
 13:   onInserted?: () => void
 14: }
 15: export function canInsertImage(editor: Editor | null): boolean {
 16:   if (!editor || !editor.isEditable) return false
 17:   if (!isExtensionAvailable(editor, "imageUpload")) return false
 18:   return editor.can().insertContent({ type: "imageUpload" })
 19: }
 20: export function isImageActive(editor: Editor | null): boolean {
 21:   if (!editor || !editor.isEditable) return false
 22:   return editor.isActive("imageUpload")
 23: }
 24: export function insertImage(editor: Editor | null): boolean {
 25:   if (!editor || !editor.isEditable) return false
 26:   if (!canInsertImage(editor)) return false
 27:   try {
 28:     return editor
 29:       .chain()
 30:       .focus()
 31:       .insertContent({
 32:         type: "imageUpload",
 33:       })
 34:       .run()
 35:   } catch {
 36:     return false
 37:   }
 38: }
 39: export function shouldShowButton(props: {
 40:   editor: Editor | null
 41:   hideWhenUnavailable: boolean
 42: }): boolean {
 43:   const { editor, hideWhenUnavailable } = props
 44:   if (!editor || !editor.isEditable) return false
 45:   if (!isExtensionAvailable(editor, "imageUpload")) return false
 46:   if (hideWhenUnavailable && !editor.isActive("code")) {
 47:     return canInsertImage(editor)
 48:   }
 49:   return true
 50: }
 51: export function useImageUpload(config?: UseImageUploadConfig) {
 52:   const {
 53:     editor: providedEditor,
 54:     hideWhenUnavailable = false,
 55:     onInserted,
 56:   } = config || {}
 57:   const { editor } = useTiptapEditor(providedEditor)
 58:   const isMobile = useIsBreakpoint()
 59:   const [isVisible, setIsVisible] = useState<boolean>(true)
 60:   const canInsert = canInsertImage(editor)
 61:   const isActive = isImageActive(editor)
 62:   useEffect(() => {
 63:     if (!editor) return
 64:     const handleSelectionUpdate = () => {
 65:       setIsVisible(shouldShowButton({ editor, hideWhenUnavailable }))
 66:     }
 67:     handleSelectionUpdate()
 68:     editor.on("selectionUpdate", handleSelectionUpdate)
 69:     return () => {
 70:       editor.off("selectionUpdate", handleSelectionUpdate)
 71:     }
 72:   }, [editor, hideWhenUnavailable])
 73:   const handleImage = useCallback(() => {
 74:     if (!editor) return false
 75:     const success = insertImage(editor)
 76:     if (success) {
 77:       onInserted?.()
 78:     }
 79:     return success
 80:   }, [editor, onInserted])
 81:   useHotkeys(
 82:     IMAGE_UPLOAD_SHORTCUT_KEY,
 83:     (event) => {
 84:       event.preventDefault()
 85:       handleImage()
 86:     },
 87:     {
 88:       enabled: isVisible && canInsert,
 89:       enableOnContentEditable: !isMobile,
 90:       enableOnFormTags: true,
 91:     }
 92:   )
 93:   return {
 94:     isVisible,
 95:     isActive,
 96:     handleImage,
 97:     canInsert,
 98:     label: "Add image",
 99:     shortcutKeys: IMAGE_UPLOAD_SHORTCUT_KEY,
100:     Icon: ImagePlusIcon,
101:   }
102: }
</file>

