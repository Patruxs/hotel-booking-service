<file path="apps/web/src/components/common/IconExplorer.tsx">
 1: "use client";
 2: import { useState } from "react";
 3: import * as LucideIcons from "lucide-react";
 4: import { Input } from "@/components/ui/input";
 5: import { cn } from "@/lib/utils";
 6: interface IconExplorerProps {
 7:   onSelect?: (icon: string) => void;
 8:   selectedIcon?: string;
 9:   className?: string;
10: }
11: export default function IconExplorer({ onSelect, selectedIcon, className }: IconExplorerProps) {
12:   const [filter, setFilter] = useState("");
13:   const allIcons = Object.keys(LucideIcons);
14:   const filteredIcons = allIcons.filter((name) =>
15:     name.toLowerCase().includes(filter.toLowerCase())
16:   );
17:   // Limit rendering to prevent freezing if filter is empty
18:   const displayIcons = filteredIcons.slice(0, 100);
19:   return (
20:     <div className={cn("p-8 border rounded-lg bg-background my-8", className)}>
21:       <h2 className="text-2xl font-bold mb-4">Icon Explorer</h2>
22:       <div className="mb-6">
23:         <Input
24:           placeholder="Search icons..."
25:           value={filter}
26:           onChange={(e) => setFilter(e.target.value)}
27:           className="max-w-md"
28:         />
29:         <p className="text-sm text-muted-foreground mt-2">
30:           Showing {displayIcons.length} of {filteredIcons.length} matches
31:         </p>
32:       </div>
33:       <div className="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-4">
34:         {displayIcons.map((name) => {
35:           const Icon = (LucideIcons as any)[name];
36:           if (!Icon) return null;
37:           if (name === "icons" || name === "createReactComponent" || name === "default") return null;
38:           const isSelected = selectedIcon === name;
39:           return (
40:             <button
41:               key={name}
42:               type="button"
43:               onClick={() => onSelect?.(name)}
44:               className={cn(
45:                 "flex flex-col items-center justify-center p-4 border rounded hover:bg-muted/50 transition-colors cursor-pointer",
46:                 isSelected && "border-primary bg-primary/10 ring-2 ring-primary ring-offset-2"
47:               )}
48:             >
49:               <Icon className="w-8 h-8 mb-2" />
50:               <span className="text-xs text-center break-all">{name}</span>
51:             </button>
52:           );
53:         })}
54:       </div>
55:     </div>
56:   );
57: }
</file>

