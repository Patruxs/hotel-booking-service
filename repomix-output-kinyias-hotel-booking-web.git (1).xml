13:   }
14: );
15: export type CreateContactFormValues = z.infer<typeof createContactSchema>;
16: export const updateContactSchema = z.object({
17:   status: z.enum(['NEW', 'IN_PROGRESS', 'RESOLVED', 'SPAM']).optional(),
18:   handledById: z.string().optional().nullable(),
19:   note: z.string().max(2000, 'Note is too long').optional().nullable(),
20: });
