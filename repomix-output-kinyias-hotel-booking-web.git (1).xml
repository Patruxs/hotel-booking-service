 15:   async uploadFile(
 16:     file: Express.Multer.File,
 17:   ): Promise<UploadApiResponse | UploadApiErrorResponse> {
 18:     return new Promise((resolve, reject) => {
 19:       const uploadStream = this.cloudinary.uploader.upload_stream(
 20:         { folder: 'stayra' },
 21:         (error, result) => {
 22:           if (error) return reject(error);
 23:           resolve(result as any);
 24:         },
 25:       );
