<file path="apps/web/src/features/room-types/mutations.ts">
 1: import { useMutation, useQueryClient } from "@tanstack/react-query";
 2: import { RoomTypeFormValues } from "./validator";
 3: import { createRoomType, deleteRoomType, updateRoomType } from "./api";
 4: export const useCreateRoomTypeMutation = (hotelId: string) => {
 5:     const queryClient = useQueryClient();
 6:     return useMutation({
 7:         mutationFn: (payload: RoomTypeFormValues) => createRoomType(hotelId, payload),
 8:         onSuccess: () => {
 9:             queryClient.invalidateQueries({ queryKey: ['room-types', hotelId] });
10:         },
11:     });
12: }
13: export const useUpdateRoomTypeMutation = (hotelId: string, id: string) => {
14:     const queryClient = useQueryClient();
15:     return useMutation({
16:         mutationFn: (payload: RoomTypeFormValues) => updateRoomType(hotelId, id, payload),
17:         onSuccess: () => {
18:             queryClient.invalidateQueries({ queryKey: ['room-types', hotelId] });
19:             queryClient.invalidateQueries({ queryKey: ['room-type', hotelId, id] });
20:         },
21:     });
22: }
23: export const useDeleteRoomTypeMutation = (hotelId: string) => {
24:     const queryClient = useQueryClient();
25:     return useMutation({
26:         mutationFn: (id: string) => deleteRoomType(hotelId, id),
27:         onSuccess: () => {
28:             queryClient.invalidateQueries({ queryKey: ['room-types', hotelId] });
29:         },
30:     });
31: }
</file>

