 33:     try {
 34:       const result = await this.cloudinary.api.root_folders();
 35:       return result;
 36:     } catch (error) {
 37:       throw error;
 38:     }
 39:   }
 40:   async getImagesInFolder(folderName: string) {
 41:     try {
 42:       const result = await this.cloudinary.search
 43:         .expression(`folder:${folderName}`)
 44:         .sort_by('created_at', 'desc')
 45:         .max_results(100)
 46:         .execute();
 47:       return result;
 48:     } catch (error) {
 49:       throw error;
 50:     }
 51:   }
 52:   async createFolder(folderName: string, userId: string) {
 53:     try {
 54:       await this.cloudinary.api.create_folder(folderName);
 55:       return this.prisma.folderGallery.create({
 56:         data: {
 57:           folderName,
 58:           userId,
 59:         },
 60:       });
 61:     } catch (error) {
 62:       throw error;
 63:     }
 64:   }
 65:   async uploadImagesToFolder(
 66:     files: Array<Express.Multer.File>,
 67:     folderName: string,
 68:     userId: string,
 69:   ) {
 70:     let folder = await this.prisma.folderGallery.findUnique({
 71:       where: { folderName },
 72:     });
 73:     if (!folder) {
 74:       folder = await this.prisma.folderGallery.create({
 75:         data: {
 76:           folderName,
 77:           userId,
 78:         },
 79:       });
 80:     }
 81:     const uploadPromises = files.map((file) => {
 82:       return new Promise((resolve, reject) => {
 83:         const uploadStream = this.cloudinary.uploader.upload_stream(
 84:           { folder: folderName },
