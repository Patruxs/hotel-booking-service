<file path="apps/api/src/modules/auth/guards/permissions.guard.ts">
 1: import {
 2:   Injectable,
 3:   CanActivate,
 4:   ExecutionContext,
 5:   ForbiddenException,
 6: } from '@nestjs/common';
 7: import { Reflector } from '@nestjs/core';
 8: import { PERMISSIONS_KEY } from '../../auth/decorator/permissions.decorator';
 9: import { PrismaService } from '../../prisma/prisma.service';
10: @Injectable()
11: export class PermissionsGuard implements CanActivate {
12:   constructor(
13:     private reflector: Reflector,
14:     private prisma: PrismaService,
15:   ) {}
16:   async canActivate(context: ExecutionContext): Promise<boolean> {
17:     const requiredPermissions = this.reflector.getAllAndOverride<string[]>(
18:       PERMISSIONS_KEY,
19:       [context.getHandler(), context.getClass()],
20:     );
21:     if (!requiredPermissions) return true;
22:     const { user } = context.switchToHttp().getRequest();
23:     const userRoles = await this.prisma.userRole.findMany({
24:       where: { userId: user.id },
25:       include: {
26:         role: { include: { permissions: { include: { permission: true } } } },
27:       },
28:     });
29:     const userPerms = new Set<string>();
30:     userRoles.forEach((ur) =>
31:       ur.role.permissions.forEach((rp) => userPerms.add(rp.permission.name)),
32:     );
33:     const hasPerm = requiredPermissions.every((p) => userPerms.has(p));
34:     if (!hasPerm)
35:       throw new ForbiddenException('Access denied: missing permissions');
36:     return true;
37:   }
38: }
</file>

