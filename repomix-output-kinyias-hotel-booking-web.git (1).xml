<file path="apps/web/src/components/ui/EllipsisPagination.tsx">
 1: 'use client';
 2: import { Button } from '@/components/ui/button';
 3: import { ChevronLeft, ChevronRight } from 'lucide-react';
 4: interface EllipsisPaginationProps {
 5:   currentPage: number;
 6:   totalPages: number;
 7:   onPageChange: (page: number) => void;
 8: }
 9: export default function EllipsisPagination({
10:   currentPage,
11:   totalPages,
12:   onPageChange,
13: }: EllipsisPaginationProps) {
14:   const renderPageNumbers = () => {
15:     const pages = [];
16:     const delta = 1;
17:     const range = [];
18:     for (
19:       let i = Math.max(2, currentPage - delta);
20:       i <= Math.min(totalPages - 1, currentPage + delta);
21:       i++
22:     ) {
23:       range.push(i);
24:     }
25:     if (currentPage - delta > 2) {
26:       range.unshift('...');
27:     }
28:     if (currentPage + delta < totalPages - 1) {
29:       range.push('...');
30:     }
31:     range.unshift(1);
32:     if (totalPages > 1) range.push(totalPages);
33:     for (const page of range) {
34:       if (page === '...') {
35:         pages.push(
36:           <span key={Math.random()} className="px-2 text-gray-500">
37:             ...
38:           </span>
39:         );
40:       } else {
41:         pages.push(
42:           <Button
43:             key={page}
44:             variant={page === currentPage ? 'default' : 'outline'}
45:             onClick={() => onPageChange(Number(page))}
46:             className="mx-1"
47:           >
48:             {page}
49:           </Button>
50:         );
51:       }
52:     }
53:     return pages;
54:   };
55:   return (
56:     <div className="flex items-center justify-center gap-2">
57:       <Button
58:         variant="outline"
59:         onClick={() => onPageChange(currentPage - 1)}
60:         disabled={currentPage <= 1}
61:         className="px-2"
62:       >
63:         <ChevronLeft className="h-4 w-4" />
64:       </Button>
65:       {renderPageNumbers()}
66:       <Button
67:         variant="outline"
68:         onClick={() => onPageChange(currentPage + 1)}
69:         disabled={currentPage >= totalPages}
70:         className="px-2"
71:       >
72:         <ChevronRight className="h-4 w-4" />
73:       </Button>
74:     </div>
75:   );
76: }
</file>

