 55:       new Date(dto.startAt) > new Date(dto.endAt)
 56:     ) {
 57:       throw new BadRequestException('startAt must be <= endAt');
 58:     }
 59:     if (dto.position !== undefined) {
 60:       const existingBanner = await this.prisma.banner.findFirst({
 61:         where: {
 62:           position: dto.position,
 63:           id: { not: id },
 64:         },
 65:       });
 66:       if (existingBanner) {
 67:         const total = await this.prisma.banner.count();
 68:         throw new BadRequestException(
 69:           `Position ${dto.position} is already taken. Total banners: ${total}. Please choose a different position.`,
 70:         );
 71:       }
 72:     }
 73:     const ops: Prisma.PrismaPromise<any>[] = [];
 74:     ops.push(
 75:       this.prisma.banner.update({
 76:         where: { id },
 77:         data: {
 78:           title: dto.title,
 79:           subtitle: dto.subtitle,
 80:           link: dto.link,
 81:           linkType: dto.linkType,
 82:           position: dto.position,
 83:           isActive: dto.isActive,
 84:           startAt: dto.startAt ? new Date(dto.startAt) : undefined,
 85:           endAt: dto.endAt ? new Date(dto.endAt) : undefined,
 86:         },
 87:       }),
 88:     );
 89:     if (dto.images) {
 90:       ops.push(this.prisma.bannerImage.deleteMany({ where: { bannerId: id } }));
 91:       ops.push(
 92:         this.prisma.bannerImage.createMany({
 93:           data: dto.images.map((url) => ({ bannerId: id, url })),
 94:         }),
 95:       );
 96:     }
 97:     await this.prisma.$transaction(ops);
 98:     return this.prisma.banner.findUnique({
 99:       where: { id },
100:       include: { images: true },
101:     });
102:   }
103:   async remove(id: string) {
104:     return this.prisma.banner.delete({ where: { id } });
105:   }
106:   async listPublic() {
107:     const now = new Date();
108:     return this.prisma.banner.findMany({
109:       where: {
110:         isActive: true,
111:         AND: [
112:           { OR: [{ startAt: null }, { startAt: { lte: now } }] },
113:           { OR: [{ endAt: null }, { endAt: { gte: now } }] },
114:         ],
115:       },
116:       orderBy: { position: 'asc' },
117:       include: { images: true },
118:     });
119:   }
