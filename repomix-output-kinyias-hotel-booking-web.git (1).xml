  1: 'use client';
  2: import React, { useEffect, useState, useRef } from 'react';
  3: import { useForm } from 'react-hook-form';
  4: import { zodResolver } from '@hookform/resolvers/zod';
  5: import {
  6:   Dialog,
  7:   DialogContent,
  8:   DialogDescription,
  9:   DialogFooter,
 10:   DialogHeader,
 11:   DialogTitle,
 12: } from '@/components/ui/dialog';
 13: import {
 14:   Form,
 15:   FormControl,
 16:   FormField,
 17:   FormItem,
 18:   FormLabel,
 19:   FormMessage,
 20: } from '@/components/ui/form';
 21: import { Input } from '@/components/ui/input';
 22: import { Badge } from '@/components/ui/badge';
 23: import { Button } from '@/components/ui/button';
 24: import {
 25:   Command,
 26:   CommandList,
 27:   CommandItem,
 28: } from '@/components/ui/command';
 29: import { CommissionPackage } from '../types';
 30: import { useHotelsQuery } from '@/features/hotels/queries';
 31: import { assignCommissionToHotelsSchema, AssignCommissionToHotelsFormValues } from '../validator';
 32: import { useSetHotelCommissionPackageMutation } from '../mutations';
 33: import toast from 'react-hot-toast';
 34: interface CommissionAssignToHotelsDialogProps {
 35:   open: boolean;
 36:   onOpenChange: (open: boolean) => void;
 37:   commissionPackage: CommissionPackage | null;
 38: }
 39: export default function CommissionAssignToHotelsDialog({
 40:   open,
 41:   onOpenChange,
 42:   commissionPackage,
 43: }: CommissionAssignToHotelsDialogProps) {
 44:   const { data: hotelsData } = useHotelsQuery({ limit: 100 });
 45:   const setCommissionMutation = useSetHotelCommissionPackageMutation();
 46:   const [inputValue, setInputValue] = useState('');
 47:   const [openPopover, setOpenPopover] = useState(false);
 48:   const inputRef = useRef<HTMLInputElement>(null);
 49:   const hotels = hotelsData?.data || [];
 50:   const form = useForm<AssignCommissionToHotelsFormValues>({
 51:     resolver: zodResolver(assignCommissionToHotelsSchema),
 52:     defaultValues: {
 53:       hotelIds: [],
 54:     },
 55:   });
 56:   useEffect(() => {
 57:     if (open) {
 58:       form.reset({ hotelIds: [] });
 59:       setInputValue('');
 60:     }
 61:   }, [open, form]);
 62:   const onSubmit = async (values: AssignCommissionToHotelsFormValues) => {
 63:     if (!commissionPackage) return;
 64:     try {
 65:       const promises = values.hotelIds.map((hotelId) =>
 66:         setCommissionMutation.mutateAsync({
 67:           hotelId,
 68:           commissionPackageId: commissionPackage.id,
 69:         })
 70:       );
 71:       await Promise.all(promises);
 72:       toast.success(`Commission package assigned to ${values.hotelIds.length} hotels`);
 73:       onOpenChange(false);
 74:     } catch (error) {
 75:       console.error(error);
 76:       toast.error('Failed to assign commission package to some hotels');
 77:     }
 78:   };
 79:   return (
 80:     <Dialog open={open} onOpenChange={onOpenChange}>
 81:       <DialogContent className="max-w-lg">
 82:         <DialogHeader>
 83:           <DialogTitle>Assign Hotels to {commissionPackage?.name}</DialogTitle>
 84:           <DialogDescription>
 85:             Search and select hotels to assign to this commission package.
 86:           </DialogDescription>
 87:         </DialogHeader>
 88:         <Form {...form}>
 89:           <form onSubmit={form.handleSubmit(onSubmit)} className="space-y-6">
 90:             <FormField
 91:               control={form.control}
 92:               name="hotelIds"
 93:               render={({ field }) => {
 94:                 const selectedHotels = hotels.filter((h) => field.value.includes(h.id));
 95:                 const filteredSuggestions = hotels.filter(
 96:                   (h) =>
 97:                     h.name.toLowerCase().includes(inputValue.toLowerCase()) &&
 98:                     !field.value.includes(h.id)
 99:                 );
100:                 const addHotel = (id: string) => {
101:                   field.onChange([...field.value, id]);
102:                   setInputValue('');
103:                   inputRef.current?.focus();
104:                 };
105:                 const removeHotel = (id: string) => {
106:                   field.onChange(field.value.filter((hotelId) => hotelId !== id));
107:                 };
108:                 return (
109:                   <FormItem>
110:                     <FormLabel>Hotels</FormLabel>
111:                     <FormControl>
112:                       <div className="space-y-3">
113:                         {selectedHotels.length > 0 && (
114:                           <div className="flex flex-wrap gap-2">
115:                             {selectedHotels.map((hotel) => (
116:                               <Badge
117:                                 key={hotel.id}
118:                                 variant="secondary"
119:                                 className="cursor-pointer"
120:                                 onClick={() => removeHotel(hotel.id)}
121:                               >
122:                                 {hotel.name} ✕
123:                               </Badge>
124:                             ))}
125:                           </div>
126:                         )}
127:                         <div className="relative">
128:                           <Input
129:                             ref={inputRef}
130:                             placeholder="Search hotels..."
131:                             value={inputValue}
132:                             onChange={(e) => {
133:                               setInputValue(e.target.value);
134:                               setOpenPopover(e.target.value.length > 0);
135:                             }}
136:                             onFocus={() => setOpenPopover(inputValue.length > 0)}
137:                             onBlur={() => setTimeout(() => setOpenPopover(false), 200)}
138:                           />
139:                           {openPopover && filteredSuggestions.length > 0 && (
140:                             <div className="absolute z-50 w-full mt-1 rounded-md border bg-popover text-popover-foreground shadow-md outline-none animate-in">
141:                               <Command>
142:                                 <CommandList>
143:                                   {filteredSuggestions.map((hotel) => (
144:                                     <CommandItem
145:                                       key={hotel.id}
146:                                       onMouseDown={(e) => {
147:                                         e.preventDefault();
148:                                         addHotel(hotel.id);
149:                                       }}
150:                                       className="cursor-pointer"
151:                                     >
152:                                       {hotel.name}
153:                                     </CommandItem>
154:                                   ))}
155:                                 </CommandList>
156:                               </Command>
157:                             </div>
158:                           )}
159:                         </div>
160:                         <FormMessage />
161:                       </div>
162:                     </FormControl>
163:                   </FormItem>
164:                 );
165:               }}
166:             />
167:             <DialogFooter>
168:               <Button
169:                 type="button"
170:                 variant="outline"
171:                 onClick={() => onOpenChange(false)}
172:               >
173:                 Cancel
174:               </Button>
175:               <Button type="submit" disabled={setCommissionMutation.isPending}>
176:                 {setCommissionMutation.isPending ? 'Assigning...' : 'Assign Hotels'}
177:               </Button>
178:             </DialogFooter>
179:           </form>
180:         </Form>
181:       </DialogContent>
182:     </Dialog>
183:   );
184: }
</file>

