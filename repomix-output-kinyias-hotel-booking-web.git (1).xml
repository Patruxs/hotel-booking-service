 19: export default function AmenitiesPage() {
 20:   const [search, setSearch] = useState('');
 21:   const [page, setPage] = useState(1);
 22:   const pageSize = 10;
 23:   // Pass pagination and search params to the query
 24:   const { data, isLoading, isError } = useGetAmenitiesQuery({
 25:     limit: pageSize,
 26:     page,
 27:     q: search || undefined,
 28:   });
 29:   const amenities = data?.data ?? [];
 30:   const total = data?.meta?.total ?? 0;
 31:   const totalPages = Math.max(1, Math.ceil(total / pageSize));
 32:   if (isError)
 33:     return <div className="p-6 text-red-500">Failed to load amenities.</div>;
 34:   return (
 35:     <div className="container mx-auto py-6 space-y-4" style={{display: 'block'}}>
 36:       <div className="flex items-center justify-between mb-4">
 37:         <h1 className="text-2xl font-bold">Amenities</h1>
 38:         <div className="flex items-center gap-2">
 39:           <Input
 40:             placeholder="Search by label..."
 41:             value={search}
 42:             onChange={(e) => {
 43:               setSearch(e.target.value);
 44:               setPage(1);
 45:             }}
 46:             className="w-64"
 47:           />
 48:           <Link href="/admin/amenities/new">
 49:                 <Button className="bg-primary hover:bg-primary/90 text-primary-foreground">
 50:                   <Icons.Plus size={20} className="mr-2" />
 51:                   Add Amenity
 52:                 </Button>
 53:                 </Link>
 54:         </div>
 55:       </div>
 56:       {isLoading? (<div className="p-6">Loading amenities...</div>): (
 57:         <div>
 58:       <Card className="overflow-hidden mb-5">
 59:         <Table className="table-fixed w-full">
 60:           <TableHeader>
 61:             <TableRow className="bg-secondary/50">
 62:               <TableHead className="w-1/6">Icon</TableHead>
 63:               <TableHead className="w-3/6">Label</TableHead>
 64:               <TableHead className="w-2/6">Key</TableHead>
 65:               <TableHead className="w-1/6">Actions</TableHead>
 66:             </TableRow>
 67:           </TableHeader>
 68:           <TableBody>
