19:   }, [mode, breakpoint])
20:   return !!matches
21: }
</file>

<file path="apps/web/src/hooks/use-menu-navigation.ts">
  1: "use client"
  2: import type { Editor } from "@tiptap/react"
  3: import { useEffect, useState } from "react"
  4: type Orientation = "horizontal" | "vertical" | "both"
  5: interface MenuNavigationOptions<T> {
  6:   editor?: Editor | null
  7:   containerRef?: React.RefObject<HTMLElement | null>
  8:   query?: string
  9:   items: T[]
 10:   onSelect?: (item: T) => void
 11:   onClose?: () => void
 12:   orientation?: Orientation
 13:   autoSelectFirstItem?: boolean
 14: }
 15: export function useMenuNavigation<T>({
 16:   editor,
 17:   containerRef,
 18:   query,
 19:   items,
 20:   onSelect,
 21:   onClose,
 22:   orientation = "vertical",
 23:   autoSelectFirstItem = true,
 24: }: MenuNavigationOptions<T>) {
 25:   const [selectedIndex, setSelectedIndex] = useState<number>(
 26:     autoSelectFirstItem ? 0 : -1
 27:   )
 28:   useEffect(() => {
 29:     const handleKeyboardNavigation = (event: KeyboardEvent) => {
 30:       if (!items.length) return false
 31:       const moveNext = () =>
 32:         setSelectedIndex((currentIndex) => {
 33:           if (currentIndex === -1) return 0
 34:           return (currentIndex + 1) % items.length
 35:         })
 36:       const movePrev = () =>
 37:         setSelectedIndex((currentIndex) => {
 38:           if (currentIndex === -1) return items.length - 1
 39:           return (currentIndex - 1 + items.length) % items.length
 40:         })
 41:       switch (event.key) {
 42:         case "ArrowUp": {
 43:           if (orientation === "horizontal") return false
 44:           event.preventDefault()
 45:           movePrev()
 46:           return true
 47:         }
 48:         case "ArrowDown": {
 49:           if (orientation === "horizontal") return false
 50:           event.preventDefault()
 51:           moveNext()
 52:           return true
 53:         }
 54:         case "ArrowLeft": {
 55:           if (orientation === "vertical") return false
 56:           event.preventDefault()
 57:           movePrev()
 58:           return true
 59:         }
 60:         case "ArrowRight": {
 61:           if (orientation === "vertical") return false
 62:           event.preventDefault()
 63:           moveNext()
 64:           return true
 65:         }
 66:         case "Tab": {
 67:           event.preventDefault()
 68:           if (event.shiftKey) {
 69:             movePrev()
 70:           } else {
 71:             moveNext()
 72:           }
 73:           return true
 74:         }
 75:         case "Home": {
 76:           event.preventDefault()
 77:           setSelectedIndex(0)
 78:           return true
 79:         }
 80:         case "End": {
 81:           event.preventDefault()
 82:           setSelectedIndex(items.length - 1)
 83:           return true
 84:         }
 85:         case "Enter": {
 86:           if (event.isComposing) return false
 87:           event.preventDefault()
 88:           if (selectedIndex !== -1 && items[selectedIndex]) {
 89:             onSelect?.(items[selectedIndex])
 90:           }
 91:           return true
 92:         }
 93:         case "Escape": {
 94:           event.preventDefault()
 95:           onClose?.()
 96:           return true
 97:         }
 98:         default:
 99:           return false
100:       }
101:     }
102:     let targetElement: HTMLElement | null = null
103:     if (editor) {
104:       targetElement = editor.view.dom
105:     } else if (containerRef?.current) {
106:       targetElement = containerRef.current
107:     }
108:     if (targetElement) {
109:       targetElement.addEventListener("keydown", handleKeyboardNavigation, true)
110:       return () => {
111:         targetElement?.removeEventListener(
112:           "keydown",
113:           handleKeyboardNavigation,
114:           true
115:         )
116:       }
117:     }
118:     return undefined
119:   }, [
120:     editor,
121:     containerRef,
122:     items,
123:     selectedIndex,
124:     onSelect,
125:     onClose,
126:     orientation,
127:   ])
128:   useEffect(() => {
129:     if (query) {
130:       setSelectedIndex(autoSelectFirstItem ? 0 : -1)
131:     }
132:   }, [query, autoSelectFirstItem])
133:   return {
134:     selectedIndex: items.length ? selectedIndex : undefined,
135:     setSelectedIndex,
136:   }
137: }
</file>

