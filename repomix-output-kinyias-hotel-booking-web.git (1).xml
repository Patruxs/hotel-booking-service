 16: function NewsContent() {
 17:   const searchParams = useSearchParams();
 18:   const router = useRouter();
 19:   const pathname = usePathname();
 20:   const page = Number(searchParams.get('page')) || 1;
 21:   const q = searchParams.get('q') || '';
 22:   const limit = 9; // Display 9 items per page
 23:   const [searchTerm, setSearchTerm] = useState(q);
 24:   const debouncedSearch = useDebounce(searchTerm, 500);
 25:   // Sync searchTerm with URL when URL changes explicitly (e.g. back button)
 26:   useEffect(() => {
 27:     setSearchTerm(searchParams.get('q') || '');
 28:   }, [searchParams]);
 29:   const { data, isLoading, isError } = usePublicNewsListQuery({
 30:     page,
 31:     limit,
 32:     q,
 33:   });
 34:   const newsItems = data?.items || [];
 35:   const totalItems = data?.total || 0;
 36:   const totalPages = Math.ceil(totalItems / limit);
 37:   const handlePageChange = (newPage: number) => {
 38:     const params = new URLSearchParams(searchParams);
 39:     params.set('page', newPage.toString());
 40:     router.push(`${pathname}?${params.toString()}`);
 41:   };
 42:   const handleSearch = (term: string) => {
 43:     setSearchTerm(term);
 44:   };
 45:   useEffect(() => {
 46:     const timer = setTimeout(() => {
 47:       if (debouncedSearch !== q) {
 48:         const params = new URLSearchParams(searchParams);
 49:         if (debouncedSearch) {
 50:           params.set('q', debouncedSearch);
 51:         } else {
 52:           params.delete('q');
 53:         }
 54:         params.set('page', '1');
 55:         router.push(`${pathname}?${params.toString()}`);
 56:       }
 57:     }, 500);
 58:     return () => clearTimeout(timer);
 59:   }, [debouncedSearch, q, router, pathname, searchParams]);
 60:   if (isLoading) {
 61:     return (
 62:       <div className="container mx-auto py-12 px-4">
 63:         <div className="flex justify-between items-center mb-8">
 64:            <Skeleton className="h-10 w-64" />
 65:         </div>
 66:         <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
 67:           {[...Array(6)].map((_, i) => (
 68:             <Card key={i} className="overflow-hidden border-none shadow-lg h-full flex flex-col">
 69:                <Skeleton className="h-48 w-full" />
 70:                <CardContent className="flex-grow p-6 space-y-4">
 71:                  <Skeleton className="h-6 w-3/4" />
 72:                  <Skeleton className="h-4 w-full" />
